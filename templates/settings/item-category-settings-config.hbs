<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Категории предметов</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="migratePresetSettings"><i class="fa-solid fa-code-compare"></i> Мигрировать из других пресетов</button>
        <button type="button" data-action="createCategory"><i class="fa-solid fa-plus"></i> Создать категорию</button>
      </div>
    </header>

    <div class="fallout-maw-settings-table item-category-settings">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span></span>
        <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
        <span></span>
      </div>
      {{#each categories}}
      <div class="fallout-maw-settings-row" data-item-category-row>
        <button type="button" class="fallout-maw-drag-handle" data-drag-handle title="{{localize 'FALLOUTMAW.Common.Reorder'}}"><i class="fa-solid fa-grip-lines"></i></button>
        <input type="text" data-field="label" value="{{label}}">
        <button type="button" data-action="deleteCategory" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">Категории предметов не созданы.</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
