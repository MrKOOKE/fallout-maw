<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{limb.label}}</h2>
      <p class="hint">{{limb.key}}</p>
    </header>

    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Максимальное состояние конечности</span>
        <input type="number" name="limb.stateMax" value="{{limb.stateMax}}" min="0" step="1">
      </label>
      <label>
        <span>Множитель урона</span>
        <input type="number" name="limb.damageMultiplier" value="{{limb.damageMultiplier}}" min="0" step="0.1">
      </label>
      <label>
        <span>Доп. сложность поражения, % от уклонения</span>
        <input type="number" name="limb.aimedDifficultyPercent" value="{{limb.aimedDifficultyPercent}}" step="1">
      </label>
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
