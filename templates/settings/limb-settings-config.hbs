<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{limb.label}}</h2>
      <p class="hint">{{limb.key}}</p>
    </header>

    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Максимальное состояние конечности</span>
        <input type="text" name="limb.stateMax" value="{{limb.stateMax}}" data-formula-autocomplete="all">
      </label>
      <label>
        <span>Базовый лимит имплантов</span>
        <input type="number" name="limb.implantLimit" value="{{limb.implantLimit}}" min="0" step="1">
      </label>
      <label>
        <span>Множитель урона</span>
        <input type="number" name="limb.damageMultiplier" value="{{limb.damageMultiplier}}" min="0" step="0.1">
      </label>
      <label>
        <span>Доп. сложность поражения, % от уклонения</span>
        <input type="number" name="limb.aimedDifficultyPercent" value="{{limb.aimedDifficultyPercent}}" step="1">
      </label>
      <div>
        <span>Критическая часть тела</span>
        <input aria-label="Критическая часть тела" type="checkbox" name="limb.critical" {{#if limb.critical}}checked{{/if}}>
      </div>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Эффекты утраты</h2>
      {{#if limb.critical}}
      <p class="hint">Критическая часть тела при утрате вызывает смерть; отдельные дебафы утраты недоступны.</p>
      {{else}}
      <p class="hint">Работает как эффекты травм, но применяется при состоянии -100% и удаляется при восстановлении части тела.</p>
      {{/if}}
    </header>

    {{#unless limb.critical}}
    <div class="fallout-maw-trauma-effect-table">
      <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
        <span>Ключ</span>
        <span>Тип</span>
        <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
        <span>Приоритет</span>
        <span></span>
      </div>
      {{#each limb.lossEffects}}
      <div class="fallout-maw-trauma-effect-row" data-limb-loss-effect="{{index}}">
        <input type="text" data-limb-loss-effect-key data-effect-key-autocomplete value="{{key}}">
        <select data-limb-loss-effect-type>
          <option value="add" {{#if addSelected}}selected{{/if}}>{{localize "FALLOUTMAW.Effects.ChangeAdd"}}</option>
          <option value="multiply" {{#if multiplySelected}}selected{{/if}}>Процент</option>
          <option value="override" {{#if overrideSelected}}selected{{/if}}>{{localize "FALLOUTMAW.Effects.ChangeOverride"}}</option>
        </select>
        <input type="text" data-limb-loss-effect-value value="{{value}}">
        <input type="number" data-limb-loss-effect-priority value="{{priority}}">
        <button type="button" data-action="deleteLossEffect" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Effects.NoChanges"}}</p>
      {{/each}}
    </div>
    <button type="button" data-action="addLossEffect"><i class="fa-solid fa-plus"></i> Добавить эффект</button>
    {{/unless}}
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
