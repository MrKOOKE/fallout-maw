<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel" hidden>
    <header class="fallout-maw-panel-header">
      <h2>{{damageType.label}}</h2>
      <p class="hint">{{damageType.key}}</p>
    </header>

    <div class="fallout-maw-list-grid two-columns" hidden>
      <label hidden>
        <span>Множитель состояния конечности</span>
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <label class="fallout-maw-section-toggle">
        <input type="hidden" name="settings.bleeding.enabled" value="false">
        <input type="checkbox" name="settings.bleeding.enabled" value="true" {{checked settings.bleeding.enabled}}>
        <span>Кровотечение</span>
      </label>
    </header>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Название эффекта</span>
        <input type="text" name="settings.bleeding.effectName" value="{{settings.bleeding.effectName}}">
      </label>
      <label>
        <span>Изображение эффекта</span>
        <file-picker type="image" name="settings.bleeding.img" value="{{settings.bleeding.img}}"></file-picker>
      </label>
      <label>
        <span>% от прошедшего урона</span>
        <input type="number" name="settings.bleeding.percent" value="{{settings.bleeding.percent}}" min="0" max="100" step="1">
      </label>
      <label>
        <span>Длительность, секунд</span>
        <input type="number" name="settings.bleeding.durationSeconds" value="{{settings.bleeding.durationSeconds}}" min="1" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <label class="fallout-maw-section-toggle">
        <input type="hidden" name="settings.equipmentConditionDamage.enabled" value="false">
        <input type="checkbox" name="settings.equipmentConditionDamage.enabled" value="true" {{checked settings.equipmentConditionDamage.enabled}}>
        <span>Повреждение защитного снаряжения</span>
      </label>
    </header>
    <label>
      <span>Формула износа</span>
      <input type="text" name="settings.equipmentConditionDamage.formula" value="{{settings.equipmentConditionDamage.formula}}">
    </label>
    <p class="hint">Переменные: incoming, final, blocked, protected, penetrated, condition, conditionMax, mitigation, penetration.</p>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <label class="fallout-maw-section-toggle">
        <input type="hidden" name="settings.needIncrease.enabled" value="false">
        <input type="checkbox" name="settings.needIncrease.enabled" value="true" {{checked settings.needIncrease.enabled}}>
        <span>Увеличение потребности</span>
      </label>
    </header>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Потребность</span>
        <select name="settings.needIncrease.needKey">
          {{#each needOptions}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>% конвертации</span>
        <input type="number" name="settings.needIncrease.percent" value="{{settings.needIncrease.percent}}" min="0" step="1">
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Не наносить урон по ОЗ</span>
        <input type="hidden" name="settings.needIncrease.preventHealthDamage" value="false">
        <input type="checkbox" name="settings.needIncrease.preventHealthDamage" value="true" {{checked settings.needIncrease.preventHealthDamage}}>
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <label class="fallout-maw-section-toggle">
        <input type="hidden" name="settings.periodic.enabled" value="false">
        <input type="checkbox" name="settings.periodic.enabled" value="true" {{checked settings.periodic.enabled}}>
        <span>Периодический урон</span>
      </label>
    </header>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Название эффекта</span>
        <input type="text" name="settings.periodic.effectName" value="{{settings.periodic.effectName}}">
      </label>
      <label>
        <span>Изображение эффекта</span>
        <file-picker type="image" name="settings.periodic.img" value="{{settings.periodic.img}}"></file-picker>
      </label>
      <label>
        <span>% сразу</span>
        <input type="number" name="settings.periodic.immediatePercent" value="{{settings.periodic.immediatePercent}}" min="0" max="100" step="1">
      </label>
      <label>
        <span>% отложенно</span>
        <input type="number" name="settings.periodic.delayedPercent" value="{{settings.periodic.delayedPercent}}" min="0" max="100" step="1">
      </label>
      <label>
        <span>Тиков</span>
        <input type="number" name="settings.periodic.tickCount" value="{{settings.periodic.tickCount}}" min="0" step="1">
      </label>
      <label>
        <span>Интервал, секунд</span>
        <input type="number" name="settings.periodic.intervalSeconds" value="{{settings.periodic.intervalSeconds}}" min="1" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <label class="fallout-maw-section-toggle">
        <input type="hidden" name="settings.resourceLimit.enabled" value="false">
        <input type="checkbox" name="settings.resourceLimit.enabled" value="true" {{checked settings.resourceLimit.enabled}}>
        <span>Ограничение ресурсов</span>
      </label>
      <button type="button" data-action="addResourceLimit"><i class="fa-solid fa-plus"></i> Добавить ресурс</button>
    </header>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Название эффекта</span>
        <input type="text" name="settings.resourceLimit.effectName" value="{{settings.resourceLimit.effectName}}">
      </label>
      <label>
        <span>Изображение эффекта</span>
        <file-picker type="image" name="settings.resourceLimit.img" value="{{settings.resourceLimit.img}}"></file-picker>
      </label>
      <label>
        <span>Цвет ограничения</span>
        <input type="color" name="settings.resourceLimit.color" value="{{settings.resourceLimit.color}}">
      </label>
      <label>
        <span>Длительность, секунд</span>
        <input type="number" name="settings.resourceLimit.durationSeconds" value="{{settings.resourceLimit.durationSeconds}}" min="1" step="1">
      </label>
    </div>

    <div class="fallout-maw-resource-limit-list">
      {{#each resourceLimitRows}}
      <div class="fallout-maw-settings-row fallout-maw-resource-limit-row" data-resource-limit-row>
        <select name="settings.resourceLimit.resources.{{@index}}.resourceKey">
          {{#each options}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <label>
          <span>% ограничения</span>
          <input type="number" name="settings.resourceLimit.resources.{{@index}}.percent" value="{{percent}}" min="0" step="1">
        </label>
        <button type="button" class="fallout-maw-icon-button" data-action="deleteResourceLimit" aria-label="Удалить ресурс"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
