<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройка действий</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <div class="fallout-maw-settings-table fallout-maw-system-action-settings-table">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Image"}}</span>
        <span></span>
      </div>
      {{#each actions}}
      <div class="fallout-maw-settings-row" data-system-action-row data-action-key="{{key}}" data-action-label="{{label}}" data-tool-key="{{toolKey}}">
        <input type="text" value="{{label}}" disabled>
        <input type="text" data-field="img" value="{{img}}">
        <button type="button" data-action="browseActionImage" title="{{localize 'FALLOUTMAW.Common.Image'}}"><i class="fa-solid fa-image"></i></button>
      </div>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
