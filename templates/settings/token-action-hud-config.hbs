<div class="fallout-maw-config-body fallout-maw-token-action-hud-config">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройки HUD</h2>
    </header>

    <label class="fallout-maw-token-action-hud-scale-field">
      <span>Масштаб</span>
      <strong data-token-action-hud-scale-output>{{scale}}%</strong>
      <input type="range" name="scale" value="{{scale}}" min="{{min}}" max="{{max}}" step="1" data-token-action-hud-scale>
    </label>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> Сохранить</button>
  </footer>
</div>
