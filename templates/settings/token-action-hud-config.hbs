<div class="fallout-maw-config-body fallout-maw-token-action-hud-config">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.HUD.Title"}}</h2>
    </header>

    <div class="fallout-maw-token-action-hud-icon-grid">
      <section>
        <h3>Общие иконки</h3>
        <div class="fallout-maw-settings-table fallout-maw-token-action-hud-icon-table">
          {{#each damageIconRows}}
          <div class="fallout-maw-settings-row" data-hud-icon-section="{{section}}" data-hud-icon-key="{{key}}">
            <span>{{label}}</span>
            <img class="fallout-maw-token-action-hud-icon-preview" src="{{img}}" alt="" data-hud-icon-preview>
            <input type="text" data-hud-icon-input value="{{img}}">
            <button type="button" data-action="browseHudImage" title="{{localize 'FALLOUTMAW.Common.Image'}}"><i class="fa-solid fa-image"></i></button>
          </div>
          {{/each}}
        </div>
      </section>

      <section>
        <h3>Основные кнопки HUD</h3>
        <div class="fallout-maw-settings-table fallout-maw-token-action-hud-icon-table">
          {{#each mainActionIconRows}}
          <div class="fallout-maw-settings-row" data-hud-icon-section="{{section}}" data-hud-icon-key="{{key}}">
            <span>{{label}}</span>
            <img class="fallout-maw-token-action-hud-icon-preview" src="{{img}}" alt="" data-hud-icon-preview>
            <input type="text" data-hud-icon-input value="{{img}}">
            <button type="button" data-action="browseHudImage" title="{{localize 'FALLOUTMAW.Common.Image'}}"><i class="fa-solid fa-image"></i></button>
          </div>
          {{/each}}
        </div>
      </section>

      <section>
        <h3>Активные действия</h3>
        <div class="fallout-maw-settings-table fallout-maw-token-action-hud-icon-table">
          {{#each activeActionIconRows}}
