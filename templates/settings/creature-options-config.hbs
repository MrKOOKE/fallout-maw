<div class="fallout-maw-config-body">
  <div class="fallout-maw-two-pane">
    <aside class="fallout-maw-sidebar">
      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Types"}}</h2>
          <button type="button" data-action="createType"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateType"}}</button>
        </header>

        <div class="fallout-maw-option-list">
          {{#each typeOptions}}
          <div class="fallout-maw-option-row {{#if selected}}active{{/if}}">
            <button type="button" data-action="selectType" data-id="{{id}}">{{name}}</button>
            <button type="button" data-action="deleteType" data-id="{{id}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoTypes"}}</p>
          {{/each}}
        </div>
      </section>

      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Races"}}</h2>
          <button type="button" data-action="createRace"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateRace"}}</button>
        </header>

        <div class="fallout-maw-race-group-list">
          {{#each raceGroups}}
          <div class="fallout-maw-race-group">
            <h3>{{name}}</h3>
            <div class="fallout-maw-option-list">
              {{#each races}}
              <div class="fallout-maw-option-row {{#if selected}}active{{/if}}">
                <button type="button" data-action="selectRace" data-id="{{id}}">{{name}}</button>
                <button type="button" data-action="deleteRace" data-id="{{id}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{/each}}
            </div>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoRaces"}}</p>
          {{/each}}
        </div>
      </section>
    </aside>

    <main class="fallout-maw-editor-pane">
      {{#if editingType}}
      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.type.cssClass}}" data-creature-section="type">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.type.ariaExpanded}}"><i class="fa-solid {{sections.type.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.TypeSection"}}</span></button>
        </header>
        <label>
          <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
          <input type="text" name="type.name" value="{{selectedType.name}}">
        </label>
      </section>
      {{else}}
      {{#if editingRace}}
      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.race.cssClass}}" data-creature-section="race">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.race.ariaExpanded}}"><i class="fa-solid {{sections.race.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.RaceSection"}}</span></button>
        </header>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
            <input type="text" name="race.name" value="{{selectedRace.name}}">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.TypeSection"}}</span>
            <select name="race.typeId">
              {{#each typeOptions}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.base.cssClass}}" data-creature-section="base">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.base.ariaExpanded}}"><i class="fa-solid {{sections.base.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.BaseParameters"}}</span></button>
        </header>
        <div class="fallout-maw-race-characteristic-grid">
          {{#each characteristics}}
          <label class="fallout-maw-stacked-field">
            <span title="{{abbr}}">{{label}}</span>
            <input type="number" name="race.characteristics.{{key}}" value="{{value}}">
          </label>
          {{/each}}
        </div>
        <div class="fallout-maw-race-pool-grid">
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.CharacteristicDistributionPoints"}}</span>
            <input type="number" name="race.baseParameters.characteristicDistributionPoints" value="{{baseParameters.characteristicDistributionPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.SignatureSkillPoints"}}</span>
            <input type="number" name="race.baseParameters.signatureSkillPoints" value="{{baseParameters.signatureSkillPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.TraitPoints"}}</span>
            <input type="number" name="race.baseParameters.traitPoints" value="{{baseParameters.traitPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.ProficiencyPoints"}}</span>
            <input type="number" name="race.baseParameters.proficiencyPoints" value="{{baseParameters.proficiencyPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Common.Load"}}</span>
            <input type="text" name="race.baseParameters.loadFormula" value="{{baseParameters.loadFormula}}" placeholder="20 + 10*str">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>Предел нагрузки (% от базы)</span>
            <input type="number" name="race.baseParameters.loadLimitPercent" value="{{baseParameters.loadLimitPercent}}" min="0" step="1">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.development.cssClass}}" data-creature-section="development">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.development.ariaExpanded}}"><i class="fa-solid {{sections.development.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.Development"}}</span></button>
        </header>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.SkillPointsPerLevel"}}</span>
            <input type="text" name="race.progression.skillPointsPerLevel" value="{{selectedRace.progression.skillPointsPerLevel}}" data-formula-autocomplete="characteristics">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.ResearchPointsPerLevel"}}</span>
            <input type="text" name="race.progression.researchPointsPerLevel" value="{{selectedRace.progression.researchPointsPerLevel}}" data-formula-autocomplete="characteristics">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.regeneration.cssClass}}" data-creature-section="regeneration">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.regeneration.ariaExpanded}}"><i class="fa-solid {{sections.regeneration.iconClass}}"></i><span>Регенерация</span></button>
        </header>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Common.Formula"}}</span>
            <input type="text" name="race.regeneration.formula" value="{{regeneration.formula}}" data-formula-autocomplete="all">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.limbs.cssClass}}" data-creature-section="limbs">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.limbs.ariaExpanded}}"><i class="fa-solid {{sections.limbs.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.Limbs"}}</span></button>
          <button type="button" data-action="createLimb"><i class="fa-solid fa-plus"></i> Добавить конечность</button>
        </header>

        <div class="fallout-maw-settings-table limb-settings">
          {{#each limbs}}
          <div class="fallout-maw-settings-row" data-limb-row>
            <input type="text" data-field="key" value="{{key}}" placeholder="Код" title="Код конечности">
            <input type="text" data-field="label" value="{{label}}">
            <button type="button" class="fallout-maw-icon-button" data-action="openLimbSettings" title="Доп. настройки конечности"><i class="fa-solid fa-gear"></i></button>
            <button type="button" data-action="deleteLimb" data-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoLimbs"}}</p>
          {{/each}}
        </div>

        <div class="fallout-maw-settings-actions">
          <button type="button" data-action="configureLimbSilhouette"><i class="fa-solid fa-person"></i> Настроить силуэт</button>
          {{#if hasLimbSilhouette}}<span class="hint">Силуэт настроен.</span>{{/if}}
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.equipment.cssClass}}" data-creature-section="equipment">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.equipment.ariaExpanded}}"><i class="fa-solid {{sections.equipment.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.EquipmentWeaponSlots"}}</span></button>
        </header>

        <div class="fallout-maw-equipment-config-grid">
          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.EquipmentSlots"}}</h3>
              <button type="button" data-action="createEquipmentSlot"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateEquipmentSlot"}}</button>
            </header>

            <div class="fallout-maw-settings-table equipment-slot-settings">
              {{#each equipmentSlots}}
              <div class="fallout-maw-settings-row" data-equipment-slot-row>
                <input type="hidden" data-field="key" value="{{key}}">
                <input type="text" data-field="label" value="{{label}}">
                <button type="button" data-action="deleteEquipmentSlot" data-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
              {{/each}}
            </div>
          </div>

          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.WeaponSets"}}</h3>
              <button type="button" data-action="createWeaponSet"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateWeaponSet"}}</button>
            </header>

            <div class="fallout-maw-weapon-set-list">
              {{#each weaponSets}}
              <div class="fallout-maw-weapon-set-config" data-weapon-set-row>
                <header class="fallout-maw-weapon-set-header">
                  <input type="hidden" data-field="key" value="{{key}}">
                  <input type="text" data-field="label" value="{{label}}">
                  <button type="button" data-action="createWeaponSlot" data-set-key="{{key}}" title="{{localize 'FALLOUTMAW.Settings.CreatureOptions.CreateWeaponSlot'}}"><i class="fa-solid fa-plus"></i></button>
                  <button type="button" data-action="deleteWeaponSet" data-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                </header>

                <div class="fallout-maw-settings-table weapon-slot-settings">
                  {{#each slots}}
                  <div class="fallout-maw-settings-row" data-weapon-slot-row>
                    <input type="hidden" data-field="key" value="{{key}}">
                    <select data-field="limbKey">
                      {{#each limbOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <button type="button" data-action="deleteWeaponSlot" data-set-key="{{../key}}" data-slot-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                  </div>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSlots"}}</p>
                  {{/each}}
                </div>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
              {{/each}}
            </div>
          </div>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.natural.cssClass}}" data-creature-section="natural">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.natural.ariaExpanded}}"><i class="fa-solid {{sections.natural.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.NaturalWeaponsFeatures"}}</span></button>
        </header>

        <div class="fallout-maw-equipment-config-grid fallout-maw-natural-race-config-grid">
          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.NaturalWeapons"}}</h3>
              <button type="button" data-action="createNaturalWeapon"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateNaturalWeapon"}}</button>
            </header>

            <div class="fallout-maw-settings-table fallout-maw-natural-item-settings">
              {{#each naturalWeapons}}
              <div class="fallout-maw-settings-row fallout-maw-natural-item-row" data-natural-weapon-row data-natural-item-id="{{id}}">
                <img src="{{img}}" alt="">
                <span>{{name}}</span>
                <button type="button" class="fallout-maw-icon-button" data-action="editNaturalWeapon" title="{{localize 'FALLOUTMAW.Common.Edit'}}"><i class="fa-solid fa-pen"></i></button>
                <button type="button" class="fallout-maw-icon-button" data-action="deleteNaturalWeapon" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoNaturalWeapons"}}</p>
              {{/each}}
            </div>
          </div>

          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.NaturalFeatures"}}</h3>
              <button type="button" data-action="addNaturalFeature"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.AddNaturalFeature"}}</button>
            </header>

            <div class="fallout-maw-settings-table fallout-maw-natural-item-settings">
              {{#each naturalFeatures}}
              <div class="fallout-maw-settings-row fallout-maw-natural-item-row" data-natural-feature-row data-natural-item-id="{{id}}">
                <img src="{{img}}" alt="">
                <span>{{name}}</span>
                <button type="button" class="fallout-maw-icon-button" data-action="editNaturalFeature" title="{{localize 'FALLOUTMAW.Common.Edit'}}"><i class="fa-solid fa-pen"></i></button>
                <button type="button" class="fallout-maw-icon-button" data-action="deleteNaturalFeature" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoNaturalFeatures"}}</p>
              {{/each}}
            </div>
          </div>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.inventory.cssClass}}" data-creature-section="inventory">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.inventory.ariaExpanded}}"><i class="fa-solid {{sections.inventory.iconClass}}"></i><span>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventorySize"}}</span></button>
        </header>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventoryColumns"}}</span>
            <input type="number" name="race.inventorySize.columns" value="{{inventorySize.columns}}" min="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventoryRows"}}</span>
            <input type="number" name="race.inventorySize.rows" value="{{inventorySize.rows}}" min="1">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.resistances.cssClass}}" data-creature-section="resistances">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.resistances.ariaExpanded}}"><i class="fa-solid {{sections.resistances.iconClass}}"></i><span>{{localize "FALLOUTMAW.Common.DamageResistances"}}</span></button>
        </header>
        <p class="hint">{{localize "FALLOUTMAW.Settings.CreatureOptions.DamageResistanceFormulaHint"}}</p>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>Сопротивление кровотечению</span>
            <input type="text" name="race.bleedingResistanceFormula" value="{{bleedingResistanceFormula}}" data-formula-autocomplete="all">
          </label>
          {{#each resistanceDamageTypes}}
          <label>
            <span>{{label}}</span>
            <input type="text" name="race.damageResistances.{{key}}" value="{{formula}}" data-formula-autocomplete="all">
          </label>
          {{/each}}
        </div>
      </section>

      <section class="fallout-maw-panel fallout-maw-collapsible-panel {{sections.needs.cssClass}}" data-creature-section="needs">
        <header class="fallout-maw-panel-header fallout-maw-collapsible-header">
          <button type="button" data-creature-section-toggle aria-expanded="{{sections.needs.ariaExpanded}}"><i class="fa-solid {{sections.needs.iconClass}}"></i><span>Потребности</span></button>
          <button type="button" data-action="createRaceNeed"><i class="fa-solid fa-plus"></i> Создать потребность</button>
        </header>

        <p class="hint">{{localize "FALLOUTMAW.Settings.Needs.FormulaHint"}}</p>

        <div class="fallout-maw-settings-table need-settings race-need-settings">
          <div class="fallout-maw-settings-row fallout-maw-grid-header">
            <span>{{localize "FALLOUTMAW.Common.Code"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Key"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Color"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Formula"}}</span>
            <span></span>
            <span></span>
          </div>
          {{#each needSettings}}
          <div class="fallout-maw-settings-row" data-race-need-row>
            <input type="text" data-field="abbr" value="{{abbr}}">
            <input type="text" data-field="key" value="{{key}}">
            <input type="text" data-field="label" value="{{label}}">
            <input type="color" data-field="color" value="{{color}}">
            <input type="text" data-field="formula" value="{{formula}}" data-formula-autocomplete="all">
            <button type="button" data-action="openRaceNeedSettings" title="Доп. настройки"><i class="fa-solid fa-gear"></i></button>
            <button type="button" data-action="deleteRaceNeed" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">Потребности не настроены.</p>
          {{/each}}
        </div>
      </section>
      {{else}}
      <section class="fallout-maw-panel fallout-maw-empty-editor">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.EmptyEditor"}}</h2>
        <p class="hint">{{localize "FALLOUTMAW.Settings.CreatureOptions.EmptyEditorHint"}}</p>
      </section>
      {{/if}}
      {{/if}}
    </main>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
