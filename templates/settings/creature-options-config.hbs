<div class="fallout-maw-config-body">
  <div class="fallout-maw-two-pane">
    <aside class="fallout-maw-sidebar">
      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Types"}}</h2>
          <button type="button" data-action="createType"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateType"}}</button>
        </header>

        <div class="fallout-maw-option-list">
          {{#each typeOptions}}
          <div class="fallout-maw-option-row {{#if selected}}active{{/if}}">
            <button type="button" data-action="selectType" data-id="{{id}}">{{name}}</button>
            <button type="button" data-action="deleteType" data-id="{{id}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoTypes"}}</p>
          {{/each}}
        </div>
      </section>

      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Races"}}</h2>
          <button type="button" data-action="createRace"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateRace"}}</button>
        </header>

        <div class="fallout-maw-race-group-list">
          {{#each raceGroups}}
          <div class="fallout-maw-race-group">
            <h3>{{name}}</h3>
            <div class="fallout-maw-option-list">
              {{#each races}}
              <div class="fallout-maw-option-row {{#if selected}}active{{/if}}">
                <button type="button" data-action="selectRace" data-id="{{id}}">{{name}}</button>
                <button type="button" data-action="deleteRace" data-id="{{id}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{/each}}
            </div>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoRaces"}}</p>
          {{/each}}
        </div>
      </section>
    </aside>

    <main class="fallout-maw-editor-pane">
      {{#if editingType}}
      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.TypeSection"}}</h2>
        <label>
          <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
          <input type="text" name="type.name" value="{{selectedType.name}}">
        </label>
      </section>
      {{else}}
      {{#if editingRace}}
      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.RaceSection"}}</h2>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
            <input type="text" name="race.name" value="{{selectedRace.name}}">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.TypeSection"}}</span>
            <select name="race.typeId">
              {{#each typeOptions}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.BaseParameters"}}</h2>
        <div class="fallout-maw-race-characteristic-grid">
          {{#each characteristics}}
          <label class="fallout-maw-stacked-field">
            <span title="{{abbr}}">{{label}}</span>
            <input type="number" name="race.characteristics.{{key}}" value="{{value}}">
          </label>
          {{/each}}
        </div>
        <div class="fallout-maw-race-pool-grid">
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.CharacteristicDistributionPoints"}}</span>
            <input type="number" name="race.baseParameters.characteristicDistributionPoints" value="{{baseParameters.characteristicDistributionPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.SignatureSkillPoints"}}</span>
            <input type="number" name="race.baseParameters.signatureSkillPoints" value="{{baseParameters.signatureSkillPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.TraitPoints"}}</span>
            <input type="number" name="race.baseParameters.traitPoints" value="{{baseParameters.traitPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.ProficiencyPoints"}}</span>
            <input type="number" name="race.baseParameters.proficiencyPoints" value="{{baseParameters.proficiencyPoints}}" min="0">
          </label>
          <label class="fallout-maw-stacked-field">
            <span>{{localize "FALLOUTMAW.Common.Load"}}</span>
            <input type="text" name="race.baseParameters.loadFormula" value="{{baseParameters.loadFormula}}" placeholder="20 + 10*str">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Development"}}</h2>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.SkillPointsPerLevel"}}</span>
            <input type="number" name="race.progression.skillPointsPerLevel" value="{{selectedRace.progression.skillPointsPerLevel}}" min="0">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.ResearchPointsPerLevel"}}</span>
            <input type="number" name="race.progression.researchPointsPerLevel" value="{{selectedRace.progression.researchPointsPerLevel}}" min="0">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.Limbs"}}</h2>
        </header>

        <div class="fallout-maw-settings-table limb-settings">
          {{#each limbs}}
          <div class="fallout-maw-settings-row" data-limb-row>
            <input type="hidden" data-field="key" value="{{key}}">
            <input type="text" data-field="label" value="{{label}}">
            <input type="number" data-field="stateMax" value="{{stateMax}}" min="0" placeholder="{{localize 'FALLOUTMAW.Settings.CreatureOptions.LimbStateMax'}}" title="{{localize 'FALLOUTMAW.Settings.CreatureOptions.LimbStateMax'}}">
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoLimbs"}}</p>
          {{/each}}
        </div>
      </section>

      <section class="fallout-maw-panel">
        <header class="fallout-maw-panel-header">
          <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.EquipmentWeaponSlots"}}</h2>
        </header>

        <div class="fallout-maw-equipment-config-grid">
          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.EquipmentSlots"}}</h3>
              <button type="button" data-action="createEquipmentSlot"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateEquipmentSlot"}}</button>
            </header>

            <div class="fallout-maw-settings-table equipment-slot-settings">
              {{#each equipmentSlots}}
              <div class="fallout-maw-settings-row" data-equipment-slot-row>
                <input type="hidden" data-field="key" value="{{key}}">
                <input type="text" data-field="label" value="{{label}}">
                <button type="button" data-action="deleteEquipmentSlot" data-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
              {{/each}}
            </div>
          </div>

          <div class="fallout-maw-settings-block">
            <header class="fallout-maw-panel-header">
              <h3>{{localize "FALLOUTMAW.Settings.CreatureOptions.WeaponSets"}}</h3>
              <button type="button" data-action="createWeaponSet"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.CreatureOptions.CreateWeaponSet"}}</button>
            </header>

            <div class="fallout-maw-weapon-set-list">
              {{#each weaponSets}}
              <div class="fallout-maw-weapon-set-config" data-weapon-set-row>
                <header class="fallout-maw-weapon-set-header">
                  <input type="hidden" data-field="key" value="{{key}}">
                  <input type="text" data-field="label" value="{{label}}">
                  <button type="button" data-action="createWeaponSlot" data-set-key="{{key}}" title="{{localize 'FALLOUTMAW.Settings.CreatureOptions.CreateWeaponSlot'}}"><i class="fa-solid fa-plus"></i></button>
                  <button type="button" data-action="deleteWeaponSet" data-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                </header>

                <div class="fallout-maw-settings-table weapon-slot-settings">
                  {{#each slots}}
                  <div class="fallout-maw-settings-row" data-weapon-slot-row>
                    <input type="hidden" data-field="key" value="{{key}}">
                    <select data-field="limbKey">
                      {{#each limbOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <button type="button" data-action="deleteWeaponSlot" data-set-key="{{../key}}" data-slot-key="{{key}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                  </div>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSlots"}}</p>
                  {{/each}}
                </div>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
              {{/each}}
            </div>
          </div>
        </div>
      </section>

      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventorySize"}}</h2>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventoryColumns"}}</span>
            <input type="number" name="race.inventorySize.columns" value="{{inventorySize.columns}}" min="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Settings.CreatureOptions.InventoryRows"}}</span>
            <input type="number" name="race.inventorySize.rows" value="{{inventorySize.rows}}" min="1">
          </label>
        </div>
      </section>

      <section class="fallout-maw-panel">
        <h2>{{localize "FALLOUTMAW.Common.DamageResistances"}}</h2>
        <p class="hint">{{localize "FALLOUTMAW.Settings.CreatureOptions.DamageFormulaHint"}}</p>
        <div class="fallout-maw-list-grid two-columns">
          {{#each damageTypes}}
          <label>
            <span>{{label}}</span>
            <input type="text" name="race.damageResistances.{{key}}" value="{{formula}}" data-formula-autocomplete="all">
          </label>
          {{/each}}
        </div>
      </section>
      {{else}}
      <section class="fallout-maw-panel fallout-maw-empty-editor">
        <h2>{{localize "FALLOUTMAW.Settings.CreatureOptions.EmptyEditor"}}</h2>
        <p class="hint">{{localize "FALLOUTMAW.Settings.CreatureOptions.EmptyEditorHint"}}</p>
      </section>
      {{/if}}
      {{/if}}
    </main>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
