<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Proficiencies.InfluenceTitle"}}</h2>
    </header>
    <div class="fallout-maw-proficiency-influence-grid">
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Settings.Proficiencies.InfluenceAccuracy"}}</span>
        <div>
          <input type="number" data-influence-field="accuracy" data-influence-bound="min" value="{{influence.accuracy.min}}" step="1">
          <strong>/</strong>
          <input type="number" data-influence-field="accuracy" data-influence-bound="max" value="{{influence.accuracy.max}}" step="1">
        </div>
      </label>
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Settings.Proficiencies.InfluenceDamage"}}</span>
        <div>
          <input type="number" data-influence-field="damage" data-influence-bound="min" value="{{influence.damage.min}}" step="1">
          <strong>/</strong>
          <input type="number" data-influence-field="damage" data-influence-bound="max" value="{{influence.damage.max}}" step="1">
        </div>
      </label>
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Settings.Proficiencies.InfluenceCriticalChance"}}</span>
        <div>
          <input type="number" data-influence-field="criticalChance" data-influence-bound="min" value="{{influence.criticalChance.min}}" step="1">
          <strong>/</strong>
          <input type="number" data-influence-field="criticalChance" data-influence-bound="max" value="{{influence.criticalChance.max}}" step="1">
        </div>
      </label>
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Settings.Proficiencies.InfluenceCriticalDamage"}}</span>
        <div>
          <input type="number" data-influence-field="criticalDamage" data-influence-bound="min" value="{{influence.criticalDamage.min}}" step="1">
          <strong>/</strong>
          <input type="number" data-influence-field="criticalDamage" data-influence-bound="max" value="{{influence.criticalDamage.max}}" step="1">
        </div>
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Proficiencies.Title"}}</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="createProficiency"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.Proficiencies.Create"}}</button>
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <div class="fallout-maw-settings-table proficiency-settings">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span></span>
        <span>{{localize "FALLOUTMAW.Common.Code"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Key"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Maximum"}}</span>
        <span></span>
      </div>
      {{#each proficiencies}}
      <div class="fallout-maw-settings-row" data-proficiency-row>
        <button type="button" class="fallout-maw-drag-handle" data-drag-handle title="{{localize 'FALLOUTMAW.Common.Reorder'}}"><i class="fa-solid fa-grip-lines"></i></button>
        <input type="text" data-field="abbr" value="{{abbr}}">
        <input type="text" data-field="key" value="{{key}}">
        <input type="text" data-field="label" value="{{label}}">
        <input type="number" data-field="max" value="{{max}}" min="0" step="1">
        <button type="button" data-action="deleteProficiency" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.Proficiencies.Empty"}}</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
