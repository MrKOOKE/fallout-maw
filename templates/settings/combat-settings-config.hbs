<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Combat.Title"}}</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <div class="fallout-maw-settings-grid">
      <label>
        <span>Стоимость вставки оружия в набор, ОД</span>
        <input type="number" name="weaponSwitch.actionPointCost" value="{{settings.weaponSwitch.actionPointCost}}" min="0" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.DodgeAttackCostPercent"}}</span>
        <input type="number" name="dodge.attackCostPercent" value="{{settings.dodge.attackCostPercent}}" min="0" max="100" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.DodgeBurstMultiplier"}}</span>
        <input type="number" name="dodge.burstMultiplier" value="{{settings.dodge.burstMultiplier}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.DodgeVolleyMultiplier"}}</span>
        <input type="number" name="dodge.volleyMultiplier" value="{{settings.dodge.volleyMultiplier}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.DodgeAreaDamageMultiplier"}}</span>
        <input type="number" name="dodge.areaDamageMultiplier" value="{{settings.dodge.areaDamageMultiplier}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.DodgeRoundRecoveryPercent"}}</span>
        <input type="number" name="dodge.roundRecoveryPercent" value="{{settings.dodge.roundRecoveryPercent}}" min="0" max="100" step="1">
      </label>
    </div>

    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Combat.AreasTitle"}}</h2>
    </header>

    <div class="fallout-maw-settings-grid">
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Combat.AreaMovementDamageThresholdFormula"}}</span>
        <input type="text" name="areas.movementDamageThresholdFormula" value="{{settings.areas.movementDamageThresholdFormula}}" data-formula-autocomplete="all">
        <small>{{localize "FALLOUTMAW.Settings.Combat.AreaMovementDamageThresholdHint"}}</small>
      </label>
    </div>

    <header class="fallout-maw-panel-header">
      <h2>Отбрасывание</h2>
    </header>

    <div class="fallout-maw-settings-grid">
      <label>
        <span>Порог дополнительной проверки</span>
        <input type="number" name="knockback.repeatDifficultyThreshold" value="{{settings.knockback.repeatDifficultyThreshold}}" min="1" step="1">
      </label>
      <label>
        <span>Снижение сложности после каждой проверки</span>
        <input type="number" name="knockback.repeatDifficultyStep" value="{{settings.knockback.repeatDifficultyStep}}" min="1" step="1">
      </label>
    </div>

    <header class="fallout-maw-panel-header">
      <h2>Потеря сознания</h2>
    </header>

    <div class="fallout-maw-settings-grid">
      <label>
        <span>Урон по обычной конечности</span>
        <input type="text" name="unconsciousness.normalDamageFormula" value="{{settings.unconsciousness.normalDamageFormula}}" data-formula-autocomplete="all">
        <small>Накопление сложности при состояние конечности &gt;0.</small>
      </label>
      <label>
        <span>Урон по поврежденной конечности</span>
        <input type="text" name="unconsciousness.negativeDamageFormula" value="{{settings.unconsciousness.negativeDamageFormula}}" data-formula-autocomplete="all">
        <small>Накопление сложности при состояние конечности &lt;0.</small>
      </label>
      <label>
        <span>Множитель по ключевой конечности</span>
        <input type="text" name="unconsciousness.criticalDamageFormula" value="{{settings.unconsciousness.criticalDamageFormula}}" data-formula-autocomplete="all">
        <small>Накопление сложности при повреждении ключевой конечности.</small>
      </label>
      <label>
        <span>Множитель недостающего состояния</span>
        <input type="text" name="unconsciousness.stateMultiplierFormula" value="{{settings.unconsciousness.stateMultiplierFormula}}" data-formula-autocomplete="all">
        <small>Чем ниже состояние конечности от максимальной, тем больше сложности накапливается от других источников.</small>
      </label>
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
