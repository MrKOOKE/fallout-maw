<form class="fallout-maw-formula-config" autocomplete="off">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройка типов урона</h2>
      <div class="fallout-maw-header-actions">
        <button type="button" data-action="create-damage-type">
          <i class="fa-solid fa-plus"></i>
          Создать тип урона
        </button>
        <button type="button" data-action="reset-defaults">
          <i class="fa-solid fa-rotate-left"></i>
          Установить по умолчанию
        </button>
      </div>
    </header>

    <div class="fallout-maw-settings-table key-label-settings">
      <div class="fallout-maw-settings-table-head">
        <span>Ключ</span>
        <span>Название</span>
        <span></span>
      </div>
      {{#each damageTypes}}
        <div class="fallout-maw-settings-row" data-damage-type-row>
          <input type="text" name="damageTypes.{{@index}}.key" value="{{key}}" data-field="key" placeholder="damageKey">
          <input type="text" name="damageTypes.{{@index}}.label" value="{{label}}" data-field="label" placeholder="Название типа урона">
          <button type="button" class="icon-only" data-action="delete-damage-type" data-index="{{@index}}" title="Удалить тип урона">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      {{else}}
        <p class="fallout-maw-empty-list">Типы урона не созданы.</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i>
      Сохранить изменения
    </button>
  </footer>
</form>
