<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройка скрытности</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <div class="fallout-maw-settings-grid">
      <label>
        <span>Расчет сложности</span>
        <select name="difficultyMode">
          <option value="perception" {{#if (eq settings.difficultyMode "perception")}}selected{{/if}}>Восприятие</option>
          <option value="naturalist" {{#if (eq settings.difficultyMode "naturalist")}}selected{{/if}}>Натуралист / 10</option>
        </select>
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Пороги освещения</h2>
    </header>
    <div class="fallout-maw-settings-grid three-columns">
      <label>
        <span>Очень яркий максимум</span>
        <input type="number" name="thresholds.veryBrightMax" value="{{settings.thresholds.veryBrightMax}}" min="0" max="1" step="0.01">
      </label>
      <label>
        <span>Яркий максимум</span>
        <input type="number" name="thresholds.brightMax" value="{{settings.thresholds.brightMax}}" min="0" max="1" step="0.01">
      </label>
      <label>
        <span>Тусклый максимум</span>
        <input type="number" name="thresholds.dimMax" value="{{settings.thresholds.dimMax}}" min="0" max="1" step="0.01">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Модификаторы света</h2>
    </header>
    <div class="fallout-maw-settings-table fallout-maw-stealth-settings-table">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span>Уровень</span>
        <span>Бонус СЛ</span>
        <span>Множитель восприятия</span>
        <span>Радиус</span>
      </div>
      {{#each levels}}
      <div class="fallout-maw-settings-row">
        <strong>{{label}}</strong>
        <input type="number" name="{{key}}.difficultyBonus" value="{{settings.difficultyBonus}}" step="1">
        <input type="number" name="{{key}}.perceptionMultiplier" value="{{settings.perceptionMultiplier}}" min="1" step="1">
        <input type="number" name="{{key}}.radius" value="{{settings.radius}}" min="0" step="1">
      </div>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
