<div class="fallout-maw-silhouette-editor">
  <div class="fallout-maw-silhouette-body">
    <aside class="fallout-maw-silhouette-tools" aria-label="Инструменты силуэта">
      <button type="button" class="fallout-maw-silhouette-tool command" data-action="chooseImage" title="Загрузить контур">
        <i class="fa-solid fa-image"></i>
        <span>Загрузить</span>
      </button>

      <div class="fallout-maw-silhouette-tool-group">
        {{#each tools}}
        <button type="button" class="fallout-maw-silhouette-tool {{#if active}}active{{/if}}" data-action="setTool" data-tool="{{key}}" title="{{label}}">
          <i class="fa-solid {{icon}}"></i>
          <span>{{label}}</span>
        </button>
        {{/each}}
      </div>

      <div class="fallout-maw-silhouette-tool-group">
        <button type="button" class="fallout-maw-silhouette-tool command" data-action="finishPolygon" {{#unless canFinishPolygon}}disabled{{/unless}} title="Завершить вырез">
          <i class="fa-solid fa-check"></i>
          <span>Вырез</span>
        </button>
        <button type="button" class="fallout-maw-silhouette-tool command" data-action="cancelPolygon" title="Сбросить черновик">
          <i class="fa-solid fa-xmark"></i>
          <span>Сброс</span>
        </button>
        <button type="button" class="fallout-maw-silhouette-tool command" data-action="undo" {{#unless canUndo}}disabled{{/unless}} title="Отменить">
          <i class="fa-solid fa-rotate-left"></i>
          <span>Назад</span>
        </button>
        <button type="button" class="fallout-maw-silhouette-tool command" data-action="clearActive" title="Включить ластик">
          <i class="fa-solid fa-eraser"></i>
          <span>Ластик</span>
        </button>
        <button type="button" class="fallout-maw-silhouette-tool command danger" data-action="reset" {{#unless hasSilhouette}}disabled{{/unless}} title="Удалить силуэт">
          <i class="fa-solid fa-trash"></i>
          <span>Удалить</span>
        </button>
      </div>
    </aside>

    <div class="fallout-maw-silhouette-stage">
      {{#if hasSilhouette}}
      <svg class="fallout-maw-silhouette-svg" viewBox="{{viewBox}}" data-action="addPoint" data-silhouette-svg>
        {{#each remaining}}
        <path class="fallout-maw-silhouette-remaining" d="{{d}}" fill="{{fill}}"></path>
        {{/each}}
        {{#each parts}}
        <path class="fallout-maw-silhouette-part" d="{{d}}" fill="{{fill}}">
          <title>{{label}}</title>
        </path>
        {{/each}}
        {{#each outline}}
        <path class="fallout-maw-silhouette-outline" d="{{d}}"></path>
        {{/each}}
        {{#if draftPoints}}
        <polyline class="fallout-maw-silhouette-draft-line" points="{{draftPoints}}"></polyline>
        {{/if}}
        <polygon class="fallout-maw-silhouette-preview" points="{{previewPoints}}" data-silhouette-preview></polygon>
        {{#each draftPointMarkers}}
        <circle class="fallout-maw-silhouette-draft-point" cx="{{x}}" cy="{{y}}" r="3"></circle>
        {{/each}}
      </svg>
      {{else}}
      <div class="fallout-maw-silhouette-empty">
        <i class="fa-solid fa-image"></i>
        <span>Загрузите прозрачное изображение, чтобы снять контур.</span>
      </div>
      {{/if}}
    </div>

    <aside class="fallout-maw-silhouette-side">
      <div class="fallout-maw-silhouette-side-title">Части тела</div>
      <div class="fallout-maw-silhouette-limb-list">
        {{#each limbs}}
        <button type="button" class="fallout-maw-silhouette-limb {{#if active}}active{{/if}}" data-action="selectLimb" data-limb-key="{{key}}">
          <span class="fallout-maw-silhouette-limb-swatch" style="background: {{color}}"></span>
          <span>{{label}}</span>
          <strong>{{areaPercent}}%</strong>
        </button>
        {{else}}
        <p class="fallout-maw-empty-list">Сначала добавьте конечности в расу.</p>
        {{/each}}
      </div>
      <p class="hint">Активная часть получает область выбранным инструментом. Ластик стирает из активной части. Shift+колесо меняет радиус кисти/ластика: {{brushRadius}}. Alt фиксирует квадрат, круг или равностороннюю фигуру. Остаток: {{unassignedPercent}}%.</p>
    </aside>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save" {{#unless canSave}}disabled{{/unless}}><i class="fa-solid fa-save"></i> Сохранить</button>
    <button type="button" data-action="close"><i class="fa-solid fa-xmark"></i> Закрыть</button>
  </footer>
</div>
