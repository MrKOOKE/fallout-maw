<form class="fallout-maw-formula-config" autocomplete="off">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройки навыков</h2>
      <div class="fallout-maw-header-actions">
        <button type="button" data-action="create-skill">
          <i class="fa-solid fa-plus"></i>
          Создать навык
        </button>
        <button type="button" data-action="reset-defaults">
          <i class="fa-solid fa-rotate-left"></i>
          Установить по умолчанию
        </button>
      </div>
    </header>

    <div class="fallout-maw-settings-table skill-settings">
      <div class="fallout-maw-settings-table-head">
        <span>Ключ</span>
        <span>Название</span>
        <span>Формула</span>
        <span></span>
      </div>
      {{#each skills}}
        <div class="fallout-maw-settings-row" data-skill-row>
          <input type="text" name="skills.{{@index}}.key" value="{{key}}" data-field="key" placeholder="skillKey">
          <input type="text" name="skills.{{@index}}.label" value="{{label}}" data-field="label" placeholder="Название навыка">
          <input type="text" name="skills.{{@index}}.formula" value="{{formula}}" data-field="formula" placeholder="0">
          <button type="button" class="icon-only" data-action="delete-skill" data-index="{{@index}}" title="Удалить навык">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      {{else}}
        <p class="fallout-maw-empty-list">Навыки не созданы.</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i>
      Сохранить изменения
    </button>
  </footer>
</form>
