<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Skills.Title"}}</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="createSkill"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.Skills.Create"}}</button>
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <p class="hint">{{localize "FALLOUTMAW.Settings.Skills.FormulaHint"}}</p>

    <div class="fallout-maw-settings-table skill-settings">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span></span>
        <span>{{localize "FALLOUTMAW.Common.Code"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Key"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Formula"}}</span>
        <span></span>
      </div>
      {{#each skills}}
      <div class="fallout-maw-settings-row" data-skill-row>
        <button type="button" class="fallout-maw-drag-handle" data-drag-handle title="{{localize 'FALLOUTMAW.Common.Reorder'}}"><i class="fa-solid fa-grip-lines"></i></button>
        <input type="text" data-field="abbr" value="{{abbr}}">
        <input type="text" data-field="key" value="{{key}}">
        <input type="text" data-field="label" value="{{label}}">
        <input type="text" data-field="formula" value="{{formula}}" data-formula-autocomplete="characteristics">
        <button type="button" data-action="deleteSkill" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.Skills.Empty"}}</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Skills.AdvancementTitle"}}</h2>
    </header>

    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Skills.SignatureMultiplier"}}</span>
        <input type="number" data-field="signatureMultiplier" value="{{signatureMultiplier}}" step="0.01">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Skills.SignatureFlatBonus"}}</span>
        <input type="number" data-field="signatureFlatBonus" value="{{signatureFlatBonus}}" step="0.01">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Settings.Skills.DevelopmentLimit"}}</span>
        <input type="number" data-field="developmentLimit" value="{{developmentLimit}}" min="0" step="1">
      </label>
    </div>

    <div class="fallout-maw-weapon-set-list fallout-maw-skill-advancement-list">
      {{#each skills}}
      <fieldset class="fallout-maw-weapon-set-config fallout-maw-skill-advancement-block" data-skill-advancement-row data-skill-key="{{key}}">
        <legend>{{label}}</legend>
        <div class="fallout-maw-list-grid two-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Settings.Skills.BaseMultiplier"}}</span>
            <input type="number" data-field="baseMultiplier" value="{{advancement.base}}" step="0.01">
          </label>
        </div>
        <div class="fallout-maw-list-grid two-columns">
          {{#each characteristics}}
          <label>
            <span>{{label}}</span>
            <input type="number" data-characteristic-key="{{key}}" value="{{value}}" step="0.01">
          </label>
          {{/each}}
        </div>
      </fieldset>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
