<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{need.label}}</h2>
      <p class="hint">{{need.key}}</p>
    </header>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Накопление потребности</h2>
    </header>
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>Скорость накопления в час</span>
        <input type="number" name="settings.accumulation.perHour" value="{{settings.accumulation.perHour}}" min="0" step="0.1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Пороги потребности</h2>
      <button type="button" data-action="addThreshold"><i class="fa-solid fa-plus"></i> Добавить порог</button>
    </header>

    {{#each settings.thresholds}}
    <article class="fallout-maw-panel" data-need-threshold-row>
      <input type="hidden" name="settings.thresholds.{{@index}}.id" value="{{id}}">
      <div class="fallout-maw-list-grid three-columns">
        <label>
          <span>% потребности</span>
          <input type="number" name="settings.thresholds.{{@index}}.percent" value="{{percent}}" min="0" max="100" step="1">
        </label>
        <label>
          <span>Уровень болезни</span>
          <input type="number" name="settings.thresholds.{{@index}}.diseaseLevel" value="{{diseaseLevel}}" min="0" step="1">
        </label>
        <button type="button" data-action="deleteThreshold"><i class="fa-solid fa-trash"></i> Удалить порог</button>
      </div>

      <header class="fallout-maw-panel-header">
        <h3>Штрафы порога</h3>
        <button type="button" data-action="addThresholdEffect"><i class="fa-solid fa-plus"></i> Добавить штраф</button>
      </header>
      <div class="fallout-maw-trauma-effect-table">
        <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
          <span>Ключ</span><span>Тип</span><span>Значение</span><span>Приоритет</span><span></span>
        </div>
        {{#each effects}}
        <div class="fallout-maw-trauma-effect-row" data-need-effect-row>
          <input type="text" name="settings.thresholds.{{@../index}}.effects.{{@index}}.key" value="{{key}}" data-effect-key-autocomplete>
          <select name="settings.thresholds.{{@../index}}.effects.{{@index}}.type">
            <option value="add" {{#if addSelected}}selected{{/if}}>{{localize "FALLOUTMAW.Effects.ChangeAdd"}}</option>
            <option value="override" {{#if overrideSelected}}selected{{/if}}>{{localize "FALLOUTMAW.Effects.ChangeOverride"}}</option>
          </select>
          <input type="text" name="settings.thresholds.{{@../index}}.effects.{{@index}}.value" value="{{value}}">
          <input type="number" name="settings.thresholds.{{@../index}}.effects.{{@index}}.priority" value="{{priority}}" step="1">
          <button type="button" data-action="deleteThresholdEffect"><i class="fa-solid fa-trash"></i></button>
        </div>
        {{/each}}
      </div>
    </article>
    {{else}}
    <p class="fallout-maw-empty-list">Пороги не настроены.</p>
    {{/each}}
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
