<section class="fallout-maw-settings-baseline">
  <div class="fallout-maw-settings-baseline-actions">
    <button type="button" data-action="copy">
      <i class="fa-solid fa-copy"></i>
      <span>Copy JSON</span>
    </button>
    <button type="button" data-action="download">
      <i class="fa-solid fa-download"></i>
      <span>Download JSON</span>
    </button>
    <button type="button" data-action="refresh">
      <i class="fa-solid fa-rotate"></i>
      <span>Refresh</span>
    </button>
  </div>

  <div class="fallout-maw-settings-baseline-meta">
    <span>{{settingCount}} settings</span>
    <span>{{snapshot.systemVersion}}</span>
    <span>{{snapshot.sourceWorld}}</span>
  </div>

  <textarea class="fallout-maw-settings-baseline-output" readonly>{{snapshotText}}</textarea>
</section>
