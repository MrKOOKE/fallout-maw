<form class="fallout-maw-formula-config" autocomplete="off">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>Настройка характеристик</h2>
      <div class="fallout-maw-header-actions">
        <button type="button" data-action="create-characteristic">
          <i class="fa-solid fa-plus"></i>
          Создать характеристику
        </button>
        <button type="button" data-action="reset-defaults">
          <i class="fa-solid fa-rotate-left"></i>
          Установить по умолчанию
        </button>
      </div>
    </header>

    <div class="fallout-maw-settings-table characteristic-settings">
      <div class="fallout-maw-settings-table-head">
        <span>Код</span>
        <span>Ключ</span>
        <span>Название</span>
        <span></span>
      </div>
      {{#each characteristics}}
        <div class="fallout-maw-settings-row" data-characteristic-row>
          <input type="text" name="characteristics.{{@index}}.abbr" value="{{abbr}}" data-field="abbr" placeholder="str">
          <input type="text" name="characteristics.{{@index}}.key" value="{{key}}" data-field="key" placeholder="characteristicKey">
          <input type="text" name="characteristics.{{@index}}.label" value="{{label}}" data-field="label" placeholder="Название характеристики">
          <button type="button" class="icon-only" data-action="delete-characteristic" data-index="{{@index}}" title="Удалить характеристику">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      {{else}}
        <p class="fallout-maw-empty-list">Характеристики не созданы.</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i>
      Сохранить изменения
    </button>
  </footer>
</form>
