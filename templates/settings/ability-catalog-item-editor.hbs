                <div class="fallout-maw-item-use-category-list">
                  {{#each skillRows}}
                  <div class="fallout-maw-item-use-category-row" data-skill-index="{{index}}">
                    <select data-field="conditionSkill">{{#each choices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
                    <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteConditionWeaponSkill" title="Удалить навык"><i class="fa-solid fa-trash"></i></button>
                  </div>
                  {{else}}<span class="fallout-maw-empty-list">Навыки не выбраны.</span>{{/each}}
                </div>
              </div>
              {{/if}}

              {{#if isWeaponProficiency}}
              <div class="fallout-maw-item-use-category-field">
                <div class="fallout-maw-item-use-category-header">
                  <span>Задействованные оружейные владения</span>
                  <button type="button" data-action="addConditionWeaponProficiency" {{#unless canAddProficiency}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить</button>
                </div>
                <div class="fallout-maw-item-use-category-list">
                  {{#each proficiencyRows}}
                  <div class="fallout-maw-item-use-category-row" data-proficiency-index="{{index}}">
                    <select data-field="conditionProficiency">{{#each choices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
                    <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteConditionWeaponProficiency" title="Удалить владение"><i class="fa-solid fa-trash"></i></button>
                  </div>
                  {{else}}<span class="fallout-maw-empty-list">Владения не выбраны.</span>{{/each}}
                </div>
              </div>
              {{/if}}

              {{#if isAura}}
              <div class="fallout-maw-aura-condition">
                <label><span>Режим наложения</span><select data-field="conditionAuraMode">{{#each auraModeChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                <div class="fallout-maw-item-use-category-field">
                  <div class="fallout-maw-item-use-category-header">
                    <span>{{auraTargetGroupsLabel}}</span>
                    <button type="button" data-action="addConditionAuraTargetGroup" {{#unless canAddAuraTargetGroup}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить</button>
                  </div>
                  <div class="fallout-maw-item-use-category-list">
                    {{#each auraTargetGroupRows}}
                    <div class="fallout-maw-item-use-category-row" data-aura-target-group-index="{{index}}">
                      <select data-field="conditionAuraTargetGroup">{{#each choices}}<option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>{{/each}}</select>
                      <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteConditionAuraTargetGroup" title="Удалить группу целей"><i class="fa-solid fa-trash"></i></button>
                    </div>
                    {{else}}<span class="fallout-maw-empty-list">Цели не выбраны.</span>{{/each}}
                  </div>
                </div>
                <div class="fallout-maw-aura-condition-caption">Условия воздействия</div>
                <div class="fallout-maw-aura-condition-fields">
                  <label><span>Радиус, м</span><input type="number" data-field="conditionAuraRadiusMeters" value="{{auraRadiusMeters}}" min="0" step="0.1"></label>
                  <label><span>Требуется актеров для работы</span><input type="number" data-field="conditionRequiredCount" value="{{requiredCount}}" min="1" step="1"></label>
                  {{#if showAuraIncludeSelf}}
                  <label><span>Учитывать себя</span><select data-field="conditionAuraIncludeSelf">{{#each auraIncludeSelfChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                  {{/if}}
                  <label><span>Только в бою</span><select data-field="conditionAuraCombatOnly">{{#each auraCombatOnlyChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                  <label><span>Блокирование стенами</span><select data-field="conditionAuraWallsBlock">{{#each auraWallsBlockChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                  <label><span>Только участники боя</span><select data-field="conditionAuraCombatantsOnly">{{#each auraCombatantsOnlyChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                  <label><span>Игнорировать мертвых и без сознания</span><select data-field="conditionAuraIgnoreIncapacitated">{{#each auraIgnoreIncapacitatedChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                  <label><span>Игнорировать скрытых</span><select data-field="conditionAuraIgnoreHidden">{{#each auraIgnoreHiddenChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                </div>
              </div>
              {{/if}}

              {{#if isLimitedChanges}}
              <label>
                <span>Выбрать изменений</span>
                <input type="number" data-field="conditionLimit" value="{{changeLimit}}" min="1" max="{{changeLimitMax}}" step="1">
              </label>
              <label>
                <span>Всего изменений</span>
                <input type="number" value="{{changeLimitTotal}}" disabled>
              </label>
              {{/if}}

              {{#if isItemUse}}
              <div class="fallout-maw-item-use-category-field">
                <div class="fallout-maw-item-use-category-header">
                  <span>Категории предметов</span>
                  <button type="button" data-action="addConditionItemCategory" {{#unless canAddItemCategory}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить</button>
                </div>
                <div class="fallout-maw-item-use-category-list">
                  {{#each itemCategoryRows}}
                  <div class="fallout-maw-item-use-category-row" data-item-use-category-index="{{index}}">
                    <select data-field="conditionItemCategory">
                      {{#each choices}}
                      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteConditionItemCategory" title="Удалить категорию"><i class="fa-solid fa-trash"></i></button>
                  </div>
                  {{else}}
                  <span class="fallout-maw-empty-list">Категории не выбраны.</span>
                  {{/each}}
                </div>
              </div>
              <label>
                <span>Применений</span>
                <input type="number" data-field="conditionRequiredCount" value="{{requiredCount}}" min="1" step="1">
              </label>
              <label class="fallout-maw-split-number-field">
                <span>Длительность</span>
                <div>
                  <input type="number" data-field="conditionDurationAmount" value="{{durationAmount}}" min="0" step="1">
                  <select data-field="conditionDurationUnit">
                    {{#each durationUnitChoices}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </div>
              </label>
              {{/if}}

              {{#if isCooldown}}
              <label>
                <span>Длительность, секунд</span>
                <input type="number" data-field="conditionDurationSeconds" value="{{durationSeconds}}" min="0" step="1">
              </label>
              {{/if}}

            </div>
          </div>
          {{/if}}
        </div>
        {{/each}}
        {{#if isOrGroup}}
        </div>
        {{/if}}
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if hasPenalties}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Штрафы</h3>
        <button type="button" data-action="addFunctionPenalty"><i class="fa-solid fa-plus"></i> Добавить строку</button>
      </div>
      <div data-ability-penalties>
        {{#each penalties}}
        <div class="fallout-maw-ability-change-card" data-ability-penalty-row data-change-id="{{id}}">
          <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
            <span>Ключ</span>
            <span>Тип</span>
            <span>Значение</span>
            <span>Приоритет</span>
            <span></span>
          </div>
          <div class="fallout-maw-trauma-effect-row">
            <input type="text" data-field="changeKey" data-effect-key-autocomplete value="{{key}}">
            <select data-field="changeType">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="text" data-field="changeValue" value="{{value}}" data-formula-autocomplete="all">
            <input type="number" data-field="changePriority" value="{{priority}}" step="1">
            <button type="button" class="fallout-maw-icon-button" data-action="deleteFunctionPenalty" title="Удалить строку"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}
  </section>
  {{else}}
  <section class="fallout-maw-panel">
    <p class="fallout-maw-empty-list">Функции не настроены.</p>
  </section>
  {{/each}}
</section>

</div>
