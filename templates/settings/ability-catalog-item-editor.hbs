<div class="fallout-maw-sheet-body">
<header class="sheet-header fallout-maw-sheet-header">
  <input type="hidden" data-field="img" value="{{ability.img}}">
  <img class="profile-img" src="{{ability.img}}" data-action="editAbilityImage" title="{{ability.name}}" height="80" width="80">
  <div class="fallout-maw-header-fields">
    <input class="fallout-maw-title-input" data-field="name" type="text" value="{{ability.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
  </div>
</header>

<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="selectTab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">Общие данные</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="selectTab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">Функции</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Условия приобретения</h2>
      <button type="button" data-action="addAcquisitionRequirement"><i class="fa-solid fa-plus"></i> Добавить условие</button>
    </div>
    <div class="fallout-maw-acquisition-requirements" data-acquisition-requirements>
      {{#each acquisitionRequirements}}
      <div class="fallout-maw-ability-condition-row{{#if isPending}} empty{{else}} configured{{/if}}" data-acquisition-requirement-row data-requirement-id="{{id}}">
        {{#if isPending}}
        <label>
          <span>Условие</span>
          <select data-field="acquisitionRequirementType">
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteAcquisitionRequirement" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
        {{else}}
        <input type="hidden" data-field="acquisitionRequirementType" value="{{type}}">
        <div class="fallout-maw-ability-condition-card">
          <div class="fallout-maw-ability-condition-card-header">
            <h4>{{typeLabel}}</h4>
            <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteAcquisitionRequirement" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
          </div>
          <div class="fallout-maw-ability-condition-fields">
            {{#if isRace}}
            <label>
              <span>Раса</span>
              <select data-field="acquisitionRequirementRaceId">
                {{#each raceChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            {{/if}}
            {{#if isCharacteristic}}
            <label>
              <span>Характеристика</span>
              <select data-field="acquisitionRequirementCharacteristicKey">
                {{#each characteristicChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label>
              <span>Минимум</span>
              <input type="number" data-field="acquisitionRequirementValue" value="{{value}}" min="0" step="1">
            </label>
            {{/if}}
            {{#if isSkill}}
            <label>
              <span>Навык</span>
              <select data-field="acquisitionRequirementSkillKey">
                {{#each skillChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label>
              <span>Минимум</span>
              <input type="number" data-field="acquisitionRequirementValue" value="{{value}}" min="0" step="1">
            </label>
            {{/if}}
          </div>
        </div>
        {{/if}}
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">Условия приобретения не настроены.</p>
      {{/each}}
    </div>
  </section>
  {{#unless isFeature}}
  <section class="fallout-maw-panel">
    <h2>Приобретение</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Стоимость ОИ</span>
        <input type="number" data-field="cost" value="{{system.cost}}" min="0" step="1">
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только свободные ОИ</span>
        <input type="checkbox" data-field="onlyFree" {{checked onlyFree}}>
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только ручное исследование</span>
        <input type="checkbox" data-field="onlyManual" {{checked onlyManual}}>
      </label>
      <label>
        <span>Навык ручного исследования</span>
        <select data-field="researchSkillKey">
          {{#each researchSkillChoices}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>Сложность ручного исследования</span>
        <input type="number" data-field="researchDifficulty" value="{{researchDifficulty}}" min="0" step="1">
      </label>
    </div>
  </section>
  {{/unless}}

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>Описание</h2>
    <prose-mirror data-field="description" value="{{ability.description}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
  </section>
</section>

<section class="tab {{tabs.functions.cssClass}}" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Функции</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-action="addFunction" {{#unless canAddFunction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить функцию</button>
      </div>
    </div>
    {{#if showFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <select data-choose-ability-function>
        {{#each functionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
    {{#if showFixedFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <input type="search" data-fixed-ability-function-search placeholder="Поиск фиксированной функции">
      <select data-choose-fixed-ability-function>
        {{#each fixedFunctionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </section>

  {{#each functions}}
  <section class="fallout-maw-panel" data-ability-function-row data-function-id="{{id}}" data-function-type="{{type}}">
    <div class="fallout-maw-panel-header">
      <h2>{{typeLabel}}</h2>
      <div class="fallout-maw-inline-controls">
        {{#unless isFixed}}
        <button type="button" data-action="addFunctionChange"><i class="fa-solid fa-plus"></i> Добавить строку</button>
        <button type="button" data-action="addFunctionCondition"><i class="fa-solid fa-plus"></i> Добавить условие</button>
        {{/unless}}
        <button type="button" class="fallout-maw-icon-button" data-action="deleteFunction"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>

    {{#if isFixed}}
    <input type="hidden" data-field="fixedKey" value="{{fixedKey}}">
    {{#if fixedDeusSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Бог из машины</h3>
      <div class="fallout-maw-fixed-settings">
        <label>
          <span>Требуемый урон</span>
          <input type="number" data-field="fixed.damageRequired" value="{{fixedDeusSettings.damageRequired}}" min="1" step="1">
        </label>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Прозрение</strong>
          <label>
            <span>Бонус к навыкам</span>
            <input type="number" data-field="fixed.insight.skillBonus" value="{{fixedDeusSettings.insight.skillBonus}}" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.insight.durationAmount" value="{{fixedDeusSettings.insightDurationAmount}}" min="0" step="1">
              <select data-field="fixed.insight.durationUnit">
                {{#each fixedDeusSettings.insightDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Забавный случай</strong>
          <label>
            <span>Уничтожаемые предметы и валюта, %</span>
            <input type="number" data-field="fixed.disintegrate.destroyPercent" value="{{fixedDeusSettings.disintegrate.destroyPercent}}" min="0" max="100" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Удачная находка</strong>
          <label>
            <span>Минимум ценности</span>
            <input type="number" data-field="fixed.luckyFind.valueMin" value="{{fixedDeusSettings.luckyFind.valueMin}}" min="0" step="1">
          </label>
          <label>
            <span>Максимум ценности</span>
            <input type="number" data-field="fixed.luckyFind.valueMax" value="{{fixedDeusSettings.luckyFind.valueMax}}" min="0" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Чудесное спасение</strong>
          <label>
            <span>Восстановить</span>
            <select data-field="fixed.rescue.restoreMode" data-fixed-rescue-mode>
              {{#each fixedDeusSettings.restoreModeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-fixed-rescue-count {{#unless fixedDeusSettings.isRestoreCountMode}}hidden{{/unless}}>
            <span>Исцеляемые конечности</span>
            <input type="number" data-field="fixed.rescue.restoreCount" value="{{fixedDeusSettings.rescue.restoreCount}}" min="1" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedCurseAndBlessingSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Порча и благословение</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Срабатывание</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" data-field="fixed.curse.energyCost" value="{{fixedCurseAndBlessingSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса, %</span>
            <input type="text" data-field="fixed.curse.triggerFormula" value="{{fixedCurseAndBlessingSettings.triggerFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Длительность изменения</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.curse.durationAmount" value="{{fixedCurseAndBlessingSettings.durationAmount}}" min="0" step="1">
              <select data-field="fixed.curse.durationUnit">
                {{#each fixedCurseAndBlessingSettings.durationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedAllOrNothingSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Все или ничего</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Активация</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" data-field="fixed.allOrNothing.energyCost" value="{{fixedAllOrNothingSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса</span>
            <input type="text" data-field="fixed.allOrNothing.chanceFormula" value="{{fixedAllOrNothingSettings.chanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Дробь, % пуль</span>
            <input type="number" data-field="fixed.allOrNothing.pelletCoveragePercent" value="{{fixedAllOrNothingSettings.pelletCoveragePercent}}" min="0" max="100" step="1">
          </label>
          <label>
            <span>Очередь, % пуль</span>
            <input type="number" data-field="fixed.allOrNothing.burstCoveragePercent" value="{{fixedAllOrNothingSettings.burstCoveragePercent}}" min="0" max="100" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Перегрузка</strong>
          <label>
            <span>Доп. расход энергии</span>
            <input type="number" data-field="fixed.allOrNothing.overloadEnergyCost" value="{{fixedAllOrNothingSettings.overloadEnergyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.allOrNothing.overloadDurationAmount" value="{{fixedAllOrNothingSettings.overloadDurationAmount}}" min="0" step="1">
              <select data-field="fixed.allOrNothing.overloadDurationUnit">
                {{#each fixedAllOrNothingSettings.overloadDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedReaperSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Жнец</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Восстановление ОД</strong>
          <label>
            <span>Формула за убийство</span>
            <input type="text" data-field="fixed.reaper.killChanceFormula" value="{{fixedReaperSettings.killChanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Формула за атаку</span>
            <input type="text" data-field="fixed.reaper.attackChanceFormula" value="{{fixedReaperSettings.attackChanceFormula}}" data-formula-autocomplete="all">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedFourLeafCloverSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Клевер-четырёхлистник</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Заряды</strong>
          <label>
            <span>Текущие заряды</span>
            <input type="number" data-field="fixed.fourLeafClover.currentCharges" value="{{fixedFourLeafCloverSettings.currentCharges}}" min="0" step="1">
          </label>
          <label>
            <span>За провал</span>
            <input type="number" data-field="fixed.fourLeafClover.failureCharges" value="{{fixedFourLeafCloverSettings.failureCharges}}" min="0" step="1">
          </label>
          <label>
            <span>За критический провал</span>
            <input type="number" data-field="fixed.fourLeafClover.criticalFailureCharges" value="{{fixedFourLeafCloverSettings.criticalFailureCharges}}" min="0" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedAtRandomSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: На обум</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Атакующие действия</strong>
          <label>
            <span>Снижение стоимости ОД</span>
            <input type="number" data-field="fixed.atRandom.actionPointCostReduction" value="{{fixedAtRandomSettings.actionPointCostReduction}}" min="0" step="1">
          </label>
          <label>
            <span>Формула блокировки</span>
            <input type="text" data-field="fixed.atRandom.blockChanceFormula" value="{{fixedAtRandomSettings.blockChanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Формула дополнительной блокировки</span>
            <input type="text" data-field="fixed.atRandom.extraBlockChanceFormula" value="{{fixedAtRandomSettings.extraBlockChanceFormula}}" data-formula-autocomplete="all">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedDefensiveTacticsSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Оборонительная тактика</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Уклонение</strong>
          <label>
            <span>Снижение потери уклонения, %</span>
            <input type="number" data-field="fixed.defensiveTactics.dodgeLossReductionPercent" value="{{fixedDefensiveTacticsSettings.dodgeLossReductionPercent}}" min="0" step="1">
          </label>
          <label>
            <span>Бонус восстановления за раунд, %</span>
            <input type="number" data-field="fixed.defensiveTactics.dodgeRoundRecoveryBonusPercent" value="{{fixedDefensiveTacticsSettings.dodgeRoundRecoveryBonusPercent}}" min="0" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedLastChanceSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Последний шанс</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Срабатывание</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" data-field="fixed.lastChance.energyCost" value="{{fixedLastChanceSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса</span>
            <input type="text" data-field="fixed.lastChance.chanceFormula" value="{{fixedLastChanceSettings.chanceFormula}}" data-formula-autocomplete="all">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Перегрузка</strong>
          <label>
            <span>Доп. расход энергии</span>
            <input type="number" data-field="fixed.lastChance.overloadEnergyCost" value="{{fixedLastChanceSettings.overloadEnergyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.lastChance.overloadDurationAmount" value="{{fixedLastChanceSettings.overloadDurationAmount}}" min="0" step="1">
              <select data-field="fixed.lastChance.overloadDurationUnit">
                {{#each fixedLastChanceSettings.overloadDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedLuckyCoinSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Счастливая монетка</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Активация</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" data-field="fixed.luckyCoin.energyCost" value="{{fixedLuckyCoinSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса</span>
            <input type="text" data-field="fixed.luckyCoin.chanceFormula" value="{{fixedLuckyCoinSettings.chanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Формула бонуса</span>
            <input type="text" data-field="fixed.luckyCoin.successBonusFormula" value="{{fixedLuckyCoinSettings.successBonusFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Формула штрафа</span>
            <input type="text" data-field="fixed.luckyCoin.failurePenaltyFormula" value="{{fixedLuckyCoinSettings.failurePenaltyFormula}}" data-formula-autocomplete="all">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Перегрузка</strong>
          <label>
            <span>Доп. расход энергии</span>
            <input type="number" data-field="fixed.luckyCoin.overloadEnergyCost" value="{{fixedLuckyCoinSettings.overloadEnergyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.luckyCoin.overloadDurationAmount" value="{{fixedLuckyCoinSettings.overloadDurationAmount}}" min="0" step="1">
              <select data-field="fixed.luckyCoin.overloadDurationUnit">
                {{#each fixedLuckyCoinSettings.overloadDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedWhirlwindSettings}}
    <div class="fallout-maw-ability-subsection">
      <h3>Настройки: Вихрь</h3>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Активация</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" data-field="fixed.whirlwind.energyCost" value="{{fixedWhirlwindSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Изменение точности</span>
            <input type="number" data-field="fixed.whirlwind.accuracyModifier" value="{{fixedWhirlwindSettings.accuracyModifier}}" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Перегрузка</strong>
          <label>
            <span>Доп. расход энергии</span>
            <input type="number" data-field="fixed.whirlwind.overloadEnergyCost" value="{{fixedWhirlwindSettings.overloadEnergyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" data-field="fixed.whirlwind.overloadDurationAmount" value="{{fixedWhirlwindSettings.overloadDurationAmount}}" min="0" step="1">
              <select data-field="fixed.whirlwind.overloadDurationUnit">
                {{#each fixedWhirlwindSettings.overloadDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedLungeSettings}}
    <div class="fallout-maw-ability-subsection">
