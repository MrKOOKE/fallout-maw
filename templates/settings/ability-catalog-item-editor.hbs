<div class="fallout-maw-sheet-body">
<header class="sheet-header fallout-maw-sheet-header">
  <input type="hidden" data-field="img" value="{{ability.img}}">
  <img class="profile-img" src="{{ability.img}}" data-action="editAbilityImage" title="{{ability.name}}" height="80" width="80">
  <div class="fallout-maw-header-fields">
    <input class="fallout-maw-title-input" data-field="name" type="text" value="{{ability.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
  </div>
</header>

<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="selectTab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">Общие данные</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="selectTab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">Функции</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  {{#if isFeature}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Условия приобретения</h2>
      <button type="button" data-action="addAcquisitionRequirement"><i class="fa-solid fa-plus"></i> Добавить условие</button>
    </div>
    <div class="fallout-maw-acquisition-requirements" data-acquisition-requirements>
      {{#each acquisitionRequirements}}
      <div class="fallout-maw-ability-condition-row{{#if isPending}} empty{{else}} configured{{/if}}" data-acquisition-requirement-row data-requirement-id="{{id}}">
        {{#if isPending}}
        <label>
          <span>Условие</span>
          <select data-field="acquisitionRequirementType">
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteAcquisitionRequirement" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
        {{else}}
        <input type="hidden" data-field="acquisitionRequirementType" value="{{type}}">
        <div class="fallout-maw-ability-condition-card">
          <div class="fallout-maw-ability-condition-card-header">
            <h4>{{typeLabel}}</h4>
            <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteAcquisitionRequirement" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
          </div>
          <div class="fallout-maw-ability-condition-fields">
            {{#if isRace}}
            <label>
              <span>Раса</span>
              <select data-field="acquisitionRequirementRaceId">
                {{#each raceChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            {{/if}}
          </div>
        </div>
        {{/if}}
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">Условия приобретения не настроены.</p>
      {{/each}}
    </div>
  </section>
  {{else}}
  <section class="fallout-maw-panel">
    <h2>Приобретение</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Стоимость ОИ</span>
        <input type="number" data-field="cost" value="{{system.cost}}" min="0" step="1">
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только свободные ОИ</span>
        <input type="checkbox" data-field="onlyFree" {{checked onlyFree}}>
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только ручное исследование</span>
        <input type="checkbox" data-field="onlyManual" {{checked onlyManual}}>
      </label>
      <label>
        <span>Навык ручного исследования</span>
        <select data-field="researchSkillKey">
          {{#each researchSkillChoices}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>Сложность ручного исследования</span>
        <input type="number" data-field="researchDifficulty" value="{{researchDifficulty}}" min="0" step="1">
      </label>
    </div>
  </section>
  {{/if}}

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>Описание</h2>
    <prose-mirror data-field="description" value="{{ability.description}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
  </section>
</section>

<section class="tab {{tabs.functions.cssClass}}" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Функции</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-action="addFunction" {{#unless canAddFunction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить функцию</button>
      </div>
    </div>
    {{#if showFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <select data-choose-ability-function>
        {{#each functionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </section>

  {{#each functions}}
  <section class="fallout-maw-panel" data-ability-function-row data-function-id="{{id}}" data-function-type="{{type}}">
    <div class="fallout-maw-panel-header">
      <h2>{{typeLabel}}</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-action="addFunctionChange"><i class="fa-solid fa-plus"></i> Добавить строку</button>
        <button type="button" data-action="addFunctionCondition"><i class="fa-solid fa-plus"></i> Добавить условие</button>
        <button type="button" class="fallout-maw-icon-button" data-action="deleteFunction"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>

    <div data-ability-changes>
      {{#each changes}}
      <div class="fallout-maw-ability-change-card" data-ability-change-row data-change-id="{{id}}">
        <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
          <span>Ключ</span>
          <span>Тип</span>
          <span>Значение</span>
          <span>Приоритет</span>
          <span></span>
        </div>
        <div class="fallout-maw-trauma-effect-row">
          <input type="text" data-field="changeKey" data-effect-key-autocomplete value="{{key}}">
          <select data-field="changeType">
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <input type="text" data-field="changeValue" value="{{value}}">
          <input type="number" data-field="changePriority" value="{{priority}}" step="1">
          <div class="fallout-maw-inline-controls">
            <button type="button" class="fallout-maw-icon-button" data-action="deleteFunctionChange" title="Удалить строку"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">Строки изменений не настроены.</p>
      {{/each}}
    </div>

    {{#if hasConditions}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Условие</h3>
        <div class="fallout-maw-inline-controls">
          <button type="button" data-action="addFunctionCondition"><i class="fa-solid fa-plus"></i> Добавить условие</button>
          <button type="button" data-action="addFunctionPenalty" {{#unless canAddPenalty}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить штраф за невыполнение</button>
        </div>
      </div>
      <div class="fallout-maw-ability-conditions" data-ability-conditions>
        {{#each conditionGroups}}
        {{#if isOrGroup}}
        <div class="fallout-maw-ability-condition-or-group">
        {{/if}}
        {{#each conditions}}
        <div class="fallout-maw-ability-condition-row{{#if isPending}} empty{{else}} configured{{/if}}" data-ability-condition-row data-condition-id="{{id}}" data-condition-group-id="{{groupId}}">
          <input type="hidden" data-field="conditionGroupId" value="{{groupId}}">
          {{#if isPending}}
          <label>
            <span>Условие</span>
            <select data-field="conditionType">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteFunctionCondition" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
          {{else}}
          <input type="hidden" data-field="conditionType" value="{{type}}">
          <div class="fallout-maw-ability-condition-card">
            <div class="fallout-maw-ability-condition-card-header">
              <h4>{{typeLabel}}</h4>
              <div class="fallout-maw-inline-controls">
                <button type="button" data-action="addFunctionConditionAlternative"><i class="fa-solid fa-plus"></i> ИЛИ</button>
                <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-action="deleteFunctionCondition" title="Удалить условие"><i class="fa-solid fa-trash"></i></button>
              </div>
            </div>
            <div class="fallout-maw-ability-condition-fields">

              {{#if isHealth}}
              <label>
                <span>Состояние ОЗ чего</span>
                <select data-field="conditionHealthTarget">
                  {{#each healthTargetChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{#if showLimbChoice}}
              <label>
                <span>Конечность</span>
                <select data-field="conditionLimbKey">
                  {{#each limbChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{/if}}
              <label>
                <span>Оператор</span>
                <select data-field="conditionOperator">
                  {{#each healthOperatorChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Процент ОЗ</span>
                <input type="number" data-field="conditionPercent" value="{{percent}}" min="0" max="100" step="1">
              </label>
              {{/if}}

              {{#if isEquipment}}
              <label>
                <span>Слот экипировки</span>
                <select data-field="conditionEquipmentSlotKey">
                  {{#each equipmentSlotChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Оператор</span>
                <select data-field="conditionOperator">
                  {{#each equipmentOperatorChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{/if}}

            </div>
          </div>
          {{/if}}
        </div>
        {{/each}}
        {{#if isOrGroup}}
        </div>
        {{/if}}
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if hasPenalties}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Штрафы</h3>
        <button type="button" data-action="addFunctionPenalty"><i class="fa-solid fa-plus"></i> Добавить строку</button>
      </div>
      <div data-ability-penalties>
        {{#each penalties}}
        <div class="fallout-maw-ability-change-card" data-ability-penalty-row data-change-id="{{id}}">
          <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
            <span>Ключ</span>
            <span>Тип</span>
            <span>Значение</span>
            <span>Приоритет</span>
            <span></span>
          </div>
          <div class="fallout-maw-trauma-effect-row">
            <input type="text" data-field="changeKey" data-effect-key-autocomplete value="{{key}}">
            <select data-field="changeType">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="text" data-field="changeValue" value="{{value}}">
            <input type="number" data-field="changePriority" value="{{priority}}" step="1">
            <button type="button" class="fallout-maw-icon-button" data-action="deleteFunctionPenalty" title="Удалить строку"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}
  </section>
  {{else}}
  <section class="fallout-maw-panel">
    <p class="fallout-maw-empty-list">Функции не настроены.</p>
  </section>
  {{/each}}
</section>

<footer class="sheet-footer flexrow">
  <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
</footer>
</div>
