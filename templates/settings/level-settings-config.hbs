<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Settings.Levels.Title"}}</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="createLevel"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Settings.Levels.Create"}}</button>
        <button type="button" data-action="resetDefaults"><i class="fa-solid fa-rotate-left"></i> {{localize "FALLOUTMAW.Common.ResetDefaults"}}</button>
      </div>
    </header>

    <p class="hint">{{localize "FALLOUTMAW.Settings.Levels.Hint"}}</p>

    <div class="fallout-maw-settings-table level-settings">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span></span>
        <span>{{localize "FALLOUTMAW.Actor.Level"}}</span>
        <span>{{localize "FALLOUTMAW.Advancement.Experience"}}</span>
        <span></span>
      </div>
      {{#each levels}}
      <div class="fallout-maw-settings-row" data-level-row data-level="{{level}}">
        <button type="button" class="fallout-maw-drag-handle" data-drag-handle title="{{localize 'FALLOUTMAW.Common.Reorder'}}"><i class="fa-solid fa-grip-lines"></i></button>
        <input type="number" data-field="level" value="{{level}}" min="0">
        <input type="number" data-field="experience" value="{{experience}}" min="0">
        <button type="button" data-action="deleteLevel" title="{{localize 'COMMON.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
