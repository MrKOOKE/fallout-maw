<div class="fallout-maw-config-body fallout-maw-trauma-config-body">
  {{#if group}}
  <section class="fallout-maw-panel fallout-maw-trauma-group" data-trauma-group="{{group.id}}">
    <header class="fallout-maw-panel-header">
      <div>
        <h2>{{group.raceNames}}</h2>
        <p class="fallout-maw-help-text">{{group.limbsLabel}}</p>
      </div>
    </header>

    {{#each group.limbs}}
    <section class="fallout-maw-panel fallout-maw-trauma-limb" data-trauma-limb="{{key}}" data-trauma-limb-state-max="{{stateMax}}">
      <header class="fallout-maw-panel-header">
        <div>
          <h2><span data-trauma-limb-label>{{label}}</span></h2>
          <p class="fallout-maw-help-text">{{stateMax}}</p>
        </div>
        <button type="button" data-action="createStage"><i class="fa-solid fa-plus"></i> Добавить порог</button>
      </header>

      <div class="fallout-maw-trauma-stage-list">
        {{#each stages}}
        <section class="fallout-maw-panel fallout-maw-trauma-stage" data-trauma-stage="{{id}}">
          <header class="fallout-maw-panel-header">
            <label class="fallout-maw-inline-stat">
              <span>Порог состояния, %</span>
              <input type="number" data-trauma-stage-threshold value="{{thresholdPercent}}" min="0" max="100" step="1">
            </label>
            <button type="button" data-action="deleteStage" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </header>

          <div class="fallout-maw-trauma-profile-list">
            {{#each profiles}}
            <section class="fallout-maw-trauma-profile" data-trauma-profile="{{damageTypeKey}}">
              <h3>{{damageTypeLabel}}</h3>
              <div class="fallout-maw-list-grid two-columns">
                <label>
                  <span>Название травмы</span>
                  <input type="text" data-trauma-profile-name value="{{name}}">
                </label>
                <label>
                  <span>Картинка</span>
                  <input type="text" data-trauma-profile-img value="{{img}}">
                </label>
              </div>

              <div class="fallout-maw-trauma-effect-table">
                <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
                  <span>Ключ</span>
                  <span>Тип</span>
                  <span>Значение</span>
                  <span>Приоритет</span>
                  <span></span>
                </div>
                {{#each effects}}
                <div class="fallout-maw-trauma-effect-row" data-trauma-effect="{{index}}">
                  <input type="text" data-trauma-effect-key data-effect-key-autocomplete value="{{key}}">
                  <select data-trauma-effect-type>
                    <option value="add" {{#if addSelected}}selected{{/if}}>Добавить</option>
                    <option value="override" {{#if overrideSelected}}selected{{/if}}>Заменить</option>
                  </select>
                  <input type="text" data-trauma-effect-value value="{{value}}">
                  <input type="number" data-trauma-effect-priority value="{{priority}}">
                  <button type="button" data-action="deleteEffect" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                </div>
                {{/each}}
              </div>
              <button type="button" data-action="addEffect"><i class="fa-solid fa-plus"></i> Добавить эффект</button>
            </section>
            {{/each}}
          </div>
        </section>
        {{else}}
        <p class="fallout-maw-empty-list">Пороги травм не настроены.</p>
        {{/each}}
      </div>
    </section>
    {{/each}}
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
  {{else}}
  <section class="fallout-maw-panel">
    <p class="fallout-maw-empty-list">Набор конечностей не найден.</p>
  </section>
  {{/if}}
</div>
