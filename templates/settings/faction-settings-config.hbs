<div class="fallout-maw-config-body">
  <section class="fallout-maw-panel">
    <header class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Factions.SettingsTitle"}}</h2>
      <div class="fallout-maw-button-row">
        <button type="button" data-action="migratePresetSettings"><i class="fa-solid fa-code-compare"></i> Мигрировать из других пресетов</button>
        <button type="button" data-action="createFaction"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Factions.Create"}}</button>
      </div>
    </header>

    <p class="hint">{{localize "FALLOUTMAW.Factions.SettingsHint"}}</p>

    <div class="fallout-maw-settings-table fallout-maw-faction-settings-table">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span></span>
        <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
        <span></span>
      </div>
      {{#each factions}}
      <div class="fallout-maw-settings-row" data-faction-row>
        <button type="button" class="fallout-maw-drag-handle" data-drag-handle title="{{localize 'FALLOUTMAW.Common.Reorder'}}"><i class="fa-solid fa-grip-lines"></i></button>
        <input type="text" data-field="name" value="{{this}}" placeholder="{{localize 'FALLOUTMAW.Factions.NamePlaceholder'}}">
        <button type="button" data-action="deleteFaction" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Factions.Empty"}}</p>
      {{/each}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
  </footer>
</div>
