        <button type="button" data-add-ability-condition><i class="fa-solid fa-plus"></i> Добавить условие</button>
        <button type="button" class="fallout-maw-icon-button" data-delete-ability-function title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>
