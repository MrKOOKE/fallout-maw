        <input type="hidden" name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.id" value="{{id}}">
        {{#if isPending}}
        <label>
          <span>{{localize "FALLOUTMAW.Ability.Actions.Type"}}</span>
          <select name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.type" data-ability-action-type>
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-delete-ability-action title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
        {{else}}
        <input type="hidden" name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.type" value="{{type}}">
        {{#if isWeaponAttack}}
        <div class="fallout-maw-ability-condition-card">
          <div class="fallout-maw-ability-condition-card-header">
            <h4>{{localize "FALLOUTMAW.Ability.Actions.WeaponAttack"}}</h4>
            <button type="button" class="fallout-maw-icon-button" data-delete-ability-action title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          <div class="fallout-maw-ability-action-section">
            <div class="fallout-maw-item-use-category-header">
              <span>{{localize "FALLOUTMAW.Ability.Actions.AllowedAttacks"}}</span>
              <button type="button" data-add-ability-attack-choice {{#unless canAddAttackAction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Ability.Actions.AddAttackVariant"}}</button>
            </div>
            <div class="fallout-maw-ability-action-choice-list">
              {{#each attackActionRows}}
              <div class="fallout-maw-ability-action-choice-row" data-ability-attack-choice-row data-choice-index="{{choiceIndex}}">
                <select data-ability-attack-choice name="{{functionPath}}.{{functionIndex}}.actions.{{actionIndex}}.attackActionKeys.{{choiceIndex}}">{{#each choices}}<option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
                <button type="button" class="fallout-maw-icon-button" data-delete-ability-attack-choice {{#unless ../canDeleteAttackAction}}disabled{{/unless}} title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
              {{/each}}
            </div>
          </div>
          <div class="fallout-maw-list-grid two-columns fallout-maw-ability-action-main-settings">
            <label><span>{{localize "FALLOUTMAW.Ability.Actions.TargetMode"}}</span><select name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.targetMode">{{#each targetModeChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
            <label><span>{{localize "FALLOUTMAW.Ability.Actions.ActionPointCost"}}</span><select data-ability-action-cost-mode name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.actionPointCostMode">{{#each costModeChoices}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
