          <input type="hidden" name="{{functionPath}}.{{functionIndex}}.conditions.{{index}}.id" value="{{id}}">
          <input type="hidden" name="{{functionPath}}.{{functionIndex}}.conditions.{{index}}.groupId" value="{{groupId}}">
          {{#if isPending}}
          <label>
            <span>Условие</span>
            <select name="{{functionPath}}.{{functionIndex}}.conditions.{{index}}.type" data-ability-condition-type>
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-delete-ability-condition title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          {{else}}
          <input type="hidden" name="{{functionPath}}.{{functionIndex}}.conditions.{{index}}.type" value="{{type}}">
          <div class="fallout-maw-ability-condition-card">
            <div class="fallout-maw-ability-condition-card-header">
              <h4>{{typeLabel}}</h4>
