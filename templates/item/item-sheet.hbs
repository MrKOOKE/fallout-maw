                      <select name="{{../functionPath}}.{{../functionIndex}}.conditions.{{../index}}.costs.{{index}}.resourceKey" data-ability-trigger-cost-resource-key aria-label="{{localize 'FALLOUTMAW.Ability.TriggerCost.Resource'}}">
                        {{#each resourceChoices}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                      </select>
                      <input type="text" name="{{../functionPath}}.{{../functionIndex}}.conditions.{{../index}}.costs.{{index}}.formula" value="{{formula}}" data-ability-trigger-cost-formula data-formula-autocomplete="all" aria-label="{{localize 'FALLOUTMAW.Ability.TriggerCost.Formula'}}" placeholder="{{localize 'FALLOUTMAW.Ability.TriggerCost.Formula'}}">
                      <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-delete-ability-trigger-cost title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
                      <div class="fallout-maw-event-reaction-cost-overload">
                        <span>{{localize "FALLOUTMAW.Ability.TriggerCost.Overload"}}</span>
                        <input type="number" name="{{../functionPath}}.{{../functionIndex}}.conditions.{{../index}}.costs.{{index}}.overloadAmount" value="{{overloadAmount}}" min="0" step="1" data-ability-trigger-cost-overload-amount aria-label="{{localize 'FALLOUTMAW.Ability.TriggerCost.OverloadAmount'}}" placeholder="{{localize 'FALLOUTMAW.Ability.TriggerCost.OverloadAmount'}}">
                        <input type="number" value="{{overloadDurationAmount}}" min="0" step="1" data-ability-trigger-cost-overload-duration-amount aria-label="{{localize 'FALLOUTMAW.Ability.TriggerCost.OverloadDuration'}}" placeholder="{{localize 'FALLOUTMAW.Ability.TriggerCost.OverloadDuration'}}">
