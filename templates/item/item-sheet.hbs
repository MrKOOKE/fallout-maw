<div class="fallout-maw-sheet-body">
<header class="sheet-header fallout-maw-sheet-header">
  <img class="profile-img" src="{{item.img}}" {{#unless isTrauma}}data-action="editImage" data-edit="img"{{/unless}} title="{{item.name}}" height="80">
  <div class="fallout-maw-header-fields">
    {{#if isTrauma}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Конечность</span>
        <input type="text" value="{{system.limbLabel}}" disabled>
      </label>
      <label>
        <span>Тип урона</span>
        <input type="text" value="{{system.damageTypeLabel}}" disabled>
      </label>
    </div>
    {{else if isDisease}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Потребность</span>
        <input type="text" value="{{system.needLabel}}" disabled>
      </label>
      <label>
        <span>Уровень</span>
        <input type="number" value="{{system.level}}" disabled>
      </label>
    </div>
    {{else}}
    <input class="fallout-maw-title-input" name="name" type="text" value="{{item.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
    {{#if isGear}}
    <div class="fallout-maw-header-grid fallout-maw-equipped-header-grid">
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" aria-label="{{localize 'FALLOUTMAW.Item.Equipped'}}" {{checked system.equipped}}>
      </div>
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Common.Locked"}}</span>
        <input type="checkbox" name="system.locked" aria-label="{{localize 'FALLOUTMAW.Common.Locked'}}" {{checked system.locked}}>
      </div>
    </div>
    {{else if isAbility}}
    {{else}}
    <div class="fallout-maw-header-grid">
      <label>
        <span>{{localize "FALLOUTMAW.Item.Quantity"}}</span>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="{{#if isContainerFunction}}1{{else}}0{{/if}}" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>Категория предмета</span>
        <select name="system.itemCategory">
          {{#each itemCategoryChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Weight"}}</span>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.TotalWeight"}}</span>
        <input type="number" value="{{totalWeight}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Price"}}</span>
        <input type="number" name="system.price" value="{{system.price}}" min="0">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.PriceCurrency"}}</span>
        <select name="system.priceCurrency">
          {{#each currencies}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" aria-label="{{localize 'FALLOUTMAW.Item.Equipped'}}" {{checked system.equipped}}>
      </div>
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Common.Locked"}}</span>
        <input type="checkbox" name="system.locked" aria-label="{{localize 'FALLOUTMAW.Common.Locked'}}" {{checked system.locked}}>
      </div>
    </div>
    {{/if}}
    {{/if}}
  </div>
</header>

{{#if isTrauma}}
<section class="fallout-maw-panel">
  <h2>Травма</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог</span>
      <input type="text" value="{{system.thresholdPercent}}% / {{system.thresholdValue}}" disabled>
    </label>
    <label>
      <span>Получено при состоянии</span>
      <input type="number" value="{{system.triggeredAtValue}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{traumaHealingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isDisease}}
<section class="fallout-maw-panel">
  <h2>Болезнь</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог потребности</span>
      <input type="text" value="{{system.thresholdPercent}}%" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{healingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isAbility}}
<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="tab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">Общие данные</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="tab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">Функции</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  <section class="fallout-maw-panel fallout-maw-ability-category-panel">
    <label class="fallout-maw-ability-category-field">
      <span>{{localize "FALLOUTMAW.Ability.Category.Label"}}</span>
      <input type="text" name="system.category" value="{{system.category}}" placeholder="{{localize "FALLOUTMAW.Ability.Category.Placeholder"}}">
    </label>
  </section>

  <section class="fallout-maw-panel">
    <h2>Приобретение</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Стоимость ОИ</span>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" step="1">
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только свободные ОИ</span>
        <input type="checkbox" name="system.acquisition.onlyFree" data-ability-only-free {{checked isAbilityOnlyFree}}>
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только ручное исследование</span>
        <input type="checkbox" name="system.acquisition.onlyManual" data-ability-only-manual {{checked isAbilityOnlyManual}}>
      </label>
      <label>
        <span>Навык ручного исследования</span>
        <select name="system.acquisition.skillKey">
          {{#each abilityResearchSkillChoices}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>Сложность ручного исследования</span>
        <input type="number" name="system.acquisition.difficulty" value="{{system.acquisition.difficulty}}" min="0" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
    {{#if editable}}
    <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
    {{else}}
    <div class="editor editor-content">
      {{{descriptionHTML}}}
    </div>
    {{/if}}
  </section>
</section>

<section class="tab {{tabs.functions.cssClass}}" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Функции</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-add-ability-function {{#unless canAddAbilityFunction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить функцию</button>
      </div>
    </div>
    {{#if showFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <select data-choose-ability-function data-function-path="system.functions">
        {{#each abilityFunctionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
    {{#if showFixedAbilityFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <input type="search" data-fixed-ability-function-search placeholder="Поиск фиксированной функции">
      <select data-choose-fixed-ability-function>
        {{#each fixedAbilityFunctionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </section>

  {{#each abilityFunctions}}
  <section class="fallout-maw-panel" data-ability-function-row data-function-id="{{id}}" data-function-index="{{@index}}" data-function-type="{{type}}" data-function-path="{{functionPath}}">
    <div class="fallout-maw-panel-header">
      <h2>{{typeLabel}}</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" class="fallout-maw-icon-button" data-delete-ability-function title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>
    <input type="hidden" name="{{functionPath}}.{{@index}}.id" value="{{id}}">
    <input type="hidden" name="{{functionPath}}.{{@index}}.type" value="{{type}}">
    {{#if isFixed}}
    <input type="hidden" name="{{functionPath}}.{{@index}}.fixedKey" value="{{fixedKey}}">
    {{#if fixedDeusSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Настройки: Бог из машины</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <label>
          <span>Прогресс урона</span>
          <div class="fallout-maw-fixed-progress-inputs">
            <input type="number" value="{{fixedDeusSettings.damageCurrent}}" min="0" step="1" data-fixed-damage-current aria-label="Текущий прогресс">
            <b>/</b>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.damageRequired" value="{{fixedDeusSettings.damageRequired}}" min="1" step="1" aria-label="Урон для срабатывания">
          </div>
        </label>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Прозрение</strong>
          <label>
            <span>Бонус к навыкам</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.insight.skillBonus" value="{{fixedDeusSettings.insight.skillBonus}}" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" value="{{fixedDeusSettings.insightDurationAmount}}" min="0" step="1" data-fixed-insight-duration-amount>
              <select data-fixed-insight-duration-unit>
                {{#each fixedDeusSettings.insightDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Забавный случай</strong>
          <label>
            <span>Уничтожаемые предметы и валюта, %</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.disintegrate.destroyPercent" value="{{fixedDeusSettings.disintegrate.destroyPercent}}" min="0" max="100" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Удачная находка</strong>
          <label>
            <span>Минимум ценности</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.luckyFind.valueMin" value="{{fixedDeusSettings.luckyFind.valueMin}}" min="0" step="1">
          </label>
          <label>
            <span>Максимум ценности</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.luckyFind.valueMax" value="{{fixedDeusSettings.luckyFind.valueMax}}" min="0" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Чудесное спасение</strong>
          <label>
            <span>Восстановить</span>
            <select name="{{functionPath}}.{{functionIndex}}.fixedSettings.rescue.restoreMode" data-fixed-rescue-mode>
              {{#each fixedDeusSettings.restoreModeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <label data-fixed-rescue-count {{#unless fixedDeusSettings.isRestoreCountMode}}hidden{{/unless}}>
            <span>Исцеляемые конечности</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.rescue.restoreCount" value="{{fixedDeusSettings.rescue.restoreCount}}" min="1" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedCurseAndBlessingSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Настройки: Порча и благословение</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Срабатывание</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.energyCost" value="{{fixedCurseAndBlessingSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса, %</span>
            <input type="text" name="{{functionPath}}.{{functionIndex}}.fixedSettings.triggerFormula" value="{{fixedCurseAndBlessingSettings.triggerFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Длительность изменения</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" value="{{fixedCurseAndBlessingSettings.durationAmount}}" min="0" step="1" data-fixed-curse-duration-amount>
              <select data-fixed-curse-duration-unit>
                {{#each fixedCurseAndBlessingSettings.durationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedAllOrNothingSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Настройки: Все или ничего</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Активация</strong>
          <label>
            <span>Расход энергии</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.energyCost" value="{{fixedAllOrNothingSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Формула шанса</span>
            <input type="text" name="{{functionPath}}.{{functionIndex}}.fixedSettings.chanceFormula" value="{{fixedAllOrNothingSettings.chanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Дробь, % пуль</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.pelletCoveragePercent" value="{{fixedAllOrNothingSettings.pelletCoveragePercent}}" min="0" max="100" step="1">
          </label>
          <label>
            <span>Очередь, % пуль</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.burstCoveragePercent" value="{{fixedAllOrNothingSettings.burstCoveragePercent}}" min="0" max="100" step="1">
          </label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Перегрузка</strong>
          <label>
            <span>Доп. расход энергии</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.overloadEnergyCost" value="{{fixedAllOrNothingSettings.overloadEnergyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Длительность</span>
            <div class="fallout-maw-split-number-field-control">
              <input type="number" value="{{fixedAllOrNothingSettings.overloadDurationAmount}}" min="0" step="1" data-fixed-all-or-nothing-overload-duration-amount>
              <select data-fixed-all-or-nothing-overload-duration-unit>
                {{#each fixedAllOrNothingSettings.overloadDurationUnitChoices}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedReaperSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-ability-subsection-header">
        <h3>Настройки: Жнец</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Восстановление ОД</strong>
          <label>
            <span>Формула за убийство</span>
            <input type="text" name="{{functionPath}}.{{functionIndex}}.fixedSettings.killChanceFormula" value="{{fixedReaperSettings.killChanceFormula}}" data-formula-autocomplete="all">
          </label>
          <label>
            <span>Формула за атаку</span>
            <input type="text" name="{{functionPath}}.{{functionIndex}}.fixedSettings.attackChanceFormula" value="{{fixedReaperSettings.attackChanceFormula}}" data-formula-autocomplete="all">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedVirtuosoSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-ability-subsection-header">
        <h3>Настройки: Виртуоз</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Бонус при смене оружия</strong>
          <label>
            <span>Точность</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.accuracyBonus" value="{{fixedVirtuosoSettings.accuracyBonus}}" step="1">
          </label>
          <label>
            <span>Урон, %</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.damagePercentBonus" value="{{fixedVirtuosoSettings.damagePercentBonus}}" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedAimingSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-ability-subsection-header">
        <h3>Настройки: Выцеливание</h3>
      </div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Прицельный выстрел</strong>
          <label>
            <span>Расход энергии за атаку</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.energyCost" value="{{fixedAimingSettings.energyCost}}" min="0" step="1">
          </label>
          <label>
            <span>Игнорирование врождённой сложности, %</span>
            <input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.innateDifficultyIgnorePercent" value="{{fixedAimingSettings.innateDifficultyIgnorePercent}}" min="1" max="100" step="1">
          </label>
        </div>
      </div>
    </div>
    {{/if}}
    {{#if fixedRicochetSettings}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-ability-subsection-header"><h3>Настройки: Рикошет</h3></div>
      <div class="fallout-maw-fixed-settings">
        <div class="fallout-maw-fixed-settings-row">
          <strong>Активация и перегрузка</strong>
          <label><span>Стоимость активации, энергия</span><input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.activationEnergyCost" value="{{fixedRicochetSettings.activationEnergyCost}}" min="0" step="1"></label>
          <label><span>Перегрузка, энергия</span><input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.overloadEnergyCost" value="{{fixedRicochetSettings.overloadEnergyCost}}" min="0" step="1"></label>
          <label><span>Длительность перегрузки, сек.</span><input type="number" name="{{functionPath}}.{{functionIndex}}.fixedSettings.overloadDurationSeconds" value="{{fixedRicochetSettings.overloadDurationSeconds}}" min="0" step="1"></label>
        </div>
        <div class="fallout-maw-fixed-settings-row">
          <strong>Отражения</strong>
