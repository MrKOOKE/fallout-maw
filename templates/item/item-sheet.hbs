        <div class="fallout-maw-occupied-slot-list">
          {{#each slots}}
          <button type="button" class="fallout-maw-occupied-slot-choice {{#if selected}}active{{/if}}" data-weapon-slot-choice="{{selectionKey}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">
            {{label}}
          </button>
          {{/each}}
        </div>
      </section>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSlots"}}</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
