    <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
    {{else}}
    <div class="editor editor-content">
      {{{descriptionHTML}}}
    </div>
    {{/if}}
