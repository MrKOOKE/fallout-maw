<div class="fallout-maw-sheet-body">
<header class="sheet-header fallout-maw-sheet-header">
  <img class="profile-img" src="{{item.img}}" {{#unless isTrauma}}data-action="editImage" data-edit="img"{{/unless}} title="{{item.name}}" height="80">
  <div class="fallout-maw-header-fields">
    {{#if isTrauma}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Конечность</span>
        <input type="text" value="{{system.limbLabel}}" disabled>
      </label>
      <label>
        <span>Тип урона</span>
        <input type="text" value="{{system.damageTypeLabel}}" disabled>
      </label>
    </div>
    {{else if isDisease}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Потребность</span>
        <input type="text" value="{{system.needLabel}}" disabled>
      </label>
      <label>
        <span>Уровень</span>
        <input type="number" value="{{system.level}}" disabled>
      </label>
    </div>
    {{else}}
    <input class="fallout-maw-title-input" name="name" type="text" value="{{item.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
    {{#if isGear}}
    <div class="fallout-maw-header-grid fallout-maw-equipped-header-grid">
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" aria-label="{{localize 'FALLOUTMAW.Item.Equipped'}}" {{checked system.equipped}}>
      </div>
    </div>
    {{else if isAbility}}
    {{else}}
    <div class="fallout-maw-header-grid">
      <label>
        <span>{{localize "FALLOUTMAW.Item.Quantity"}}</span>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="{{#if isContainerFunction}}1{{else}}0{{/if}}" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>Категория предмета</span>
        <select name="system.itemCategory">
          {{#each itemCategoryChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Weight"}}</span>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.TotalWeight"}}</span>
        <input type="number" value="{{totalWeight}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Price"}}</span>
        <input type="number" name="system.price" value="{{system.price}}" min="0">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.PriceCurrency"}}</span>
        <select name="system.priceCurrency">
          <option value=""></option>
          {{#each currencies}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <div class="fallout-maw-inline-checkbox fallout-maw-equipped-control">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" aria-label="{{localize 'FALLOUTMAW.Item.Equipped'}}" {{checked system.equipped}}>
      </div>
    </div>
    {{/if}}
    {{/if}}
  </div>
</header>

{{#if isTrauma}}
<section class="fallout-maw-panel">
  <h2>Травма</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог</span>
      <input type="text" value="{{system.thresholdPercent}}% / {{system.thresholdValue}}" disabled>
    </label>
    <label>
      <span>Получено при состоянии</span>
      <input type="number" value="{{system.triggeredAtValue}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{traumaHealingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isDisease}}
<section class="fallout-maw-panel">
  <h2>Болезнь</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог потребности</span>
      <input type="text" value="{{system.thresholdPercent}}%" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{healingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isAbility}}
<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="tab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">Общие данные</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="tab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">Функции</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  <section class="fallout-maw-panel">
    <h2>Приобретение</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>Стоимость ОИ</span>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" step="1">
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только свободные ОИ</span>
        <input type="checkbox" name="system.acquisition.onlyFree" data-ability-only-free {{checked isAbilityOnlyFree}}>
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>Только ручное исследование</span>
        <input type="checkbox" name="system.acquisition.onlyManual" data-ability-only-manual {{checked isAbilityOnlyManual}}>
      </label>
      <label>
        <span>Навык ручного исследования</span>
        <select name="system.acquisition.skillKey">
          {{#each abilityResearchSkillChoices}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>Сложность ручного исследования</span>
        <input type="number" name="system.acquisition.difficulty" value="{{system.acquisition.difficulty}}" min="0" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
    {{#if editable}}
    <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
    {{else}}
    <div class="editor editor-content">
      {{{descriptionHTML}}}
    </div>
    {{/if}}
  </section>
</section>

<section class="tab {{tabs.functions.cssClass}}" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>Функции</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-add-ability-function {{#unless canAddAbilityFunction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить функцию</button>
      </div>
    </div>
    {{#if showFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <select data-choose-ability-function>
        {{#each abilityFunctionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </section>

  {{#each abilityFunctions}}
  <section class="fallout-maw-panel" data-ability-function-row data-function-id="{{id}}" data-function-index="{{@index}}" data-function-type="{{type}}">
    <div class="fallout-maw-panel-header">
      <h2>{{typeLabel}}</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-add-ability-change><i class="fa-solid fa-plus"></i> Добавить строку</button>
        <button type="button" data-add-ability-condition><i class="fa-solid fa-plus"></i> Добавить условие</button>
        <button type="button" class="fallout-maw-icon-button" data-delete-ability-function title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>
    <input type="hidden" name="system.functions.{{@index}}.id" value="{{id}}">
    <input type="hidden" name="system.functions.{{@index}}.type" value="{{type}}">
    <div data-ability-changes>
      {{#each changes}}
      <div class="fallout-maw-ability-change-card" data-ability-change-row data-change-index="{{index}}">
        <input type="hidden" name="system.functions.{{functionIndex}}.changes.{{index}}.id" value="{{id}}">
        <input type="hidden" name="system.functions.{{functionIndex}}.changes.{{index}}.phase" value="initial">
        <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
          <span>Ключ</span>
          <span>Тип</span>
          <span>Значение</span>
          <span>Приоритет</span>
          <span></span>
        </div>
        <div class="fallout-maw-trauma-effect-row">
          <input type="text" name="system.functions.{{functionIndex}}.changes.{{index}}.key" value="{{key}}" data-effect-key-autocomplete {{#if ../isAcquisitionChanges}}data-ability-acquisition-change-key{{/if}}>
          <select name="system.functions.{{functionIndex}}.changes.{{index}}.type">
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <input type="text" name="system.functions.{{functionIndex}}.changes.{{index}}.value" value="{{value}}">
          <input type="number" name="system.functions.{{functionIndex}}.changes.{{index}}.priority" value="{{priority}}" step="1">
          <div class="fallout-maw-inline-controls">
            <button type="button" class="fallout-maw-icon-button" data-delete-ability-change title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">Строки изменений не настроены.</p>
      {{/each}}
    </div>

    {{#if hasConditions}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Условие</h3>
        <div class="fallout-maw-inline-controls">
          <button type="button" data-add-ability-condition><i class="fa-solid fa-plus"></i> Добавить условие</button>
          <button type="button" data-add-ability-penalty {{#unless canAddPenalty}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> Добавить штраф за невыполнение</button>
        </div>
      </div>
      <div class="fallout-maw-ability-conditions">
        {{#each conditionGroups}}
        {{#if isOrGroup}}
        <div class="fallout-maw-ability-condition-or-group">
        {{/if}}
        {{#each conditions}}
        <div class="fallout-maw-ability-condition-row{{#if isPending}} empty{{else}} configured{{/if}}" data-ability-condition-row data-condition-index="{{index}}">
          <input type="hidden" name="system.functions.{{functionIndex}}.conditions.{{index}}.id" value="{{id}}">
          <input type="hidden" name="system.functions.{{functionIndex}}.conditions.{{index}}.groupId" value="{{groupId}}">
          {{#if isPending}}
          <label>
            <span>Условие</span>
            <select name="system.functions.{{functionIndex}}.conditions.{{index}}.type" data-ability-condition-type>
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
          <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-delete-ability-condition title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          {{else}}
          <input type="hidden" name="system.functions.{{functionIndex}}.conditions.{{index}}.type" value="{{type}}">
          <div class="fallout-maw-ability-condition-card">
            <div class="fallout-maw-ability-condition-card-header">
              <h4>{{typeLabel}}</h4>
              <div class="fallout-maw-inline-controls">
                {{#if canAddAlternative}}
                <button type="button" data-add-ability-condition-alternative><i class="fa-solid fa-plus"></i> ИЛИ</button>
                {{/if}}
                <button type="button" class="fallout-maw-icon-button fallout-maw-square-delete-button" data-delete-ability-condition title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
              </div>
            </div>
            <div class="fallout-maw-ability-condition-fields">
              {{#if isHealth}}
              <label>
                <span>Состояние ОЗ чего</span>
                <select name="system.functions.{{functionIndex}}.conditions.{{index}}.healthTarget" data-ability-condition-health-target>
                  {{#each healthTargetChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{#if showLimbChoice}}
              <label>
                <span>Конечность</span>
                <select name="system.functions.{{functionIndex}}.conditions.{{index}}.limbKey">
                  {{#each limbChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{/if}}
              <label>
                <span>Оператор</span>
                <select name="system.functions.{{functionIndex}}.conditions.{{index}}.operator">
                  {{#each healthOperatorChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Процент ОЗ</span>
                <input type="number" name="system.functions.{{functionIndex}}.conditions.{{index}}.percent" value="{{percent}}" min="0" max="100" step="1">
              </label>
              {{/if}}
              {{#if isEquipment}}
              <label>
                <span>Слот экипировки</span>
                <select name="system.functions.{{functionIndex}}.conditions.{{index}}.equipmentSlotKey">
                  {{#each equipmentSlotChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Оператор</span>
                <select name="system.functions.{{functionIndex}}.conditions.{{index}}.operator">
                  {{#each equipmentOperatorChoices}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>
              {{/if}}
              {{#if isLimitedChanges}}
              <label>
                <span>Выбрать изменений</span>
                <input type="number" name="system.functions.{{functionIndex}}.conditions.{{index}}.limit" value="{{changeLimit}}" min="1" max="{{changeLimitMax}}" step="1">
              </label>
              <label>
                <span>Всего изменений</span>
                <input type="number" value="{{changeLimitTotal}}" disabled>
              </label>
              {{/if}}
            </div>
          </div>
          {{/if}}
        </div>
        {{/each}}
        {{#if isOrGroup}}
        </div>
        {{/if}}
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if hasPenalties}}
    <div class="fallout-maw-ability-subsection">
      <div class="fallout-maw-panel-header">
        <h3>Штрафы</h3>
        <button type="button" data-add-ability-penalty><i class="fa-solid fa-plus"></i> Добавить строку</button>
      </div>
      <div>
        {{#each penalties}}
        <div class="fallout-maw-ability-change-card" data-ability-penalty-row data-penalty-index="{{penaltyIndex}}">
          <input type="hidden" name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.id" value="{{id}}">
          <input type="hidden" name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.phase" value="initial">
          <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
            <span>Ключ</span>
            <span>Тип</span>
            <span>Значение</span>
            <span>Приоритет</span>
            <span></span>
          </div>
          <div class="fallout-maw-trauma-effect-row">
            <input type="text" name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.key" value="{{key}}" data-effect-key-autocomplete>
            <select name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.type">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="text" name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.value" value="{{value}}">
            <input type="number" name="system.functions.{{functionIndex}}.penalties.{{penaltyIndex}}.priority" value="{{priority}}" step="1">
            <button type="button" class="fallout-maw-icon-button" data-delete-ability-penalty title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}
  </section>
  {{else}}
  <section class="fallout-maw-panel">
    <p class="fallout-maw-empty-list">Функции не настроены.</p>
  </section>
  {{/each}}
</section>
{{else if isGear}}
<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="tab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">{{localize "FALLOUTMAW.Item.DetailsTab"}}</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="tab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">{{localize "FALLOUTMAW.Item.FunctionsTab"}}</a>
  <a class="item {{tabs.craft.cssClass}}" data-action="tab" data-group="{{tabs.craft.group}}" data-tab="{{tabs.craft.id}}">Крафт</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Item.GeneralData"}}</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.Quantity"}}</span>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="{{#if isContainerFunction}}1{{else}}0{{/if}}" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.MaxStack"}}</span>
        <input type="number" name="system.maxStack" value="{{system.maxStack}}" min="1" step="1" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>Категория предмета</span>
        <select name="system.itemCategory">
          {{#each itemCategoryChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Weight"}}</span>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.TotalWeight"}}</span>
        <input type="number" value="{{totalWeight}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Price"}}</span>
        <input type="number" name="system.price" value="{{system.price}}" min="0">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.PriceCurrency"}}</span>
        <select name="system.priceCurrency">
          <option value=""></option>
          {{#each currencies}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.InventoryWidth"}}</span>
        <input type="number" name="system.placement.width" value="{{system.placement.width}}" min="1" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.InventoryHeight"}}</span>
        <input type="number" name="system.placement.height" value="{{system.placement.height}}" min="1" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Item.OccupiedSlots"}}</h2>
    <div class="fallout-maw-hidden-controls">
      {{#each equipmentSlotSelections}}
      <input type="checkbox" name="system.occupiedSlots.{{selectionKey}}" data-equipment-slot-input="{{selectionKey}}" {{checked selected}}>
      {{/each}}
    </div>
    <div class="fallout-maw-occupied-slot-groups">
      {{#each equipmentSlotGroups}}
      <section class="fallout-maw-occupied-slot-group">
        <strong>{{raceNames}}</strong>
        <div class="fallout-maw-occupied-slot-list">
          {{#each slots}}
          <button type="button" class="fallout-maw-occupied-slot-choice {{#if selected}}active{{/if}}" data-equipment-slot-choice="{{selectionKey}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">
