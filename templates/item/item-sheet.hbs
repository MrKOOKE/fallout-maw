<div class="fallout-maw-sheet-body">
<header class="sheet-header fallout-maw-sheet-header">
  <img class="profile-img" src="{{item.img}}" {{#unless isTrauma}}data-action="editImage" data-field="img"{{/unless}} title="{{item.name}}" height="80" width="80">
  <div class="fallout-maw-header-fields">
    {{#if isTrauma}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Конечность</span>
        <input type="text" value="{{system.limbLabel}}" disabled>
      </label>
      <label>
        <span>Тип урона</span>
        <input type="text" value="{{system.damageTypeLabel}}" disabled>
      </label>
    </div>
    {{else if isDisease}}
    <h1 class="fallout-maw-title-display">{{item.name}}</h1>
    <div class="fallout-maw-header-grid">
      <label>
        <span>Потребность</span>
        <input type="text" value="{{system.needLabel}}" disabled>
      </label>
      <label>
        <span>Уровень</span>
        <input type="number" value="{{system.level}}" disabled>
      </label>
    </div>
    {{else}}
    <input class="fallout-maw-title-input" name="name" type="text" value="{{item.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
    {{#if isGear}}
    <div class="fallout-maw-header-grid">
      <label class="fallout-maw-inline-checkbox">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" {{checked system.equipped}}>
      </label>
    </div>
    {{else}}
    <div class="fallout-maw-header-grid">
      <label>
        <span>{{localize "FALLOUTMAW.Item.Quantity"}}</span>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="{{#if isContainerFunction}}1{{else}}0{{/if}}" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Weight"}}</span>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.TotalWeight"}}</span>
        <input type="number" value="{{totalWeight}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Price"}}</span>
        <input type="number" name="system.price" value="{{system.price}}" min="0">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.PriceCurrency"}}</span>
        <select name="system.priceCurrency">
          <option value=""></option>
          {{#each currencies}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="fallout-maw-inline-checkbox">
        <span>{{localize "FALLOUTMAW.Item.Equipped"}}</span>
        <input type="checkbox" name="system.equipped" {{checked system.equipped}}>
      </label>
    </div>
    {{/if}}
    {{/if}}
  </div>
</header>

{{#if isTrauma}}
<section class="fallout-maw-panel">
  <h2>Травма</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог</span>
      <input type="text" value="{{system.thresholdPercent}}% / {{system.thresholdValue}}" disabled>
    </label>
    <label>
      <span>Получено при состоянии</span>
      <input type="number" value="{{system.triggeredAtValue}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{traumaHealingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isDisease}}
<section class="fallout-maw-panel">
  <h2>Болезнь</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>Порог потребности</span>
      <input type="text" value="{{system.thresholdPercent}}%" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}</span>
      <input type="number" value="{{system.healingDifficulty}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}</span>
      <input type="text" value="{{system.healingToolClass}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}</span>
      <input type="text" value="{{system.healingProgress}} / {{system.healingProgressMax}}" disabled>
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}</span>
      <input type="text" value="{{healingSkillLabel}}" disabled>
    </label>
  </div>
</section>

<section class="fallout-maw-panel">
  <h2>Эффекты</h2>
  <div class="fallout-maw-trauma-effect-table">
    <div class="fallout-maw-trauma-effect-row fallout-maw-grid-header">
      <span>Ключ</span>
      <span>Тип</span>
      <span>Значение</span>
      <span>Приоритет</span>
    </div>
    {{#each system.effects}}
    <div class="fallout-maw-trauma-effect-row">
      <span>{{key}}</span>
      <span>{{type}}</span>
      <span>{{value}}</span>
      <span>{{priority}}</span>
    </div>
    {{else}}
    <p class="fallout-maw-empty-list">Нет строк эффекта.</p>
    {{/each}}
  </div>
</section>
{{else if isGear}}
<nav class="sheet-tabs tabs fallout-maw-item-tabs" data-group="primary">
  <a class="item {{tabs.details.cssClass}}" data-action="tab" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">{{localize "FALLOUTMAW.Item.DetailsTab"}}</a>
  <a class="item {{tabs.functions.cssClass}}" data-action="tab" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">{{localize "FALLOUTMAW.Item.FunctionsTab"}}</a>
</nav>

<section class="tab {{tabs.details.cssClass}}" data-group="{{tabs.details.group}}" data-tab="{{tabs.details.id}}">
  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Item.GeneralData"}}</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.Quantity"}}</span>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="{{#if isContainerFunction}}1{{else}}0{{/if}}" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.MaxStack"}}</span>
        <input type="number" name="system.maxStack" value="{{system.maxStack}}" min="1" step="1" {{#if isContainerFunction}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Weight"}}</span>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.TotalWeight"}}</span>
        <input type="number" value="{{totalWeight}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.Price"}}</span>
        <input type="number" name="system.price" value="{{system.price}}" min="0">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.PriceCurrency"}}</span>
        <select name="system.priceCurrency">
          <option value=""></option>
          {{#each currencies}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.InventoryWidth"}}</span>
        <input type="number" name="system.placement.width" value="{{system.placement.width}}" min="1" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.InventoryHeight"}}</span>
        <input type="number" name="system.placement.height" value="{{system.placement.height}}" min="1" step="1">
      </label>
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Item.OccupiedSlots"}}</h2>
    <div class="fallout-maw-hidden-controls">
      {{#each equipmentSlotSelections}}
      <input type="checkbox" name="system.occupiedSlots.{{selectionKey}}" data-equipment-slot-input="{{selectionKey}}" {{checked selected}}>
      {{/each}}
    </div>
    <div class="fallout-maw-occupied-slot-groups">
      {{#each equipmentSlotGroups}}
      <section class="fallout-maw-occupied-slot-group">
        <strong>{{raceNames}}</strong>
        <div class="fallout-maw-occupied-slot-list">
          {{#each slots}}
          <button type="button" class="fallout-maw-occupied-slot-choice {{#if selected}}active{{/if}}" data-equipment-slot-choice="{{selectionKey}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">
            {{label}}
          </button>
          {{/each}}
        </div>
      </section>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-description-panel">
    <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
    {{#if editable}}
    <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
      {{{descriptionHTML}}}
    </prose-mirror>
    {{else}}
    <div class="editor editor-content">
      {{{descriptionHTML}}}
    </div>
    {{/if}}
  </section>
</section>

<section class="tab {{tabs.functions.cssClass}}" data-group="{{tabs.functions.group}}" data-tab="{{tabs.functions.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Item.FunctionsTab"}}</h2>
      <div class="fallout-maw-inline-controls">
        <button type="button" data-add-item-function {{#unless canAddItemFunction}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.AddFunction"}}</button>
      </div>
    </div>
    {{#if showFunctionPicker}}
    <div class="fallout-maw-function-picker">
      <select data-choose-item-function>
        {{#each itemFunctionChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </section>

  {{#if isContainerFunction}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Item.FunctionContainer"}}</h2>
      <button type="button" data-remove-item-function="container" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.ContainerColumns"}}</span>
        <input type="number" name="system.container.columns" value="{{system.container.columns}}" min="1" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.ContainerRows"}}</span>
        <input type="number" name="system.container.rows" value="{{system.container.rows}}" min="1" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.ContainerMaxLoad"}}</span>
        <input type="number" name="system.container.maxLoad" value="{{system.container.maxLoad}}" min="0" step="0.1">
      </label>
    </div>
    <label class="fallout-maw-range-field">
      <span>{{localize "FALLOUTMAW.Item.ContainerLoadReduction"}}</span>
      <div class="fallout-maw-range-control">
        <input type="range" data-container-load-reduction value="{{containerLoadReduction}}" min="0" max="100" step="1">
        <input type="number" data-container-load-reduction value="{{containerLoadReduction}}" min="0" max="100" step="1">
        <strong>%</strong>
      </div>
    </label>
  </section>
  {{/if}}

  {{#if hasDamageMitigationFunction}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Item.FunctionDamageMitigation"}}</h2>
      <button type="button" data-remove-item-function="damageMitigation" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="fallout-maw-mitigation-controls">
      <label>
        <span>{{localize "FALLOUTMAW.Item.MitigationMode"}}</span>
        <select name="system.functions.damageMitigation.mode">
          {{#each damageMitigationModeChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.FinalDamageReduction"}}</span>
        <input type="number" name="system.functions.damageMitigation.finalReduction" value="{{system.functions.damageMitigation.finalReduction}}" min="0" step="1">
      </label>
    </div>
    <div class="fallout-maw-mitigation-matrix" style="--fallout-maw-mitigation-columns: {{damageMitigationTable.columns}};">
      <div class="fallout-maw-mitigation-cell fallout-maw-grid-header">{{localize "FALLOUTMAW.Settings.DamageTypes.Title"}}</div>
      {{#each damageMitigationTable.limbs}}
      <div class="fallout-maw-mitigation-cell fallout-maw-grid-header">{{label}}</div>
      {{/each}}
      {{#each damageMitigationTable.rows}}
      <div class="fallout-maw-mitigation-cell fallout-maw-mitigation-damage-type">{{damageTypeLabel}}</div>
      {{#each cells}}
      <label class="fallout-maw-mitigation-cell" data-mitigation-cell data-mitigation-row="{{rowIndex}}" data-mitigation-column="{{columnIndex}}">
        <input type="number" name="system.functions.damageMitigation.entries.{{limbKey}}.{{damageTypeKey}}.value" value="{{value}}" step="1">
        <button type="button" class="fallout-maw-mitigation-fill-handle" data-mitigation-fill-handle title="{{localize 'FALLOUTMAW.Item.FillMitigationValues'}}" aria-label="{{localize 'FALLOUTMAW.Item.FillMitigationValues'}}"><i class="fa-solid fa-grip"></i></button>
      </label>
      {{/each}}
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if hasConditionFunction}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Item.FunctionCondition"}}</h2>
      <button type="button" data-remove-item-function="condition" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="fallout-maw-list-grid three-columns">
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Item.ConditionValue"}}</span>
        <div>
          <input type="number" name="system.functions.condition.value" value="{{system.functions.condition.value}}" min="0" step="1">
          <strong>/</strong>
          <input type="number" name="system.functions.condition.max" value="{{system.functions.condition.max}}" min="0" step="1">
        </div>
      </label>
    </div>
  </section>
  {{/if}}

  {{#each weaponFunctionSections}}
  <section class="fallout-maw-panel" data-weapon-function-section data-weapon-function-path="{{path}}">
    <div class="fallout-maw-panel-header">
      <h2>{{title}}</h2>
      <div class="fallout-maw-inline-controls">
        {{#if canAddAdditional}}
        <button type="button" data-add-additional-weapon-function><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.AddAdditionalWeaponFunction"}}</button>
        {{/if}}
        {{#if isAdditional}}
        <button type="button" data-delete-additional-weapon-function="{{id}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
        {{else}}
        <button type="button" data-remove-item-function="weapon" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
        {{/if}}
      </div>
    </div>
    {{#if isAdditional}}
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.AdditionalWeaponFunctionName"}}</span>
        <input type="text" name="{{path}}.name" value="{{weaponData.name}}">
      </label>
      <input type="hidden" name="{{path}}.id" value="{{weaponData.id}}">
      <input type="hidden" name="{{path}}.enabled" value="true">
    </div>
    {{/if}}
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponDamage"}}</span>
        <input type="number" name="{{path}}.damage" value="{{weaponData.damage}}" min="0" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponPellets"}}</span>
        <input type="number" name="{{path}}.pellets" value="{{weaponData.pellets}}" min="1" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponSkill"}}</span>
        <select name="{{path}}.skillKey">
          {{#each skillChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAccuracyBonus"}}</span>
        <input type="number" name="{{path}}.accuracyBonus" value="{{weaponData.accuracyBonus}}" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponCriticalChanceModifier"}}</span>
        <input type="number" name="{{path}}.criticalChanceModifier" value="{{weaponData.criticalChanceModifier}}" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponCriticalDamagePercent"}}</span>
        <input type="number" name="{{path}}.criticalDamagePercent" value="{{weaponData.criticalDamagePercent}}" min="0" step="1">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponMaxRange"}}</span>
        <input type="number" name="{{path}}.maxRangeMeters" value="{{weaponData.maxRangeMeters}}" min="0" step="1">
      </label>
      <label class="fallout-maw-split-number-field">
        <span>{{localize "FALLOUTMAW.Item.WeaponEffectiveRange"}}</span>
        <div>
          <input type="number" name="{{path}}.effectiveRange.value" value="{{weaponData.effectiveRange.value}}" min="0" step="1">
          <strong>/</strong>
          <input type="number" name="{{path}}.effectiveRange.max" value="{{weaponData.effectiveRange.max}}" min="0" step="1">
        </div>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponPenetration"}}</span>
        <input type="number" name="{{path}}.penetration" value="{{weaponData.penetration}}" min="0" step="1">
      </label>
      {{#if hasMagazineCost}}
        <label class="fallout-maw-split-number-field">
          <span>{{localize "FALLOUTMAW.Item.WeaponMagazine"}}</span>
          <div>
            <input type="number" name="{{path}}.magazine.value" value="{{weaponData.magazine.value}}" min="0" step="1">
            <strong>/</strong>
            <input type="number" name="{{path}}.magazine.max" value="{{weaponData.magazine.max}}" min="0" step="1">
          </div>
        </label>
      {{/if}}
    </div>

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponDamageTypes"}}</h3>
      <button type="button" data-add-weapon-damage-type><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponAddDamageType"}}</button>
    </div>
    <div class="fallout-maw-settings-table fallout-maw-weapon-damage-types">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span>{{localize "FALLOUTMAW.Common.Type"}}</span>
        <span>{{localize "FALLOUTMAW.Common.ValuePercent"}}</span>
        <span></span>
      </div>
      {{#each damageTypeRows}}
      <div class="fallout-maw-settings-row" data-weapon-damage-type-row="{{index}}">
        <select name="{{../path}}.damageTypes.{{index}}.key" data-weapon-damage-type-key>
          {{#each choices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <input type="number" name="{{../path}}.damageTypes.{{index}}.percent" value="{{percent}}" min="0" max="100" step="1" data-weapon-damage-percent>
        <button type="button" data-delete-weapon-damage-type="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{/each}}
    </div>
    <input type="hidden" name="{{path}}.damageTypeKey" value="{{weaponData.damageTypeKey}}">

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponResourceCosts"}}</h3>
      <button type="button" data-add-weapon-resource-cost><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponAddResourceCost"}}</button>
    </div>
    <div class="fallout-maw-settings-table fallout-maw-weapon-resource-costs">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span>{{localize "FALLOUTMAW.Common.Type"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
        <span></span>
      </div>
      {{#each resourceCosts}}
      <div class="fallout-maw-settings-row">
        <select name="{{../path}}.resourceCosts.{{index}}.type">
          {{#each typeChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <input type="number" name="{{../path}}.resourceCosts.{{index}}.amount" value="{{amount}}" min="0" step="1">
        <button type="button" data-delete-weapon-resource-cost="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Item.WeaponNoResourceCosts"}}</p>
      {{/each}}
    </div>

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponUseRequirements"}}</h3>
      <button type="button" data-add-weapon-requirement><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponAddRequirement"}}</button>
    </div>
    <div class="fallout-maw-settings-table fallout-maw-weapon-requirements">
      <div class="fallout-maw-settings-row fallout-maw-grid-header">
        <span>{{localize "FALLOUTMAW.Common.Type"}}</span>
        <span>{{localize "FALLOUTMAW.Item.WeaponRequirementTarget"}}</span>
        <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
        <span></span>
      </div>
      {{#each requirements}}
      <div class="fallout-maw-settings-row">
        <select name="{{../path}}.requirements.{{index}}.type" data-weapon-requirement-type="{{index}}">
          {{#each typeChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <select name="{{../path}}.requirements.{{index}}.key">
          {{#each keyChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <input type="number" name="{{../path}}.requirements.{{index}}.value" value="{{value}}" min="0" step="1">
        <button type="button" data-delete-weapon-requirement="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Item.WeaponNoRequirements"}}</p>
      {{/each}}
    </div>

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponAvailableActions"}}</h3>
    </div>
    <div class="fallout-maw-hidden-controls">
      {{#each actionChoices}}
      <input type="checkbox" name="{{../path}}.availableActions.{{key}}" data-weapon-action-input="{{key}}" {{checked selected}}>
      {{/each}}
    </div>
    <div class="fallout-maw-button-toggle-grid">
      {{#each actionChoices}}
      <button type="button" class="fallout-maw-toggle-button {{#if selected}}active{{/if}}" data-weapon-action-choice="{{key}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">
        {{label}}
      </button>
      {{/each}}
    </div>
    <div class="fallout-maw-weapon-action-settings-list">
      {{#each actionChoices}}
      {{#if selected}}
      <section class="fallout-maw-weapon-action-settings" data-weapon-action-settings="{{key}}">
        <h3>{{label}}</h3>
        {{#if isVolley}}
        <div class="fallout-maw-list-grid three-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponVolleyDamageRadius"}}</span>
            <input type="number" name="{{../path}}.volley.damageRadius" value="{{volleyDamageRadius}}" min="0" step="1">
          </label>
        </div>
        <div class="fallout-maw-panel-header">
          <h4>{{localize "FALLOUTMAW.Item.WeaponVolleyRegion"}}</h4>
          <button type="button" data-add-volley-region-damage><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponVolleyAddRegionDamage"}}</button>
        </div>
        <div class="fallout-maw-settings-table fallout-maw-damage-entry-table fallout-maw-volley-region-damage">
          <div class="fallout-maw-settings-row fallout-maw-grid-header">
            <span>{{localize "FALLOUTMAW.Item.WeaponDamageType"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
            <span></span>
          </div>
          {{#each volleyRegionDamageRows}}
          <div class="fallout-maw-settings-row" data-volley-region-damage-row="{{index}}">
            <select name="{{../../path}}.volley.regionDamageEntries.{{index}}.damageTypeKey" data-volley-region-damage-type>
              {{#each choices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="number" name="{{../../path}}.volley.regionDamageEntries.{{index}}.amount" value="{{amount}}" min="0" step="1" data-volley-region-damage-amount>
            <button type="button" class="fallout-maw-icon-delete-button" data-delete-volley-region-damage="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Item.WeaponVolleyNoRegionDamage"}}</p>
          {{/each}}
        </div>
        <div class="fallout-maw-list-grid three-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponVolleyRegionRadius"}}</span>
            <input type="number" name="{{../path}}.volley.regionRadius" value="{{volleyRegionRadius}}" min="0" step="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponVolleyRegionDuration"}}</span>
            <input type="number" name="{{../path}}.volley.regionDurationSeconds" value="{{volleyRegionDurationSeconds}}" min="0" step="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponVolleyRegionDelay"}}</span>
            <input type="number" name="{{../path}}.volley.regionDelaySeconds" value="{{volleyRegionDelaySeconds}}" min="0" step="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponVolleyRegionRadiusDelta"}}</span>
            <input type="number" name="{{../path}}.volley.regionRadiusDeltaMeters" value="{{volleyRegionRadiusDeltaMeters}}" step="1">
          </label>
        </div>
        {{else}}
        <div class="fallout-maw-list-grid three-columns">
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponAttackCone"}}</span>
            <input type="number" name="{{../path}}.{{key}}.attackConeDegrees" value="{{attackConeDegrees}}" min="0" step="1">
          </label>
          {{#if isBurst}}
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponBurstCount"}}</span>
            <input type="number" name="{{../path}}.burst.count" value="{{burstCount}}" min="1" step="1">
          </label>
          <label>
            <span>{{localize "FALLOUTMAW.Item.WeaponBurstDifficultyPerShot"}}</span>
            <input type="number" name="{{../path}}.burst.difficultyPerShot" value="{{burstDifficultyPerShot}}" min="0" step="1">
          </label>
          {{/if}}
        </div>
        {{#if isMelee}}
        <div class="fallout-maw-weapon-action-mode-grid">
          <section class="fallout-maw-weapon-action-mode">
            <div class="fallout-maw-weapon-action-mode-header">
              <h4>{{localize "FALLOUTMAW.Item.WeaponAttackModeThrust"}}</h4>
              <label>
                <input type="checkbox" name="{{../path}}.{{key}}.thrust.enabled" data-weapon-attack-mode-enabled="thrust" {{checked thrust.enabled}}>
                <span>{{localize "FALLOUTMAW.Effects.Enable"}}</span>
              </label>
            </div>
            <div class="fallout-maw-list-grid three-columns">
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeAccuracyModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.thrust.accuracyModifier" value="{{thrust.accuracyModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeCriticalChanceModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.thrust.criticalChanceModifier" value="{{thrust.criticalChanceModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeDamagePercentModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.thrust.damagePercentModifier" value="{{thrust.damagePercentModifier}}" step="1">
              </label>
            </div>
          </section>
          <section class="fallout-maw-weapon-action-mode">
            <div class="fallout-maw-weapon-action-mode-header">
              <h4>{{localize "FALLOUTMAW.Item.WeaponAttackModeSwing"}}</h4>
              <label>
                <input type="checkbox" name="{{../path}}.{{key}}.swing.enabled" data-weapon-attack-mode-enabled="swing" {{checked swing.enabled}}>
                <span>{{localize "FALLOUTMAW.Effects.Enable"}}</span>
              </label>
            </div>
            <div class="fallout-maw-list-grid three-columns">
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeAccuracyModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.accuracyModifier" value="{{swing.accuracyModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeCriticalChanceModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.criticalChanceModifier" value="{{swing.criticalChanceModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeDamagePercentModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.damagePercentModifier" value="{{swing.damagePercentModifier}}" step="1">
              </label>
            </div>
          </section>
        </div>
        {{/if}}
        {{/if}}
        <div class="fallout-maw-panel-header fallout-maw-weapon-action-subheader">
          <h4>{{localize "FALLOUTMAW.Item.WeaponCriticalFailureConsequences"}}</h4>
          <button type="button" data-add-weapon-critical-failure-consequence="{{key}}"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponAddCriticalFailureConsequence"}}</button>
        </div>
        <div class="fallout-maw-settings-table fallout-maw-weapon-critical-failure-consequences">
          <div class="fallout-maw-settings-row fallout-maw-grid-header">
            <span>{{localize "FALLOUTMAW.Common.Type"}}</span>
            <span>{{localize "FALLOUTMAW.Item.WeaponCriticalFailureResource"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
            <span></span>
          </div>
          {{#each criticalFailureConsequences}}
          <div class="fallout-maw-settings-row">
            <select name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.type">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <select name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.resourceType">
              {{#each resourceChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="number" name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.amount" value="{{amount}}" min="0" step="1">
            <button type="button" data-weapon-action-key="{{../key}}" data-delete-weapon-critical-failure-consequence="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Item.WeaponNoCriticalFailureConsequences"}}</p>
          {{/each}}
        </div>
      </section>
      {{/if}}
      {{/each}}
    </div>
    {{!-- Legacy fallback field is intentionally hidden while older items migrate by normal form saves. --}}
    <input type="hidden" name="{{path}}.attackConeDegrees" value="{{weaponData.attackConeDegrees}}">

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponAttackPresentation"}}</h3>
    </div>
    <div class="fallout-maw-list-grid {{#if hasVolleyAction}}three-columns{{else}}two-columns{{/if}}">
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackAnimation"}}</span>
        <input type="text" name="{{path}}.attackAnimationKey" value="{{weaponData.attackAnimationKey}}">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackSound"}}</span>
        <div class="fallout-maw-image-picker-field">
          <input type="text" name="{{path}}.attackSoundPath" value="{{weaponData.attackSoundPath}}" data-weapon-attack-sound-input>
          <button type="button" data-browse-weapon-attack-sound title="{{localize 'FILES.Browse'}}"><i class="fa-solid fa-music"></i></button>
        </div>
      </label>
      {{#if hasVolleyAction}}
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponExplosionAnimation"}}</span>
        <input type="text" name="{{path}}.volley.explosionAnimationKey" value="{{weaponData.volley.explosionAnimationKey}}">
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponExplosionSound"}}</span>
        <div class="fallout-maw-image-picker-field">
          <input type="text" name="{{path}}.volley.explosionSoundPath" value="{{weaponData.volley.explosionSoundPath}}" data-weapon-explosion-sound-input>
          <button type="button" data-browse-weapon-explosion-sound title="{{localize 'FILES.Browse'}}"><i class="fa-solid fa-music"></i></button>
        </div>
      </label>
      {{/if}}
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackDelay"}}</span>
        <input type="number" name="{{path}}.attackAnimationDelayMs" value="{{weaponData.attackAnimationDelayMs}}" min="0" step="1">
      </label>
    </div>
  </section>
  {{/each}}

  {{#each toolFunctions}}
  {{#if enabled}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{label}}</h2>
      <button type="button" data-remove-item-function="{{functionKey}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>Класс инструмента</span>
        <select name="system.functions.tools.{{key}}.toolClass">
          {{#each classChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="fallout-maw-split-number-field">
        <span>Запас</span>
        <div>
          <input type="number" name="system.functions.tools.{{key}}.supply.value" value="{{supplyValue}}" min="0" step="1">
          <strong>/</strong>
          <input type="number" name="system.functions.tools.{{key}}.supply.max" value="{{supplyMax}}" min="0" step="1">
        </div>
      </label>
      <label>
        <span>Порог для использования</span>
        <input type="number" name="system.functions.tools.{{key}}.skillValue" value="{{skillValue}}" min="0" step="1">
      </label>
      <label>
        <span>Навык</span>
        <select name="system.functions.tools.{{key}}.skillKey">
          {{#each skillChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}
  {{/each}}
</section>
{{else}}
<section class="fallout-maw-panel">
  <h2>{{localize "FALLOUTMAW.Item.Core"}}</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>{{localize "FALLOUTMAW.Item.MaxStack"}}</span>
      <input type="number" name="system.maxStack" value="{{system.maxStack}}" min="1" step="1">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Item.InventoryWidth"}}</span>
      <input type="number" name="system.placement.width" value="{{system.placement.width}}" min="1" step="1">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Item.InventoryHeight"}}</span>
      <input type="number" name="system.placement.height" value="{{system.placement.height}}" min="1" step="1">
    </label>

    {{#if isAbility}}
    <label>
      <span>{{localize "FALLOUTMAW.Item.Cost"}}</span>
      <input type="number" name="system.cost" value="{{system.cost}}" min="0">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Common.Formula"}}</span>
      <input type="text" name="system.formula" value="{{system.formula}}">
    </label>
    {{/if}}

  </div>
</section>

<section class="fallout-maw-panel fallout-maw-description-panel">
  <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
  {{#if editable}}
  <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
    {{{descriptionHTML}}}
  </prose-mirror>
  {{else}}
  <div class="editor editor-content">
    {{{descriptionHTML}}}
  </div>
  {{/if}}
</section>
{{/if}}
</div>
