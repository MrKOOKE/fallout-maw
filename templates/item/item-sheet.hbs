          </button>
          {{/each}}
        </div>
      </section>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Item.OccupiedWeaponSlots"}}</h2>
    <div class="fallout-maw-list-grid two-columns">
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponSlotMode"}}</span>
        <select name="system.weaponSlotRequirement.mode">
          {{#each weaponSlotRequirementModeChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
    </div>
    <div class="fallout-maw-hidden-controls">
      {{#each weaponSlotSelections}}
      <input type="checkbox" name="system.weaponSlotRequirement.slots.{{selectionKey}}" data-weapon-slot-input="{{selectionKey}}" {{checked selected}}>
      {{/each}}
    </div>
    <div class="fallout-maw-occupied-slot-groups">
      {{#each weaponSlotGroups}}
      <section class="fallout-maw-occupied-slot-group">
