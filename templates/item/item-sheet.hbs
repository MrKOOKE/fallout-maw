          <span>Ключ</span>
          <span>Тип</span>
          <span>Значение</span>
          <span>Приоритет</span>
          <span></span>
        </div>
        <div class="fallout-maw-trauma-effect-row">
          <input type="text" name="{{functionPath}}.{{functionIndex}}.changes.{{index}}.key" value="{{key}}" data-effect-key-autocomplete>
          <select name="{{functionPath}}.{{functionIndex}}.changes.{{index}}.type">
            {{#each typeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <input type="text" name="{{functionPath}}.{{functionIndex}}.changes.{{index}}.value" value="{{value}}" data-formula-autocomplete="all">
