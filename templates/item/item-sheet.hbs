              </label>
            </div>
            <div class="fallout-maw-list-grid three-columns">
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeAccuracyModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.accuracyModifier" value="{{swing.accuracyModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeCriticalChanceModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.criticalChanceModifier" value="{{swing.criticalChanceModifier}}" step="1">
              </label>
              <label>
                <span>{{localize "FALLOUTMAW.Item.WeaponModeDamagePercentModifier"}}</span>
                <input type="number" name="{{../path}}.{{key}}.swing.damagePercentModifier" value="{{swing.damagePercentModifier}}" step="1">
              </label>
            </div>
          </section>
        </div>
        {{/if}}
        {{/if}}
        {{#unless isReload}}
        <div class="fallout-maw-panel-header fallout-maw-weapon-action-subheader">
          <h4>{{localize "FALLOUTMAW.Item.WeaponCriticalFailureConsequences"}}</h4>
          <button type="button" data-add-weapon-critical-failure-consequence="{{key}}"><i class="fa-solid fa-plus"></i> {{localize "FALLOUTMAW.Item.WeaponAddCriticalFailureConsequence"}}</button>
        </div>
        <div class="fallout-maw-settings-table fallout-maw-weapon-critical-failure-consequences">
          <div class="fallout-maw-settings-row fallout-maw-grid-header">
            <span>{{localize "FALLOUTMAW.Common.Type"}}</span>
            <span>{{localize "FALLOUTMAW.Item.WeaponCriticalFailureResource"}}</span>
            <span>{{localize "FALLOUTMAW.Common.Value"}}</span>
            <span></span>
          </div>
          {{#each criticalFailureConsequences}}
          <div class="fallout-maw-settings-row">
            <select name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.type">
              {{#each typeChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <select name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.resourceType">
              {{#each resourceChoices}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="number" name="{{../../path}}.{{../key}}.criticalFailureConsequences.{{index}}.amount" value="{{amount}}" min="0" step="1">
            <button type="button" data-weapon-action-key="{{../key}}" data-delete-weapon-critical-failure-consequence="{{index}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Item.WeaponNoCriticalFailureConsequences"}}</p>
          {{/each}}
        </div>
        {{/unless}}
      </section>
      {{/if}}
      {{/each}}
    </div>
    {{!-- Legacy fallback field is intentionally hidden while older items migrate by normal form saves. --}}
    <input type="hidden" name="{{path}}.attackConeDegrees" value="{{weaponData.attackConeDegrees}}">

    <div class="fallout-maw-panel-header">
      <h3>{{localize "FALLOUTMAW.Item.WeaponAttackPresentation"}}</h3>
    </div>
    <div class="fallout-maw-list-grid {{#if hasVolleyAction}}three-columns{{else}}two-columns{{/if}}">
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackAnimation"}}</span>
        <input type="text" name="{{path}}.attackAnimationKey" value="{{effectiveWeaponData.attackAnimationKey}}" {{#if usesDamageSource}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackSound"}}</span>
        <div class="fallout-maw-image-picker-field">
          <input type="text" name="{{path}}.attackSoundPath" value="{{weaponData.attackSoundPath}}" data-weapon-attack-sound-input>
          <button type="button" data-browse-weapon-attack-sound title="{{localize 'FILES.Browse'}}"><i class="fa-solid fa-music"></i></button>
        </div>
      </label>
      {{#if hasVolleyAction}}
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponExplosionAnimation"}}</span>
        <input type="text" name="{{path}}.volley.explosionAnimationKey" value="{{effectiveWeaponData.volley.explosionAnimationKey}}" {{#if usesDamageSource}}disabled{{/if}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponExplosionSound"}}</span>
        <div class="fallout-maw-image-picker-field">
          <input type="text" name="{{path}}.volley.explosionSoundPath" value="{{weaponData.volley.explosionSoundPath}}" data-weapon-explosion-sound-input>
          <button type="button" data-browse-weapon-explosion-sound title="{{localize 'FILES.Browse'}}"><i class="fa-solid fa-music"></i></button>
        </div>
      </label>
      {{/if}}
      <label>
        <span>{{localize "FALLOUTMAW.Item.WeaponAttackDelay"}}</span>
        <input type="number" name="{{path}}.attackAnimationDelayMs" value="{{weaponData.attackAnimationDelayMs}}" min="0" step="1">
      </label>
    </div>
  </section>
  {{/if}}
  {{/each}}

  {{#if hasToolFunction}}
  {{#each toolFunctions}}
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Item.FunctionTool"}}</h2>
      <select data-tool-function-key="{{key}}">
        {{#each toolChoices}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
      <button type="button" data-remove-item-function="{{functionKey}}" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="fallout-maw-list-grid three-columns">
      <label>
        <span>Класс инструмента</span>
        <select name="system.functions.tools.{{key}}.toolClass">
          {{#each classChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="fallout-maw-split-number-field">
        <span>Запас</span>
        <div>
          <input type="number" name="system.functions.tools.{{key}}.supply.value" value="{{supplyValue}}" min="0" step="1">
          <strong>/</strong>
          <input type="number" name="system.functions.tools.{{key}}.supply.max" value="{{supplyMax}}" min="0" step="1">
        </div>
      </label>
      <label>
        <span>Порог для использования</span>
        <input type="number" name="system.functions.tools.{{key}}.skillValue" value="{{skillValue}}" min="0" step="1">
      </label>
      <label>
        <span>Навык</span>
        <select name="system.functions.tools.{{key}}.skillKey">
          {{#each skillChoices}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/each}}
  {{/if}}
</section>

<section class="tab {{tabs.craft.cssClass}}" data-group="{{tabs.craft.group}}" data-tab="{{tabs.craft.id}}">
  <div class="fallout-maw-craft-recipebar">
    <label>
      <span>Рецепт</span>
      <select data-craft-recipe-select>
        {{#each craft.recipes}}
        <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </label>
    <button type="button" data-craft-add-recipe>
      <i class="fa-solid fa-plus"></i> Добавить рецепт
    </button>
    <button type="button" data-craft-delete-recipe {{#unless craft.canDeleteActiveRecipe}}disabled{{/unless}}>
      <i class="fa-solid fa-trash"></i> Удалить рецепт
    </button>
  </div>
  <div class="fallout-maw-craft-modebar">
    <div class="fallout-maw-craft-modebar-tabs" role="tablist">
      {{#each craft.modes}}
      <button type="button" class="{{#if selected}}active{{/if}}" data-craft-mode="{{key}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">{{label}}</button>
      {{/each}}
    </div>
    {{#if craft.canCalculateCost}}
    <button type="button" class="fallout-maw-craft-cost-button" data-craft-calculate-cost>
      <i class="fa-solid fa-calculator"></i> Рассчитать стоимость
    </button>
    {{/if}}
    {{#if craft.canReverseCreation}}
    <button type="button" class="fallout-maw-craft-reverse-button" data-craft-reverse-creation>
      <i class="fa-solid fa-rotate"></i> Реверсировать Создание
    </button>
    {{/if}}
  </div>
  <div class="fallout-maw-craft-editor fallout-maw-craft-mode-{{craft.mode}}" data-craft-workspace style="{{craft.viewportStyle}}">
    <div class="fallout-maw-craft-world" data-craft-world style="{{craft.viewportStyle}}">
      <svg class="fallout-maw-craft-links" data-craft-links aria-hidden="true"></svg>
      <div class="fallout-maw-craft-snap-preview" data-craft-snap-preview hidden></div>
      {{#each craft.blocks}}
      <button type="button" class="fallout-maw-craft-block {{#if selected}}selected{{/if}}" data-craft-block-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-label="{{label}}"></button>
      {{/each}}
      {{#each craft.nodes}}
      <button type="button" class="fallout-maw-craft-node {{#if root}}root{{/if}} {{#if selected}}selected{{/if}} {{#if attaching}}attaching{{/if}} {{#if blockId}}in-block{{/if}}" data-craft-node-id="{{id}}" data-craft-block-id="{{blockId}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}">
        <span class="fallout-maw-craft-node-image">
          <img src="{{img}}" alt="{{name}}">
          {{#if hasQuantityBadge}}
          <span class="fallout-maw-craft-node-quantity">{{quantity}}</span>
          {{/if}}
        </span>
      </button>
      {{/each}}
      {{#each craft.blocks}}
      <div class="fallout-maw-craft-block-frame {{#if selected}}selected{{/if}}" data-craft-block-frame-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-hidden="true"></div>
      {{/each}}
    </div>

    {{#if craft.hasPopover}}
    <div class="fallout-maw-craft-popover" data-craft-popover>
      {{#if craft.selectedNode}}
      <section class="fallout-maw-craft-popover-section">
        <h3>{{craft.selectedNode.name}}</h3>
        <label>
          <span>{{#if craft.selectedNode.isToolRequirement}}Расход инструмента{{else}}Количество{{/if}}</span>
          <input type="number" value="{{craft.selectedNode.quantity}}" min="1" step="1" data-craft-node-quantity="{{craft.selectedNode.id}}">
        </label>
        {{#if craft.selectedNode.hasToolFunction}}
        <label class="fallout-maw-inline-checkbox">
          <span>Использовать как предмет</span>
          <input type="checkbox" data-craft-node-tool-use-as-item="{{craft.selectedNode.id}}" {{checked craft.selectedNode.toolUseAsItem}}>
        </label>
        {{/if}}
        {{#if craft.selectedNode.isToolRequirement}}
        <p>{{craft.selectedNode.toolRequirementLabel}}</p>
        {{/if}}
        <button type="button" data-craft-attach-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-link"></i> Прикрепить
        </button>
        {{#if craft.attachSourceNode}}
        <p>Выберите предмет для связи.</p>
        <button type="button" data-craft-cancel-attach>
          <i class="fa-solid fa-xmark"></i> Отменить
        </button>
        {{/if}}
        {{#if craft.selectedNode.blockId}}
        <button type="button" data-craft-extract-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-up-right-from-square"></i> Извлечь
        </button>
        {{/if}}
        {{#unless craft.selectedNode.root}}
        <button type="button" data-craft-delete-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-trash"></i> Удалить
        </button>
        {{/unless}}
      </section>
      {{else if craft.selectedBlock}}
      <section class="fallout-maw-craft-popover-section">
        <h3>Блок</h3>
        <p>{{#if craft.selectedBlock.isToolBlock}}Инструменты: {{craft.selectedBlock.nodeCount}}{{else}}Предметы: {{craft.selectedBlock.nodeCount}}{{/if}}</p>
        <label>
          <span>{{#if craft.selectedBlock.isToolBlock}}Необходимо инструментов{{else if (eq craft.mode "disassembly")}}Может быть получено предметов{{else}}Требуется предметов{{/if}}</span>
          <input type="number" value="{{craft.selectedBlock.blockLimit}}" min="1" step="1" placeholder="Все" data-craft-block-limit="{{craft.selectedBlock.id}}">
        </label>
      </section>
      {{else if craft.selectedLink}}
      <section class="fallout-maw-craft-popover-section">
        <h3>Связь</h3>
        <p>{{craft.selectedLink.title}}</p>
        {{#if craft.selectedLink.canSetFailureResult}}
        <label class="fallout-maw-inline-checkbox">
          <span>Результат при провале</span>
          <input type="checkbox" data-craft-link-failure-result="{{craft.selectedLink.id}}" {{checked craft.selectedLink.failureResult}}>
        </label>
        {{/if}}
        {{#unless craft.selectedLink.failureResult}}
        <label>
          <span>Навык</span>
          <select data-craft-link-skill="{{craft.selectedLink.id}}">
            {{#each craft.selectedLink.skillChoices}}
            <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          <span>Сложность</span>
          <input type="number" value="{{craft.selectedLink.difficulty}}" min="0" step="1" data-craft-link-difficulty="{{craft.selectedLink.id}}">
        </label>
        <label class="fallout-maw-inline-checkbox">
          <span>Без проверок</span>
          <input type="checkbox" data-craft-link-no-check="{{craft.selectedLink.id}}" {{checked craft.selectedLink.noCheck}}>
        </label>
        {{/unless}}
        <button type="button" data-craft-delete-link="{{craft.selectedLink.id}}">
          <i class="fa-solid fa-trash"></i> Удалить
        </button>
      </section>
      {{else if craft.attachSourceNode}}
      <section class="fallout-maw-craft-popover-section">
        <h3>Прикрепление</h3>
        <p>{{craft.attachSourceNode.name}}</p>
        <button type="button" data-craft-cancel-attach>
          <i class="fa-solid fa-xmark"></i> Отменить
        </button>
      </section>
      {{/if}}
    </div>
    {{/if}}
  </div>
</section>
{{else}}
<section class="fallout-maw-panel">
  <h2>{{localize "FALLOUTMAW.Item.Core"}}</h2>
  <div class="fallout-maw-list-grid two-columns">
    <label>
      <span>{{localize "FALLOUTMAW.Item.MaxStack"}}</span>
      <input type="number" name="system.maxStack" value="{{system.maxStack}}" min="1" step="1">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Item.InventoryWidth"}}</span>
      <input type="number" name="system.placement.width" value="{{system.placement.width}}" min="1" step="1">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Item.InventoryHeight"}}</span>
      <input type="number" name="system.placement.height" value="{{system.placement.height}}" min="1" step="1">
    </label>

    {{#if isAbility}}
    <label>
      <span>{{localize "FALLOUTMAW.Item.Cost"}}</span>
      <input type="number" name="system.cost" value="{{system.cost}}" min="0">
    </label>
    <label>
      <span>{{localize "FALLOUTMAW.Common.Formula"}}</span>
      <input type="text" name="system.formula" value="{{system.formula}}">
    </label>
    {{/if}}

  </div>
</section>

<section class="fallout-maw-panel fallout-maw-description-panel">
  <h2>{{localize "FALLOUTMAW.Common.Description"}}</h2>
  {{#if editable}}
  <prose-mirror name="system.description" value="{{sourceSystem.description}}" document-uuid="{{item.uuid}}" class="sized" compact>
    {{{descriptionHTML}}}
  </prose-mirror>
  {{else}}
  <div class="editor editor-content">
    {{{descriptionHTML}}}
  </div>
  {{/if}}
</section>
{{/if}}
</div>
