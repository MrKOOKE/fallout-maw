          <div class="fallout-maw-ability-action-cost-detail" data-ability-action-actual-cost {{#unless usesActualActionPointCost}}hidden{{/unless}}>
            <label><span>{{localize "FALLOUTMAW.Ability.Actions.ActualPercent"}}</span><input type="number" min="0" step="1" name="{{functionPath}}.{{functionIndex}}.actions.{{index}}.actualActionPointCostPercent" value="{{actualActionPointCostPercent}}"></label>
            <p class="hint">{{localize "FALLOUTMAW.Ability.Actions.CostHint"}}</p>
          </div>
        </div>
        {{/if}}
        {{/if}}
      </div>
      {{/each}}
    </fieldset>
    {{/if}}

    {{#if hasConditions}}
