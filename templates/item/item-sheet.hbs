                    {{else}}
                    <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Ability.TriggerCost.NoCosts"}}</p>
                    {{/each}}
                  </div>
                </div>
              </div>
              {{/if}}

              {{#if isEventReaction}}
              <label class="fallout-maw-checkbox-row fallout-maw-event-reaction-combat-only">
                <span>{{localize "FALLOUTMAW.Events.Reaction.CombatOnly"}}</span>
                <input type="checkbox" name="{{functionPath}}.{{functionIndex}}.conditions.{{index}}.combatOnly" data-ability-event-reaction-combat-only {{checked combatOnly}}>
              </label>
              <label class="fallout-maw-event-reaction-mode">
                <span>{{localize "FALLOUTMAW.Events.Reaction.ReactionMode"}}</span>
