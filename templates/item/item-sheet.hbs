<section class="tab {{tabs.craft.cssClass}}" data-group="{{tabs.craft.group}}" data-tab="{{tabs.craft.id}}">
  <div class="fallout-maw-craft-modebar">
    <div class="fallout-maw-craft-modebar-tabs" role="tablist">
      {{#each craft.modes}}
      <button type="button" class="{{#if selected}}active{{/if}}" data-craft-mode="{{key}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">{{label}}</button>
      {{/each}}
    </div>
    {{#if craft.canReverseCreation}}
    <button type="button" class="fallout-maw-craft-reverse-button" data-craft-reverse-creation>
      <i class="fa-solid fa-rotate"></i> Реверсировать Создание
    </button>
    {{/if}}
  </div>
  <div class="fallout-maw-craft-editor fallout-maw-craft-mode-{{craft.mode}}" data-craft-workspace style="{{craft.viewportStyle}}">
    <div class="fallout-maw-craft-world" data-craft-world style="{{craft.viewportStyle}}">
      <svg class="fallout-maw-craft-links" data-craft-links aria-hidden="true"></svg>
      <div class="fallout-maw-craft-snap-preview" data-craft-snap-preview hidden></div>
      {{#each craft.blocks}}
      <button type="button" class="fallout-maw-craft-block {{#if selected}}selected{{/if}}" data-craft-block-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-label="{{label}}"></button>
      {{/each}}
      {{#each craft.nodes}}
      <button type="button" class="fallout-maw-craft-node {{#if root}}root{{/if}} {{#if selected}}selected{{/if}} {{#if attaching}}attaching{{/if}} {{#if blockId}}in-block{{/if}}" data-craft-node-id="{{id}}" data-craft-block-id="{{blockId}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}">
        <span class="fallout-maw-craft-node-image">
          <img src="{{img}}" alt="{{name}}">
          {{#if hasQuantityBadge}}
          <span class="fallout-maw-craft-node-quantity">{{quantity}}</span>
          {{/if}}
        </span>
      </button>
      {{/each}}
      {{#each craft.blocks}}
      <div class="fallout-maw-craft-block-frame {{#if selected}}selected{{/if}}" data-craft-block-frame-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-hidden="true"></div>
      {{/each}}
    </div>

    {{#if craft.hasPopover}}
    <div class="fallout-maw-craft-popover" data-craft-popover>
      {{#if craft.selectedNode}}
      <section class="fallout-maw-craft-popover-section">
        <h3>{{craft.selectedNode.name}}</h3>
        <label>
          <span>{{#if craft.selectedNode.isToolRequirement}}Расход инструмента{{else}}Количество{{/if}}</span>
          <input type="number" value="{{craft.selectedNode.quantity}}" min="1" step="1" data-craft-node-quantity="{{craft.selectedNode.id}}">
        </label>
        {{#if craft.selectedNode.isToolRequirement}}
        <p>{{craft.selectedNode.toolRequirementLabel}}</p>
        {{/if}}
        <button type="button" data-craft-attach-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-link"></i> Прикрепить
        </button>
        {{#if craft.attachSourceNode}}
        <p>Выберите предмет для связи.</p>
        <button type="button" data-craft-cancel-attach>
          <i class="fa-solid fa-xmark"></i> Отменить
        </button>
        {{/if}}
        {{#if craft.selectedNode.blockId}}
        <button type="button" data-craft-extract-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-up-right-from-square"></i> Извлечь
        </button>
        {{/if}}
        {{#unless craft.selectedNode.root}}
        <button type="button" data-craft-delete-node="{{craft.selectedNode.id}}">
          <i class="fa-solid fa-trash"></i> Удалить
        </button>
        {{/unless}}
      </section>
      {{else if craft.selectedLink}}
      <section class="fallout-maw-craft-popover-section">
        <h3>Связь</h3>
        <p>{{craft.selectedLink.title}}</p>
        <label>
          <span>Навык</span>
          <select data-craft-link-skill="{{craft.selectedLink.id}}">
            {{#each craft.selectedLink.skillChoices}}
            <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          <span>Сложность</span>
          <input type="number" value="{{craft.selectedLink.difficulty}}" min="0" step="1" data-craft-link-difficulty="{{craft.selectedLink.id}}">
        </label>
        <label class="fallout-maw-inline-checkbox">
          <span>Без проверок</span>
          <input type="checkbox" data-craft-link-no-check="{{craft.selectedLink.id}}" {{checked craft.selectedLink.noCheck}}>
        </label>
        <button type="button" data-craft-delete-link="{{craft.selectedLink.id}}">
          <i class="fa-solid fa-trash"></i> Удалить
        </button>
      </section>
      {{else if craft.attachSourceNode}}
      <section class="fallout-maw-craft-popover-section">
        <h3>Прикрепление</h3>
        <p>{{craft.attachSourceNode.name}}</p>
        <button type="button" data-craft-cancel-attach>
          <i class="fa-solid fa-xmark"></i> Отменить
        </button>
      </section>
      {{/if}}
    </div>
    {{/if}}
  </div>
</section>
{{else}}
<section class="fallout-maw-panel">
