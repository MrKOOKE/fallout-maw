<div class="fallout-maw-sheet fallout-maw-search-sheet fallout-maw-craft-window-sheet" data-craft-window-root data-search-root>
  <nav class="fallout-maw-craft-window-tabs" aria-label="Вкладки крафта">
    <div class="fallout-maw-craft-window-tab-list" role="tablist">
      {{#each craftTabs}}
      <button type="button" class="fallout-maw-craft-window-tab {{#if active}}active{{/if}}" data-craft-tab-id="{{id}}" role="tab" aria-selected="{{#if active}}true{{else}}false{{/if}}">
        <i class="fa-solid {{icon}}"></i>
        <span data-craft-tab-name title="{{name}}">{{name}}</span>
        <span class="fallout-maw-craft-window-tab-close {{#unless canClose}}disabled{{/unless}}" data-craft-tab-close="{{id}}" title="Закрыть вкладку" aria-hidden="true">&times;</span>
      </button>
      {{/each}}
      <button type="button" class="fallout-maw-craft-window-tab-add" data-craft-tab-add title="Новая вкладка" aria-label="Новая вкладка">
        <i class="fa-solid fa-plus"></i>
      </button>
    </div>
  </nav>
  <div class="fallout-maw-sheet-body fallout-maw-craft-window-body">
    <section class="fallout-maw-craft-window-inventory fallout-maw-search-side fallout-maw-search-side--searcher" data-search-actor-uuid="{{actor.uuid}}" data-search-side="searcher">
      <section class="fallout-maw-panel fallout-maw-load-panel">
        <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Common.Load'}}">
          <div class="fallout-maw-load-meter-track">
            <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
          </div>
          <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
        </div>
      </section>

      <div class="fallout-maw-craft-window-inventory-stack fallout-maw-search-inventory-stack fallout-maw-pane-scroll" data-search-scroll-key="craft:inventory-stack" data-search-drop-zone data-search-actor-uuid="{{actor.uuid}}" data-inventory-parent-id="">
        <section class="fallout-maw-panel fallout-maw-equipment-pane">
          <h2>{{localize "FALLOUTMAW.Common.Equipment"}}</h2>
          <div class="fallout-maw-pane-scroll fallout-maw-equipment-scroll">
            <div class="fallout-maw-equipment-slot-list">
              {{#each inventory.equipmentSlots}}
              <div class="fallout-maw-slot-card">
                <div class="fallout-maw-slot-card-label">{{label}}</div>
                <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large {{#if (eq item.occupiedSlotMode "oneOf")}}one-of{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actor.uuid}}" data-equipment-slot="{{key}}">
                  {{#if item}}
                  <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                    {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                  </article>
                  {{/if}}
                </div>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
              {{/each}}
            </div>

            {{#if inventory.prosthesisSlots.length}}
            <h2>Протезы</h2>
            <div class="fallout-maw-equipment-slot-list fallout-maw-prosthesis-slot-list">
              {{#each inventory.prosthesisSlots}}
              <div class="fallout-maw-slot-card">
                <div class="fallout-maw-slot-card-label">{{label}}</div>
                <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-prosthesis-slot" data-prosthesis-limb="{{key}}">
                  {{#if item}}
                  <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item equipped {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                    {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                  </article>
                  {{/if}}
                </div>
              </div>
              {{/each}}
            </div>
            {{/if}}

            <h2>{{localize "FALLOUTMAW.Common.Weapon"}}</h2>
            <div class="fallout-maw-weapon-set-list">
              {{#each inventory.weaponSets}}
              <section class="fallout-maw-weapon-set">
                <h3>{{label}}</h3>
                <div class="fallout-maw-weapon-slot-list">
                  {{#each slots}}
                  <div class="fallout-maw-slot-card">
                    <div class="fallout-maw-slot-card-label">{{label}}</div>
                    <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-weapon-set="{{weaponSetKey}}" data-weapon-slot="{{key}}">
                      {{#if item}}
                      <article class="{{#unless phantom}}{{item.draggableClass}}{{/unless}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if item.locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                        <img src="{{item.img}}" alt="{{item.name}}">
                        {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                      </article>
                      {{/if}}
                    </div>
                  </div>
                  {{/each}}
                </div>
              </section>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
              {{/each}}
            </div>
          </div>
        </section>

        <section class="fallout-maw-panel fallout-maw-inventory-pane">
          <h2>{{localize "FALLOUTMAW.Common.Inventory"}}</h2>
          <div class="fallout-maw-pane-scroll fallout-maw-inventory-scroll">
            <div class="fallout-maw-inventory-grid {{#if inventory.grid.hasPhantomItems}}has-phantom-items{{/if}} {{#if inventory.grid.hasZones}}has-zones{{/if}}" data-search-drop-zone data-search-actor-uuid="{{actor.uuid}}" data-inventory-grid data-inventory-parent-id="" style="{{inventory.grid.style}}">
              {{#each inventory.grid.zones}}
              <div class="fallout-maw-inventory-grid-zone {{#if base}}base{{/if}}" style="{{style}}"></div>
              {{/each}}
              {{#each inventory.grid.items}}
              <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if placement.rotated}}rotated{{/if}} {{#if equipped}}equipped{{/if}} {{#if locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-stack-index="{{stackIndex}}" data-stack-quantity="{{stackQuantity}}" data-inventory-parent-id="" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                <img src="{{img}}" alt="{{name}}">
                {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
              </article>
              {{/each}}
            </div>

            {{#each inventory.containers}}
            <section class="fallout-maw-container-section" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-container-id="{{id}}" data-inventory-parent-id="{{id}}">
              <div class="fallout-maw-panel-header fallout-maw-container-header">
                <div class="fallout-maw-container-overview {{draggableClass}} fallout-maw-draggable-item{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}">
                  <strong class="fallout-maw-container-overview-name">{{name}}</strong>
                  <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Item.ContainerCurrentLoad'}}">
                    <div class="fallout-maw-load-meter-track">
                      <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
                    </div>
                    <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
                  </div>
                </div>
              </div>
              <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}} {{#if grid.hasZones}}has-zones{{/if}}" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="{{grid.style}}">
                {{#each grid.zones}}
                <div class="fallout-maw-inventory-grid-zone {{#if base}}base{{/if}}" style="{{style}}"></div>
                {{/each}}
                {{#each grid.items}}
                <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if placement.rotated}}rotated{{/if}} {{#if equipped}}equipped{{/if}} {{#if locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-stack-index="{{stackIndex}}" data-stack-quantity="{{stackQuantity}}" data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                  <img src="{{img}}" alt="{{name}}">
                  {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                </article>
                {{/each}}
              </div>
            </section>
            {{/each}}
            {{#with inventory.lockedStorage}}
            {{#if grid.items.length}}
            <section class="fallout-maw-container-section fallout-maw-locked-storage-section">
              <div class="fallout-maw-panel-header fallout-maw-container-header">
                <div class="fallout-maw-container-overview">
                  <strong class="fallout-maw-container-overview-name">{{localize "FALLOUTMAW.Common.Locked"}}</strong>
                </div>
              </div>
              <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}} {{#if grid.hasZones}}has-zones{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actor.uuid}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="{{grid.style}}">
                {{#each grid.zones}}
                <div class="fallout-maw-inventory-grid-zone {{#if base}}base{{/if}}" style="{{style}}"></div>
                {{/each}}
                {{#each grid.items}}
                <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item locked {{#if placement.rotated}}rotated{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-stack-index="{{stackIndex}}" data-stack-quantity="{{stackQuantity}}" data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                  <img src="{{img}}" alt="{{name}}">
                  {{#if showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</span>{{/if}}
                  {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                </article>
                {{/each}}
              </div>
            </section>
            {{/if}}
            {{/with}}
          </div>
        </section>
      </div>
    </section>

    {{> "systems/fallout-maw/templates/actor/parts/craft-window-panel.hbs"}}

    <aside class="fallout-maw-craft-window-recipes">
      <div class="fallout-maw-craft-window-recipe-modes" role="tablist">
        {{#each craftModes}}
        <button type="button" class="{{#if selected}}active{{/if}}" data-craft-mode="{{key}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">{{label}}</button>
        {{/each}}
      </div>
      <label class="fallout-maw-craft-window-recipe-search">
        <input type="search" value="{{recipeSearch}}" placeholder="Поиск" data-craft-recipe-search>
      </label>
      <div class="fallout-maw-craft-window-recipe-list fallout-maw-pane-scroll" data-search-scroll-key="craft:recipes">
        {{#each recipeCategories}}
        <section class="fallout-maw-craft-window-recipe-category {{#if collapsed}}collapsed{{/if}}" data-craft-recipe-category="{{label}}">
          <div class="fallout-maw-craft-window-recipe-category-header" role="button" tabindex="0" data-craft-recipe-category-toggle="{{key}}" aria-expanded="{{#if collapsed}}false{{else}}true{{/if}}">
            <i class="fa-solid {{#if collapsed}}fa-caret-right{{else}}fa-caret-down{{/if}}"></i>
            <span>{{label}}</span>
            <strong>{{count}}</strong>
          </div>
          <div class="fallout-maw-craft-window-recipe-category-list">
            {{#each recipes}}
            <article class="fallout-maw-craft-window-recipe {{#if selected}}selected{{/if}} {{#if missing}}missing{{/if}}" role="button" tabindex="0" data-recipe-uuid="{{uuid}}" data-tooltip-uuid="{{itemUuid}}" data-recipe-search-text="{{displayName}} {{recipeName}} {{../label}}">
              <img src="{{img}}" alt="{{displayName}}">
              <span class="name">{{displayName}}</span>
            </article>
            {{/each}}
          </div>
        </section>
        {{else}}
        <p class="fallout-maw-empty-list">Рецептов нет.</p>
        {{/each}}
      </div>
    </aside>
  </div>
</div>
