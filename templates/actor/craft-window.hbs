<div class="fallout-maw-sheet fallout-maw-search-sheet fallout-maw-craft-window-sheet" data-craft-window-root data-search-root>
  <div class="fallout-maw-sheet-body fallout-maw-craft-window-body">
    <section class="fallout-maw-craft-window-inventory fallout-maw-search-side fallout-maw-search-side--searcher" data-search-actor-uuid="{{actor.uuid}}" data-search-side="searcher">
      <section class="fallout-maw-panel fallout-maw-load-panel">
        <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Common.Load'}}">
          <div class="fallout-maw-load-meter-track">
            <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
          </div>
          <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
        </div>
      </section>

      <div class="fallout-maw-craft-window-inventory-stack fallout-maw-search-inventory-stack fallout-maw-pane-scroll" data-search-scroll-key="craft:inventory-stack" data-search-drop-zone data-search-actor-uuid="{{actor.uuid}}" data-inventory-parent-id="">
        <section class="fallout-maw-panel fallout-maw-equipment-pane">
          <h2>{{localize "FALLOUTMAW.Common.Equipment"}}</h2>
          <div class="fallout-maw-pane-scroll fallout-maw-equipment-scroll">
            <div class="fallout-maw-equipment-slot-list">
              {{#each inventory.equipmentSlots}}
              <div class="fallout-maw-slot-card">
                <div class="fallout-maw-slot-card-label">{{label}}</div>
                <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large" data-search-drop-zone data-search-actor-uuid="{{../actor.uuid}}" data-equipment-slot="{{key}}">
                  {{#if item}}
                  <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                    {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                  </article>
                  {{/if}}
                </div>
              </div>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
              {{/each}}
            </div>

            <h2>{{localize "FALLOUTMAW.Common.Weapon"}}</h2>
            <div class="fallout-maw-weapon-set-list">
              {{#each inventory.weaponSets}}
              <section class="fallout-maw-weapon-set">
                <h3>{{label}}</h3>
                <div class="fallout-maw-weapon-slot-list">
                  {{#each slots}}
                  <div class="fallout-maw-slot-card">
                    <div class="fallout-maw-slot-card-label">{{label}}</div>
                    <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-weapon-set="{{weaponSetKey}}" data-weapon-slot="{{key}}">
                      {{#if item}}
                      <article class="{{#unless phantom}}{{item.draggableClass}}{{/unless}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                        <img src="{{item.img}}" alt="{{item.name}}">
                        {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                      </article>
                      {{/if}}
                    </div>
                  </div>
                  {{/each}}
                </div>
              </section>
              {{else}}
              <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
              {{/each}}
            </div>
          </div>
        </section>

        <section class="fallout-maw-panel fallout-maw-inventory-pane">
          <h2>{{localize "FALLOUTMAW.Common.Inventory"}}</h2>
          <div class="fallout-maw-pane-scroll fallout-maw-inventory-scroll">
            <div class="fallout-maw-inventory-grid {{#if inventory.grid.hasPhantomItems}}has-phantom-items{{/if}}" data-search-drop-zone data-search-actor-uuid="{{actor.uuid}}" data-inventory-grid data-inventory-parent-id="" style="--fallout-maw-inventory-columns: {{inventory.grid.columns}};">
              {{#each inventory.grid.cells}}
              <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}} {{#if phantom}}phantom{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actor.uuid}}" data-inventory-cell data-inventory-parent-id="" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
              {{/each}}
              {{#each inventory.grid.items}}
              <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                <img src="{{img}}" alt="{{name}}">
                {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
              </article>
              {{/each}}
            </div>

            {{#each inventory.containers}}
            <section class="fallout-maw-container-section" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-container-id="{{id}}" data-inventory-parent-id="{{id}}">
              <div class="fallout-maw-panel-header fallout-maw-container-header">
                <div class="fallout-maw-container-overview {{draggableClass}} fallout-maw-draggable-item" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}">
                  <strong class="fallout-maw-container-overview-name">{{name}}</strong>
                  <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Item.ContainerCurrentLoad'}}">
                    <div class="fallout-maw-load-meter-track">
                      <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
                    </div>
                    <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
                  </div>
                </div>
              </div>
              <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}}" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="--fallout-maw-inventory-columns: {{grid.columns}};">
                {{#each grid.cells}}
                <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}} {{#if phantom}}phantom{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actorUuid}}" data-inventory-cell data-inventory-parent-id="{{../id}}" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
                {{/each}}
                {{#each grid.items}}
                <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                  <img src="{{img}}" alt="{{name}}">
                  {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                </article>
                {{/each}}
              </div>
            </section>
            {{/each}}
          </div>
        </section>
      </div>
    </section>

    <section class="fallout-maw-craft-window-craft">
      <header class="fallout-maw-craft-window-toolbar">
        <div class="fallout-maw-craft-window-title">
          {{#if recipe}}
          <img src="{{recipe.img}}" alt="{{recipe.name}}" data-tooltip-uuid="{{recipe.uuid}}">
          <div class="fallout-maw-craft-window-title-body">
            <div class="fallout-maw-craft-window-title-main">
              <strong data-tooltip-uuid="{{recipe.uuid}}">{{recipe.name}}</strong>
              <span>{{craft.summary}}</span>
            </div>
            {{#if craft.checks.length}}
            <div class="fallout-maw-craft-window-checks">
              {{#each craft.checks}}
              <span>{{label}}</span>
              {{/each}}
            </div>
            {{/if}}
          </div>
          {{else}}
          <div>
            <strong>Нет рецепта</strong>
            <span>Создайте рецепт на предмете.</span>
          </div>
          {{/if}}
        </div>
        <div class="fallout-maw-craft-window-actions">
          <div class="fallout-maw-craft-modebar-tabs" role="tablist">
            {{#each craftModes}}
            <button type="button" class="{{#if selected}}active{{/if}}" data-craft-mode="{{key}}" aria-pressed="{{#if selected}}true{{else}}false{{/if}}">{{label}}</button>
            {{/each}}
          </div>
          <button type="button" class="fallout-maw-craft-window-hammer" data-action="craft" title="{{craft.actionTitle}}" {{#unless craft.canCraft}}disabled{{/unless}}>
            <i class="fa-solid {{craft.actionIcon}}"></i>
          </button>
        </div>
      </header>

      {{#if recipe}}
      <div class="fallout-maw-craft-editor fallout-maw-craft-viewer fallout-maw-craft-mode-{{craft.mode}}" data-craft-workspace style="{{craft.viewportStyle}}">
        <div class="fallout-maw-craft-world" data-craft-world style="{{craft.viewportStyle}}">
          <svg class="fallout-maw-craft-links" data-craft-links aria-hidden="true"></svg>
          {{#each craft.blocks}}
          <div class="fallout-maw-craft-block readonly" data-craft-block-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-label="{{label}}"></div>
          {{/each}}
          {{#each craft.nodes}}
          <div class="fallout-maw-craft-node readonly {{#if root}}root{{/if}} {{#if missing}}missing{{/if}} {{pulseClass}}" data-craft-node-id="{{id}}" data-craft-block-id="{{blockId}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" data-tooltip-uuid="{{tooltipUuid}}" style="{{style}}">
            <span class="fallout-maw-craft-node-image">
              <img src="{{img}}" alt="{{name}}">
              <span class="fallout-maw-craft-node-quantity">{{quantityLabel}}</span>
            </span>
          </div>
          {{/each}}
          {{#each craft.blocks}}
          <div class="fallout-maw-craft-block-frame readonly" data-craft-block-frame-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-hidden="true"></div>
          {{/each}}
        </div>
      </div>
      {{else}}
      <div class="fallout-maw-craft-window-empty">Нет доступных рецептов</div>
      {{/if}}
    </section>

    <aside class="fallout-maw-craft-window-recipes">
      <h2>Рецепты</h2>
      <label class="fallout-maw-craft-window-recipe-search">
        <input type="search" value="{{recipeSearch}}" placeholder="Поиск" data-craft-recipe-search>
      </label>
      <div class="fallout-maw-craft-window-recipe-list fallout-maw-pane-scroll" data-search-scroll-key="craft:recipes">
        {{#each recipeCategories}}
        <section class="fallout-maw-craft-window-recipe-category {{#if collapsed}}collapsed{{/if}}" data-craft-recipe-category="{{label}}">
          <div class="fallout-maw-craft-window-recipe-category-header" role="button" tabindex="0" data-craft-recipe-category-toggle="{{key}}" aria-expanded="{{#if collapsed}}false{{else}}true{{/if}}">
            <i class="fa-solid {{#if collapsed}}fa-caret-right{{else}}fa-caret-down{{/if}}"></i>
            <span>{{label}}</span>
            <strong>{{count}}</strong>
          </div>
          <div class="fallout-maw-craft-window-recipe-category-list">
            {{#each recipes}}
            <article class="fallout-maw-craft-window-recipe {{#if selected}}selected{{/if}} {{#if missing}}missing{{/if}}" role="button" tabindex="0" data-recipe-uuid="{{uuid}}" data-tooltip-uuid="{{uuid}}" data-recipe-search-text="{{displayName}} {{../label}}">
              <img src="{{img}}" alt="{{displayName}}">
              <span class="name">{{displayName}}</span>
            </article>
            {{/each}}
          </div>
        </section>
        {{else}}
        <p class="fallout-maw-empty-list">Рецептов нет.</p>
        {{/each}}
      </div>
    </aside>
  </div>
</div>
