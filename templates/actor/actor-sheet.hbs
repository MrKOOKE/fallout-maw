<form class="fallout-maw actor-sheet {{actor.type}} {{#if freeEdit}}free-edit{{else}}locked{{/if}}" autocomplete="off">
  <header class="sheet-header">
    <button type="button" class="fallout-maw-edit-toggle" data-action="toggle-free-edit" title="{{localize 'FALLOUTMAW.Actor.FreeEdit'}}">
      <i class="fa-solid {{#if freeEdit}}fa-lock-open{{else}}fa-lock{{/if}}"></i>
    </button>
    <img class="profile-img" src="{{actor.img}}" {{#if freeEdit}}data-edit="img"{{/if}} title="{{actor.name}}" height="100" width="100">
    <h1>
      <input name="name" type="text" value="{{actor.name}}" placeholder="Name" {{editLockAttribute}}>
    </h1>
  </header>

  <section class="fallout-maw-sheet-section">
    <h2>{{localize "FALLOUTMAW.Actor.Character"}}</h2>
    <div class="fallout-maw-form-grid">
      <label>
        <span>{{localize "FALLOUTMAW.Actor.CreatureType"}}</span>
        {{#if freeEdit}}
          <select name="system.creature.typeId" data-creature-type-select>
            <option value="">{{localize "FALLOUTMAW.Actor.NoCreatureType"}}</option>
            {{selectOptions creatureTypes selected=sourceSystem.creature.typeId}}
          </select>
        {{else}}
          <input type="text" value="{{creatureTypeName}}" disabled>
        {{/if}}
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Actor.Race"}}</span>
        {{#if freeEdit}}
          <select name="system.creature.raceId" data-creature-race-select>
            <option value="">{{localize "FALLOUTMAW.Actor.NoRace"}}</option>
            {{#each creatureRaces}}
              <option value="{{id}}" data-type-id="{{typeId}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
        {{else}}
          <input type="text" value="{{creatureRaceName}}" disabled>
        {{/if}}
      </label>
    </div>
    <div class="fallout-maw-stat-grid compact">
      <label>
        <span>{{localize "FALLOUTMAW.Actor.Level"}}</span>
        <input type="number" step="1" min="1" name="system.attributes.level" value="{{sourceSystem.attributes.level}}" {{editLockAttribute}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Actor.Dodge"}}</span>
        <input type="number" step="1" min="0" name="system.attributes.dodge" value="{{sourceSystem.attributes.dodge}}" {{editLockAttribute}}>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Common.ActionPoints"}}</span>
        <input type="number" value="{{system.attributes.actionPoints}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Common.MovementPoints"}}</span>
        <input type="number" value="{{system.attributes.movementPoints}}" disabled>
      </label>
    </div>
  </section>

  <section class="fallout-maw-sheet-section">
    <h2>{{localize "FALLOUTMAW.Settings.Characteristics.Title"}}</h2>
    <div class="fallout-maw-stat-grid compact">
      {{#each characteristics}}
        <label>
          <span>{{label}}</span>
          <input type="number" step="1" min="0" name="system.characteristics.{{key}}" value="{{value}}" {{../editLockAttribute}}>
        </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-sheet-section">
    <h2>{{localize "FALLOUTMAW.Settings.Skills.Title"}}</h2>
    <div class="fallout-maw-stat-grid">
      {{#each skills}}
        <label>
          <span>{{label}}</span>
          <input type="number" value="{{value}}" disabled>
        </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-sheet-section">
    <h2>{{localize "FALLOUTMAW.Common.DamageResistances"}}</h2>
    <div class="fallout-maw-stat-grid">
      {{#each damageResistances}}
        <label>
          <span>{{label}}</span>
          <input type="number" value="{{value}}" disabled>
        </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-sheet-section">
    <h2>{{localize "FALLOUTMAW.Actor.Progression"}}</h2>
    <div class="fallout-maw-stat-grid compact">
      <label>
        <span>{{localize "FALLOUTMAW.Actor.SkillPointsPerLevel"}}</span>
        <input type="number" value="{{system.progression.skillPointsPerLevel}}" disabled>
      </label>
      <label>
        <span>{{localize "FALLOUTMAW.Actor.ResearchPointsPerLevel"}}</span>
        <input type="number" value="{{system.progression.researchPointsPerLevel}}" disabled>
      </label>
    </div>
  </section>
</form>
