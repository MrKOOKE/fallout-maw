<div class="fallout-maw-token-hud-layout">
  <div class="fallout-maw-token-hud-left-stack">
    <section class="fallout-maw-token-hud-block fallout-maw-token-hud-weapons">
      <div class="fallout-maw-token-hud-block-title">{{#if activeWeaponSet}}{{activeWeaponSet.label}}{{else}}Оружие{{/if}}</div>
      <div class="fallout-maw-token-hud-slot-row">
        {{#if activeWeaponSet}}
        {{#each activeWeaponSet.slots}}
        <button type="button" class="fallout-maw-token-hud-tile {{#unless item}}empty{{/unless}}" data-action="openItem" data-item-id="{{item.id}}" {{#unless item}}disabled{{/unless}} title="{{label}}">
          {{#if item}}
          <img src="{{item.img}}" alt="{{item.name}}" onerror="this.src='{{../fallbackIcon}}'">
          <span>{{item.name}}</span>
          {{else}}
          <img src="icons/svg/combat.svg" alt="">
          <span>{{label}}</span>
          {{/if}}
        </button>
        {{/each}}
        {{else}}
        <div class="fallout-maw-token-hud-empty">Нет слотов</div>
        {{/if}}
      </div>
    </section>

    <section class="fallout-maw-token-hud-block fallout-maw-token-hud-limbs">
      <div class="fallout-maw-token-hud-block-title">Части тела</div>
      {{#if limbSilhouette.visible}}
      <svg class="fallout-maw-token-hud-limb-silhouette" viewBox="{{limbSilhouette.viewBox}}" role="img" aria-label="Limbs" data-limb-popover-root>
        {{#each limbSilhouette.parts}}
        <path class="fallout-maw-token-hud-limb-silhouette-part" d="{{d}}" fill="{{fill}}" data-limb-key="{{limbKey}}" data-limb-popover data-label="{{label}}" data-value="{{value}}" data-max="{{max}}"></path>
        {{/each}}
        {{#each limbSilhouette.outline}}
        <path class="fallout-maw-token-hud-limb-silhouette-outline" d="{{d}}"></path>
        {{/each}}
      </svg>
      {{else}}
      <div class="fallout-maw-token-hud-meter-list">
        {{#each limbs}}
        <div class="fallout-maw-token-hud-meter-card" data-limb-control-card data-limb-key="{{key}}" role="button" tabindex="0">
          <div class="fallout-maw-token-hud-meter-header">
            <span>{{label}}</span>
            <strong>{{value}} / {{max}}</strong>
          </div>
          <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
            <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </section>
  </div>

  <section class="fallout-maw-token-hud-block fallout-maw-token-hud-resources">
    <section class="fallout-maw-token-hud-meter-section {{#if meterSections.resources.collapsed}}collapsed{{/if}}" data-token-hud-meter-section="resources">
      <button type="button" class="fallout-maw-token-hud-block-title fallout-maw-token-hud-collapse-toggle" data-action="toggleMeterSection" data-section="resources" data-token-hud-meter-toggle aria-expanded="{{meterSections.resources.expanded}}">
        <i class="fa-solid fa-caret-down" inert></i>
        <span>Ресурсы</span>
      </button>
      <div class="fallout-maw-token-hud-collapsible">
        <div class="fallout-maw-token-hud-collapsible-inner fallout-maw-token-hud-meter-list">
          {{#each resources}}
          <div class="fallout-maw-token-hud-meter-card" data-token-hud-resource-card data-resource-key="{{key}}">
            <div class="fallout-maw-token-hud-meter-header">
              <span>{{label}}</span>
              <strong>{{value}} / {{max}}</strong>
            </div>
            <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}" data-token-hud-resource-meter data-resource-key="{{key}}" data-resource-min="{{min}}" data-resource-value="{{value}}" data-resource-max="{{max}}">
              <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
              <span class="fallout-maw-resource-meter-preview" aria-hidden="true"></span>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="fallout-maw-token-hud-meter-section {{#if meterSections.needs.collapsed}}collapsed{{/if}}" data-token-hud-meter-section="needs">
      <button type="button" class="fallout-maw-token-hud-block-title fallout-maw-token-hud-collapse-toggle secondary" data-action="toggleMeterSection" data-section="needs" data-token-hud-meter-toggle aria-expanded="{{meterSections.needs.expanded}}">
        <i class="fa-solid fa-caret-down" inert></i>
        <span>Потребности</span>
      </button>
      <div class="fallout-maw-token-hud-collapsible">
        <div class="fallout-maw-token-hud-collapsible-inner fallout-maw-token-hud-meter-list">
          {{#each needs}}
          <div class="fallout-maw-token-hud-meter-card">
            <div class="fallout-maw-token-hud-meter-header">
              <span>{{label}}</span>
              <strong>{{value}} / {{max}}</strong>
            </div>
            <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
              <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </section>
  </section>

  <section class="fallout-maw-token-hud-actions-wrap">
    {{#if tray.visible}}
    <div class="fallout-maw-token-hud-popup" data-token-action-hud-popup style="{{tray.metrics.style}}">
      {{#if (eq activeTray "skills")}}
      {{#each tray.skills}}
      <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="rollSkill" data-skill-key="{{key}}" title="{{label}}">
        <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
        <strong>{{value}}</strong>
      </button>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "items")}}
      {{#each tray.items}}
      <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="openItem" data-item-id="{{id}}" title="{{name}}">
        <img src="{{img}}" alt="{{name}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{name}}</span>
        {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
      </button>
      {{else}}
      <div class="fallout-maw-token-hud-empty">Нет предметов</div>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "abilities")}}
      {{#each tray.abilities}}
      <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="openItem" data-item-id="{{id}}" title="{{name}}">
        <img src="{{img}}" alt="{{name}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{name}}</span>
      </button>
      {{else}}
      <div class="fallout-maw-token-hud-empty">Нет способностей</div>
      {{/each}}
      {{/if}}
    </div>
    {{/if}}

    <div class="fallout-maw-token-hud-actions" data-token-action-hud-actions>
      {{#each actions}}
      {{#if (eq key "weapon")}}
      <button type="button" class="fallout-maw-token-hud-main-action" data-action="cycleWeaponSet" title="{{caption}}">
        <img src="{{icon}}" alt="{{caption}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{caption}}</span>
      </button>
      {{else if (eq key "settings")}}
      <button type="button" class="fallout-maw-token-hud-main-action" data-action="openSettings" title="{{label}}">
        <img src="{{icon}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
      </button>
      {{else}}
      <button type="button" class="fallout-maw-token-hud-main-action {{#if active}}active{{/if}}" data-action="toggleTray" data-tray="{{key}}" title="{{label}}">
        <img src="{{icon}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
      </button>
      {{/if}}
      {{/each}}
    </div>
  </section>
</div>
