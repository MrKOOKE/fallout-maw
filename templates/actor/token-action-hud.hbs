<div class="fallout-maw-token-hud-layout">
  <div class="fallout-maw-token-hud-main-grid">
  <div class="fallout-maw-token-hud-left-stack">
    <section class="fallout-maw-token-hud-block fallout-maw-token-hud-limbs">
      <div class="fallout-maw-token-hud-block-title fallout-maw-token-hud-limbs-title">
        <details class="fallout-maw-token-hud-limb-layer-menu" data-limb-layer-menu>
          <summary aria-label="Слой состояния частей тела">
            <span>{{limbLayer.label}}</span>
            <i class="fa-solid fa-caret-down" inert></i>
          </summary>
          <div class="fallout-maw-token-hud-limb-layer-options" role="listbox">
            {{#each limbLayer.choices}}
            <button type="button" class="{{#if selected}}active{{/if}}" data-limb-layer-option="{{key}}" role="option" aria-selected="{{selected}}">{{label}}</button>
            {{/each}}
          </div>
        </details>
        {{#if gmControls}}
        <span class="fallout-maw-token-hud-gm-actions">
          <button type="button" data-action="gmHealSelected" title="Полностью вылечить выбранных актеров"><i class="fa-solid fa-kit-medical"></i></button>
          <button type="button" data-action="gmAwardExperience" title="Выдать опыт выбранным актерам"><i class="fa-solid fa-star"></i></button>
        </span>
        {{/if}}
      </div>
      {{#if limbSilhouette.visible}}
      <svg class="fallout-maw-token-hud-limb-silhouette" viewBox="{{limbSilhouette.viewBox}}" role="img" aria-label="Limbs" data-limb-popover-root>
        {{#each limbSilhouette.parts}}
        <path class="fallout-maw-token-hud-limb-silhouette-part" d="{{d}}" fill="{{fill}}" data-limb-key="{{limbKey}}" data-limb-popover data-label="{{label}}" data-value="{{value}}" data-max="{{max}}" data-popover-rows="{{popoverRowsJson}}"></path>
        {{/each}}
        {{#each limbSilhouette.outline}}
        <path class="fallout-maw-token-hud-limb-silhouette-outline" d="{{d}}"></path>
        {{/each}}
      </svg>
      {{else}}
      <div class="fallout-maw-token-hud-meter-list">
        {{#each limbs}}
        <div class="fallout-maw-token-hud-meter-card" data-limb-control-card data-limb-key="{{key}}" role="button" tabindex="0">
          <div class="fallout-maw-token-hud-meter-header">
            <span>{{label}}</span>
            <strong>{{valueLabel}}{{#if maxLabel}} / {{maxLabel}}{{/if}}</strong>
          </div>
          <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
            <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </section>
  </div>

  <section class="fallout-maw-token-hud-block fallout-maw-token-hud-resources">
    <section class="fallout-maw-token-hud-meter-section {{#if meterSections.resources.collapsed}}collapsed{{/if}} {{#if meterSections.resources.editable}}editable{{/if}}" data-token-hud-meter-section="resources">
      <div class="fallout-maw-token-hud-meter-title-row">
        <button type="button" class="fallout-maw-token-hud-block-title fallout-maw-token-hud-collapse-toggle" data-action="toggleMeterSection" data-section="resources" data-token-hud-meter-toggle aria-expanded="{{meterSections.resources.expanded}}">
          <i class="fa-solid fa-caret-down" inert></i>
          <span>Ресурсы</span>
        </button>
        {{#if gmControls}}
        <button type="button" class="fallout-maw-token-hud-meter-edit-lock {{#if meterSections.resources.editable}}unlocked{{/if}}" data-action="toggleMeterEdit" data-section="resources" title="Редактировать текущие значения ресурсов" aria-pressed="{{meterSections.resources.editable}}">
          <i class="fa-solid {{#if meterSections.resources.editable}}fa-lock-open{{else}}fa-lock{{/if}}" inert></i>
        </button>
        {{/if}}
      </div>
      <div class="fallout-maw-token-hud-collapsible">
        <div class="fallout-maw-token-hud-collapsible-inner fallout-maw-token-hud-meter-list">
          {{#each resources}}
          <div class="fallout-maw-token-hud-meter-card" data-token-hud-resource-card data-resource-key="{{key}}">
            <div class="fallout-maw-token-hud-meter-header">
              <span>{{label}}</span>
              {{#if ../meterSections.resources.editable}}
              <label class="fallout-maw-token-hud-meter-value-editor">
                <input type="number" value="{{value}}" min="{{min}}" max="{{max}}" step="1" data-token-hud-meter-value-input data-section="resources" data-key="{{key}}" data-original-value="{{value}}" aria-label="{{label}}">
                <b>/ {{max}}</b>
              </label>
              {{else}}
              <strong>{{valueLabel}}{{#if maxLabel}} / {{maxLabel}}{{/if}}</strong>
              {{/if}}
            </div>
            <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}" data-token-hud-resource-meter data-resource-key="{{key}}" data-resource-min="{{min}}" data-resource-value="{{value}}" data-resource-max="{{max}}" data-resource-limited="{{blockedAmount}}">
              <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
              {{#if blockedAmount}}<span class="fallout-maw-resource-meter-blocked" style="{{blockedStyle}}" aria-hidden="true"></span>{{/if}}
              <span class="fallout-maw-resource-meter-preview" aria-hidden="true"></span>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="fallout-maw-token-hud-meter-section {{#if meterSections.needs.collapsed}}collapsed{{/if}} {{#if meterSections.needs.editable}}editable{{/if}}" data-token-hud-meter-section="needs">
      <div class="fallout-maw-token-hud-meter-title-row secondary">
        <button type="button" class="fallout-maw-token-hud-block-title fallout-maw-token-hud-collapse-toggle secondary" data-action="toggleMeterSection" data-section="needs" data-token-hud-meter-toggle aria-expanded="{{meterSections.needs.expanded}}">
          <i class="fa-solid fa-caret-down" inert></i>
          <span>Потребности</span>
        </button>
        {{#if gmControls}}
        <button type="button" class="fallout-maw-token-hud-meter-edit-lock {{#if meterSections.needs.editable}}unlocked{{/if}}" data-action="toggleMeterEdit" data-section="needs" title="Редактировать текущие значения потребностей" aria-pressed="{{meterSections.needs.editable}}">
          <i class="fa-solid {{#if meterSections.needs.editable}}fa-lock-open{{else}}fa-lock{{/if}}" inert></i>
        </button>
        {{/if}}
      </div>
      <div class="fallout-maw-token-hud-collapsible">
        <div class="fallout-maw-token-hud-collapsible-inner fallout-maw-token-hud-meter-list">
          {{#each needs}}
          <div class="fallout-maw-token-hud-meter-card">
            <div class="fallout-maw-token-hud-meter-header">
              <span>{{label}}</span>
              {{#if ../meterSections.needs.editable}}
              <label class="fallout-maw-token-hud-meter-value-editor">
                <input type="number" value="{{value}}" min="{{min}}" max="{{max}}" step="1" data-token-hud-meter-value-input data-section="needs" data-key="{{key}}" data-original-value="{{value}}" aria-label="{{label}}">
                <b>/ {{max}}</b>
              </label>
              {{else}}
              <strong>{{value}} / {{max}}</strong>
              {{/if}}
            </div>
            <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
              <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </section>
  </section>

  <section class="fallout-maw-token-hud-actions-wrap">
    {{#if tray.visible}}
    <div class="fallout-maw-token-hud-popup {{#if (eq activeTray "actions")}}actions{{/if}} {{#if (eq activeTray "abilities")}}abilities{{/if}} {{#if (eq activeTray "weaponActions")}}weapon-actions{{/if}} {{#if (eq activeTray "weaponSets")}}weapon-sets{{/if}}" data-token-action-hud-popup style="{{tray.metrics.style}}">
      {{#if (eq activeTray "skills")}}
      {{#each tray.skills}}
      <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="rollSkill" data-skill-key="{{key}}" title="{{label}}">
        <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
      </button>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "items")}}
      {{#each tray.items}}
      <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="useItem" data-item-id="{{id}}" data-hud-tooltip-item="{{id}}" aria-label="{{name}}">
        <img src="{{img}}" alt="{{name}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{name}}</span>
        {{#if showFirstAidCharges}}<strong class="fallout-maw-token-hud-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</strong>{{else}}
        {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
        {{/if}}
      </button>
      {{else}}
      <div class="fallout-maw-token-hud-empty">Нет предметов</div>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "abilities")}}
      {{#each tray.abilityGroups}}
      <div class="fallout-maw-token-hud-action-row fallout-maw-token-hud-ability-row">
        <div class="fallout-maw-token-hud-action-row-title">{{label}}</div>
        <div class="fallout-maw-token-hud-action-row-buttons">
          {{#each items}}
          <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="openItem" data-item-id="{{id}}" data-hud-tooltip-item="{{id}}" aria-label="{{name}}">
            <img src="{{img}}" alt="{{name}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{name}}</span>
          </button>
          {{else}}
          <div class="fallout-maw-token-hud-empty">{{emptyLabel}}</div>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "actions")}}
      {{#each tray.actionGroups}}
      <div class="fallout-maw-token-hud-action-row">
        <div class="fallout-maw-token-hud-action-row-title">{{label}}</div>
        <div class="fallout-maw-token-hud-action-row-buttons">
          {{#each actions}}
          {{#if (eq action "useActiveAction")}}
          <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="useActiveAction" data-active-action-key="{{key}}" title="{{label}}" {{#if disabled}}disabled{{/if}}>
            <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{label}}</span>
          </button>
          {{else}}
          {{#if (eq action "dragGrappledTarget")}}
          <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="dragGrappledTarget" title="{{label}}" {{#if disabled}}disabled{{/if}}>
            <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{label}}</span>
          </button>
          {{else}}
          <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="useSystemAction" data-system-action-key="{{key}}" title="{{label}}">
            <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{label}}</span>
          </button>
          {{/if}}
          {{/if}}
          {{else}}
          <div class="fallout-maw-token-hud-empty">{{localize "FALLOUTMAW.Settings.HUD.NoActions"}}</div>
          {{/each}}
        </div>
      </div>
      {{else}}
      <div class="fallout-maw-token-hud-empty">Действий нет</div>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "weaponActions")}}
      {{#each tray.weaponActionRows}}
      <div class="fallout-maw-token-hud-action-row">
        <div class="fallout-maw-token-hud-action-row-title">{{label}}</div>
        <div class="fallout-maw-token-hud-action-row-buttons">
          {{#each actions}}
          <button type="button" class="fallout-maw-token-hud-tile fallout-maw-token-hud-action-tile" data-action="useWeaponAction" data-item-id="{{itemId}}" data-weapon-function-id="{{weaponFunctionId}}" data-weapon-action-key="{{key}}" aria-label="{{label}}" {{#if disabled}}disabled{{/if}}>
            <img src="{{img}}" alt="{{label}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{label}}</span>
            {{#if actionPointCostLabel}}<strong class="{{actionPointCostClass}}" {{#if actionPointCostTooltipHtml}}data-action-point-cost-tooltip data-action-point-cost-tooltip-html="{{actionPointCostTooltipHtml}}"{{/if}} aria-label="{{actionPointCostTooltipLabel}}">{{actionPointCostLabel}}</strong>{{/if}}
          </button>
          {{/each}}
        </div>
      </div>
      {{else}}
      <div class="fallout-maw-token-hud-empty">Действий нет</div>
      {{/each}}
      {{/if}}

      {{#if (eq activeTray "weaponSets")}}
      {{#each tray.weaponSets}}
      <button type="button" class="fallout-maw-token-hud-weapon-set-row {{#if active}}active{{/if}}" data-action="selectHudWeaponSet" data-weapon-set="{{key}}" title="{{label}}">
        <span class="fallout-maw-token-hud-weapon-set-row-title">{{label}}</span>
        <span class="fallout-maw-token-hud-weapon-set-row-slots">
          {{#each slots}}
          <span class="fallout-maw-token-hud-set-slot-preview {{#if selected}}active{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}} {{#unless item}}empty{{/unless}}" {{#if hudAspectStyle}}style="{{hudAspectStyle}}"{{/if}}>
            {{#if item}}
            <img src="{{item.img}}" alt="{{item.name}}" onerror="this.src='{{../../fallbackIcon}}'">
            <span>{{item.name}}</span>
            {{else}}
            <img src="{{emptyIcon}}" alt="">
            <span>{{label}}</span>
            {{/if}}
          </span>
          {{/each}}
        </span>
      </button>
      {{/each}}
      {{/if}}
    </div>
    {{/if}}

    <div class="fallout-maw-token-hud-actions" data-token-action-hud-actions>
      {{#if weaponSet}}
      <button type="button" class="fallout-maw-token-hud-main-action fallout-maw-token-hud-weapon-set-toggle {{#if (eq activeTray "weaponSets")}}active{{/if}}" data-action="toggleTray" data-tray="weaponSets" title="{{weaponSet.label}}">
        <span>Наборы</span>
        <i class="fa-solid fa-caret-up" inert></i>
      </button>
      {{#each weaponSet.weapons}}
      <button type="button" class="fallout-maw-token-hud-main-action fallout-maw-token-hud-weapon-button {{#if selected}}active{{/if}} {{#if useDisabled}}unusable{{/if}} variable-width" data-action="toggleWeaponActions" data-item-id="{{item.id}}" data-weapon-set="{{weaponSetKey}}" title="{{item.name}}" {{#if hudAspectStyle}}style="{{hudAspectStyle}}"{{/if}} {{#if useDisabled}}disabled{{/if}}>
        <img src="{{item.img}}" alt="{{item.name}}" onerror="this.src='{{../fallbackIcon}}'">
        {{#if hudStatusBadges.magazine}}<strong class="fallout-maw-token-hud-weapon-badge magazine">{{hudStatusBadges.magazine.label}}</strong>{{/if}}
        {{#if hudStatusBadges.condition}}<strong class="fallout-maw-token-hud-weapon-badge condition {{hudStatusBadges.condition.tone}}">{{hudStatusBadges.condition.label}}</strong>{{/if}}
        <span>{{item.name}}</span>
      </button>
      {{/each}}
      {{/if}}
      {{#each actions}}
      {{#if (eq key "settings")}}
      <button type="button" class="fallout-maw-token-hud-main-action" data-action="openSettings" aria-label="{{label}}">
        <img src="{{icon}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
      </button>
      {{else}}
      <button type="button" class="fallout-maw-token-hud-main-action {{#if active}}active{{/if}}" data-action="toggleTray" data-tray="{{key}}" aria-label="{{label}}">
        <img src="{{icon}}" alt="{{label}}" onerror="this.src='{{../fallbackIcon}}'">
        <span>{{label}}</span>
      </button>
      {{/if}}
      {{/each}}
      {{#if endTurnAction}}
      <button type="button" class="fallout-maw-token-hud-main-action fallout-maw-token-hud-end-turn" data-action="endCombatTurn" title="{{endTurnAction.title}}" aria-label="{{endTurnAction.label}}">
        <i class="{{endTurnAction.icon}}" inert></i>
        <span>{{endTurnAction.label}}</span>
      </button>
      {{/if}}
    </div>
  </section>
  </div>
</div>
