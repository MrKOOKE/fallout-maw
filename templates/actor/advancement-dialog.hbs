<div class="fallout-maw-config-body fallout-maw-advancement-body">
  {{#if isDevelopmentPage}}
  <section class="fallout-maw-panel fallout-maw-advancement-hero">
    <div class="fallout-maw-advancement-hero-layout">
      <div class="fallout-maw-advancement-hero-main">
        <div class="fallout-maw-advancement-info-grid">
          <div class="fallout-maw-advancement-info-row">
            <span>{{localize "FALLOUTMAW.Common.Label"}}</span>
            <strong>{{actor.name}}</strong>
          </div>
          <div class="fallout-maw-advancement-info-row">
            <span>{{localize "FALLOUTMAW.Actor.Race"}}</span>
            <strong>{{raceName}}</strong>
          </div>
          <div class="fallout-maw-advancement-info-row">
            <span>{{localize "FALLOUTMAW.Actor.Level"}}</span>
            <strong>{{level}}</strong>
          </div>
          <div class="fallout-maw-advancement-info-row">
            <span>{{localize "FALLOUTMAW.Advancement.Experience"}}</span>
            <strong>{{experienceCurrent}} / {{experienceNext}}</strong>
          </div>
        </div>

        <div class="fallout-maw-advancement-xp">
          <div class="fallout-maw-research-progress-bar fallout-maw-advancement-xp-bar">
            <span style="{{experienceBarStyle}}"></span>
          </div>
        </div>

        <button type="button" class="fallout-maw-advancement-action-button fallout-maw-advancement-major-button" data-action="levelUp" {{#unless canLevelUp}}disabled{{/unless}}>
          <i class="fa-solid fa-arrow-up"></i>
          {{localize "FALLOUTMAW.Advancement.LevelUp"}}
        </button>
      </div>

      <div class="fallout-maw-advancement-hero-side">
        <div class="fallout-maw-advancement-side-stat">
          <span>{{localize "FALLOUTMAW.Actor.SkillPointsPerLevel"}}</span>
          <strong>{{skillPointsPerLevel}}</strong>
        </div>
        <div class="fallout-maw-advancement-side-stat">
          <span>ОИ за уровень</span>
          <strong>{{researchPointsPerLevel}}</strong>
        </div>
        <button type="button" class="fallout-maw-advancement-action-button fallout-maw-advancement-reset-button" data-action="resetDevelopment">
          <i class="fa-solid fa-rotate-left"></i>
          {{localize "FALLOUTMAW.Advancement.Reset"}}
        </button>
      </div>
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-advancement-section">
    <div class="fallout-maw-advancement-section-title">
      <h2>{{localize "FALLOUTMAW.Common.Characteristics"}}</h2>
    </div>
    <div class="fallout-maw-advancement-characteristics">
      {{#each characteristics}}
      <div class="fallout-maw-advancement-row">
        <span class="fallout-maw-advancement-name" title="{{abbr}} / {{key}}">{{label}}</span>
        <div class="fallout-maw-advancement-controls">
          <button type="button" class="fallout-maw-advancement-control-button" data-repeat-action="decreaseCharacteristic" data-characteristic-key="{{key}}" {{#unless canDecrease}}disabled{{/unless}}><i class="fa-solid fa-minus"></i></button>
          <strong>{{value}}</strong>
          <button type="button" class="fallout-maw-advancement-control-button" data-repeat-action="increaseCharacteristic" data-characteristic-key="{{key}}" {{#unless canIncrease}}disabled{{/unless}}><i class="fa-solid fa-plus"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
    <div class="fallout-maw-advancement-section-footer fallout-maw-advancement-characteristics-footer">
      <div></div>
      <div class="fallout-maw-advancement-meter">
        <span>{{localize "FALLOUTMAW.Advancement.CharacteristicPoints"}}</span>
        <strong>{{characteristicPointsDisplay}}</strong>
      </div>
    </div>
  </section>

  <section class="fallout-maw-panel fallout-maw-advancement-section">
    <div class="fallout-maw-advancement-section-title">
      <h2>{{localize "FALLOUTMAW.Common.Skills"}}</h2>
    </div>
    <div class="fallout-maw-advancement-skills">
      {{#each skills}}
      <div class="fallout-maw-advancement-skill-row">
        <button
          type="button"
          class="fallout-maw-advancement-signature fallout-maw-advancement-control-button{{#if signature}} active{{/if}}"
          data-action="toggleSignatureSkill"
          data-skill-key="{{key}}"
          {{#unless canToggleSignature}}disabled{{/unless}}
          title="{{localize 'FALLOUTMAW.Advancement.ToggleSignatureSkill'}}"
        >
          <i class="fa-solid fa-star"></i>
        </button>

        <span class="fallout-maw-advancement-name">{{label}}</span>

        <div class="fallout-maw-advancement-controls">
          <button type="button" class="fallout-maw-advancement-control-button" data-repeat-action="decreaseSkill" data-skill-key="{{key}}" {{#unless canDecrease}}disabled{{/unless}}><i class="fa-solid fa-minus"></i></button>
          <strong>{{value}}</strong>
          <button type="button" class="fallout-maw-advancement-control-button" data-repeat-action="increaseSkill" data-skill-key="{{key}}" {{#unless canIncrease}}disabled{{/unless}}><i class="fa-solid fa-plus"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
    <div class="fallout-maw-advancement-section-footer fallout-maw-advancement-skills-footer">
      <div class="fallout-maw-advancement-meter">
        <span>{{localize "FALLOUTMAW.Advancement.SignatureSkillPoints"}}</span>
        <strong>{{signatureSkillPointsDisplay}}</strong>
      </div>
      <div class="fallout-maw-advancement-meter">
        <span>{{localize "FALLOUTMAW.Advancement.SkillPoints"}}</span>
        <strong>{{skillPointsDisplay}}</strong>
      </div>
    </div>
  </section>
  {{/if}}

  {{#if isAbilitiesPage}}
  <section class="fallout-maw-advancement-talents">
    <div class="fallout-maw-advancement-talents-row fallout-maw-advancement-available-abilities">
      <div class="fallout-maw-advancement-talents-header">Доступные способности</div>
      <input type="text" class="fallout-maw-advancement-talent-search-input" data-ability-search placeholder="Поиск способностей...">

      <div class="fallout-maw-advancement-talents-list">
        {{#each abilityCategories}}
        <div class="fallout-maw-advancement-talent-group{{#unless expanded}} collapsed{{/unless}}" data-ability-category>
          <button type="button" class="fallout-maw-advancement-talent-group-header {{traitAvailabilityClass}}" data-action="toggleAbilityCategory" data-category-id="{{id}}">
            <span class="fallout-maw-advancement-collapse-icon">{{#if expanded}}▾{{else}}▸{{/if}}</span>
            <span>{{displayName}}</span>
          </button>
          <div class="fallout-maw-advancement-talent-group-abilities">
            {{#each abilities}}
            <button
              type="button"
              class="fallout-maw-advancement-talent-item{{#if selected}} selected{{/if}}{{#if owned}} owned{{/if}}{{#if researchActive}} research-active{{/if}}{{#unless acquisitionAvailable}} unavailable{{/unless}}"
              data-action="selectAbility"
              data-ability-entry
              data-ability-search-text="{{name}} {{acquisitionLabel}} {{manualLabel}}"
              data-ability-source-id="{{sourceId}}"
              {{#if descriptionTooltipHTML}}data-ability-description-tooltip="{{descriptionTooltipHTML}}"{{/if}}
            >
              <img class="fallout-maw-advancement-talent-icon" src="{{img}}" alt="">
              <span class="fallout-maw-advancement-talent-name">{{name}}</span>
            </button>
            {{else}}
            <p class="fallout-maw-empty-list fallout-maw-advancement-talent-empty">В каталоге нет способностей.</p>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    <div class="fallout-maw-advancement-talents-row fallout-maw-advancement-details-row">
      {{#if selectedAbility}}
      <div class="fallout-maw-advancement-talents-details">
        <div class="fallout-maw-advancement-talent-details-content">
          <div class="fallout-maw-advancement-talent-details-name">{{selectedAbility.name}}</div>
          <div class="fallout-maw-advancement-talent-research-info">
            <div><span>Статус:</span> {{selectedAbility.statusLabel}}</div>
            {{#if selectedAbility.isFeature}}
            {{#if selectedAbility.requirementLabel}}<div><span>Условия:</span> {{selectedAbility.requirementLabel}}</div>{{/if}}
            {{else}}
            <div><span>Стоимость:</span> {{selectedAbility.cost}} ОИ</div>
            <div><span>Прогресс:</span> {{selectedAbility.progressLabel}}</div>
            <div><span>Приобретение:</span> {{selectedAbility.acquisitionLabel}}</div>
            {{#if selectedAbility.manualLabel}}<div><span>Ручное исследование:</span> {{selectedAbility.manualLabel}}</div>{{/if}}
            {{/if}}
          </div>
        </div>
      </div>
      <div class="fallout-maw-advancement-talent-action-panel" data-ability-source-id="{{selectedAbility.sourceId}}" data-research-id="{{selectedAbility.researchId}}">
        {{#if selectedAbility.isFeature}}
        <button type="button" class="fallout-maw-advancement-talent-action-button primary" data-action="purchaseTraitAbility" {{#unless selectedAbility.canPurchaseTrait}}disabled{{/unless}}>
          Приобрести
        </button>
        <div class="fallout-maw-advancement-talents-points">Особенности: {{traitPointsDisplay}}</div>
        {{else}}
        <button type="button" class="fallout-maw-advancement-talent-action-button primary" data-action="startAbilityResearch" {{#unless selectedAbility.canStartManual}}disabled{{/unless}}>
          Начать исследование
        </button>
        <button type="button" class="fallout-maw-advancement-talent-action-button secondary" data-action="spendAbilityResearch" {{#unless selectedAbility.canSpendFree}}disabled{{/unless}}>
          Вложить очки
        </button>
        <div class="fallout-maw-advancement-talents-points">Свободные ОИ: {{researchPointsDisplay}}</div>
        {{/if}}
      </div>
      {{else}}
      <div class="fallout-maw-advancement-talents-details">
        <div class="fallout-maw-advancement-details-placeholder">Выберите способность для просмотра данных исследования</div>
      </div>
      <div class="fallout-maw-advancement-talent-action-panel">
        <button type="button" class="fallout-maw-advancement-talent-action-button primary" disabled>Начать исследование</button>
        <button type="button" class="fallout-maw-advancement-talent-action-button secondary" disabled>Вложить очки</button>
        <div class="fallout-maw-advancement-talents-points">Свободные ОИ: {{researchPointsDisplay}}</div>
      </div>
      {{/if}}
    </div>
  </section>
  {{/if}}

  <footer class="sheet-footer flexrow fallout-maw-advancement-footer">
    <button type="button" class="fallout-maw-advancement-page-button" data-action="previousPage" {{#if isDevelopmentPage}}disabled{{/if}}><i class="fa-solid fa-chevron-left"></i></button>
    <button type="submit" class="fallout-maw-advancement-save-button"><i class="fa-solid fa-save"></i> {{localize "FALLOUTMAW.Common.SaveChanges"}}</button>
    <button type="button" class="fallout-maw-advancement-page-button" data-action="nextPage" {{#if isAbilitiesPage}}disabled{{/if}}><i class="fa-solid fa-chevron-right"></i></button>
  </footer>
</div>
