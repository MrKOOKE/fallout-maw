<div class="fallout-maw-sheet fallout-maw-search-sheet" data-search-root {{#if isTrade}}data-trade-root{{/if}}>
  <header class="fallout-maw-sheet-header fallout-maw-search-header">
    {{#each actors}}
    <section class="fallout-maw-search-actor-title fallout-maw-search-actor-title--{{side}}">
      <div class="fallout-maw-title-display">
      {{#if selector.canSelect}}
        <span>{{selector.label}}</span>
        <select class="fallout-maw-trade-actor-select" data-trade-actor-select="{{side}}" aria-label="{{selector.label}}">
        {{#each selector.options}}
          <option value="{{actorUuid}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
        </select>
      {{else}}
        <span>{{name}}</span>
      {{/if}}
      </div>
    </section>
    {{/each}}
    {{#unless isTrade}}
    <div class="fallout-maw-search-bulk-controls">
      <button type="button" data-search-bulk-transfer="put" title="Положить все" {{#unless canInteract}}disabled{{/unless}}>
        <img src="icons/svg/chest.svg" alt="Положить все">
      </button>
      <button type="button" data-search-bulk-transfer="take" title="Забрать все" {{#unless canInteract}}disabled{{/unless}}>
        <img src="icons/svg/item-bag.svg" alt="Забрать все">
      </button>
    </div>
    {{/unless}}
  </header>

  <div class="fallout-maw-sheet-body fallout-maw-search-sheet-body">
    {{#unless canInteract}}
    <p class="fallout-maw-empty-list fallout-maw-search-notice">Нет прав на обыскивающего актера.</p>
    {{/unless}}

    <section class="tab active fallout-maw-search-tab" data-tab="inventory">
      <div class="fallout-maw-search-columns">
        {{#each actors}}
        <section class="fallout-maw-search-side fallout-maw-search-side--{{side}}" data-search-actor-uuid="{{uuid}}" data-search-side="{{side}}">
          <section class="fallout-maw-panel fallout-maw-load-panel">
            <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Common.Load'}}">
              <div class="fallout-maw-load-meter-track">
                <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
              </div>
              <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
            </div>
          </section>

          <section class="fallout-maw-inventory-summary">
            <section class="fallout-maw-panel">
              <div class="fallout-maw-currency-list">
                {{#each currencies}}
                <div class="fallout-maw-currency-chip {{#if tradePrimary}}trade-primary{{/if}}" data-search-currency="{{key}}" data-search-actor-uuid="{{../uuid}}" data-trade-base-amount="{{amount}}" title="{{label}} | {{localize 'FALLOUTMAW.Common.Value'}}: {{value}}">
                  <span class="fallout-maw-currency-icon">
                    {{#if hasImage}}
                    <img src="{{img}}" alt="{{label}}">
                    {{else}}
                    <span class="fallout-maw-currency-icon-placeholder"></span>
                    {{/if}}
                  </span>
                  <strong class="fallout-maw-currency-amount">{{amount}}</strong>
                </div>
                {{else}}
                <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.Currencies.Empty"}}</p>
                {{/each}}
              </div>
            </section>
          </section>

          <div class="fallout-maw-search-inventory-stack fallout-maw-pane-scroll" data-search-scroll-key="{{side}}:inventory-stack" data-search-drop-zone data-search-actor-uuid="{{uuid}}" data-inventory-parent-id="">
          {{#if ../isTrade}}
          <section class="fallout-maw-panel fallout-maw-trade-offer">
            <header class="fallout-maw-trade-offer-header">
              <h2>
                <span>{{#if tradeOffer.completed}}Купленное{{else}}Предложение{{/if}}</span>
                {{#unless tradeOffer.completed}}
                <strong>{{tradeOffer.total}}</strong>
                <em class="fallout-maw-trade-offer-difference fallout-maw-trade-offer-difference--{{tradeOffer.differenceClass}}">({{tradeOffer.differenceLabel}})</em>
                {{/unless}}
              </h2>
              <div class="fallout-maw-trade-offer-actions">
                <button type="button" class="fallout-maw-trade-offer-clear" data-trade-offer-remove="all" data-trade-side="{{tradeOffer.side}}" title="Забрать все" {{#unless tradeOffer.canControl}}disabled{{/unless}}>
                  <i class="fa-solid fa-box-open"></i>
                </button>
                {{#if tradeOffer.completed}}
                <button type="button" class="fallout-maw-trade-ready-button" data-trade-restart {{#unless tradeOffer.canControl}}disabled{{/unless}}>
                  <i class="fa-solid fa-rotate-right"></i>
                  <span>Возобновить торговлю</span>
                </button>
                {{else}}
                <button type="button" class="fallout-maw-trade-ready-button {{#if tradeOffer.ready}}ready{{/if}}" data-trade-ready="{{tradeOffer.side}}" {{#unless tradeOffer.canConfirm}}disabled{{/unless}}>
                  <i class="fa-solid fa-check"></i>
                  <span>Подтвердить</span>
                </button>
                {{/if}}
              </div>
            </header>
            <div class="fallout-maw-trade-offer-grid" data-search-drop-zone data-search-actor-uuid="{{uuid}}" data-trade-offer-grid data-trade-offer-actor-uuid="{{uuid}}" style="--fallout-maw-trade-offer-columns: {{tradeOffer.grid.columns}};">
              {{#each tradeOffer.grid.cells}}
              <div class="fallout-maw-inventory-cell fallout-maw-trade-offer-cell {{#if occupied}}occupied{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../uuid}}" data-trade-offer-actor-uuid="{{../uuid}}" data-trade-offer-cell data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
              {{/each}}
              {{#each tradeOffer.items}}
              <article class="{{#if ../tradeOffer.canControl}}draggable fallout-maw-draggable-item{{/if}} fallout-maw-inventory-item fallout-maw-inventory-grid-item fallout-maw-trade-offer-item {{#if brokenCondition}}broken-condition{{/if}}" draggable="{{#if ../tradeOffer.canControl}}true{{else}}false{{/if}}" style="{{gridStyle}}" data-trade-offer-entry data-trade-offer-kind="item" data-trade-offer-side="{{side}}" data-trade-offer-key="{{offerKey}}" data-trade-offer-actor-uuid="{{../uuid}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-x="{{placement.x}}" data-y="{{placement.y}}">
                <img src="{{img}}" alt="{{name}}">
                {{#if price}}<span class="fallout-maw-trade-price">{{price}}</span>{{/if}}
                {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                {{#unless completed}}
                <button type="button" class="fallout-maw-trade-offer-remove" data-trade-offer-remove="item" data-trade-side="{{side}}" data-trade-offer-key="{{offerKey}}" title="Убрать" {{#unless ../tradeOffer.canControl}}disabled{{/unless}}>
                  <i class="fa-solid fa-xmark"></i>
                </button>
                {{/unless}}
              </article>
              {{/each}}
              {{#each tradeOffer.currencies}}
              <article class="{{#if completed}}{{#if ../tradeOffer.canControl}}draggable fallout-maw-draggable-item{{/if}}{{/if}} fallout-maw-inventory-item fallout-maw-inventory-grid-item fallout-maw-trade-offer-currency" draggable="{{#if completed}}{{#if ../tradeOffer.canControl}}true{{else}}false{{/if}}{{else}}false{{/if}}" style="{{gridStyle}}" title="{{label}}: {{amount}}" data-trade-offer-entry data-trade-offer-kind="currency" data-trade-offer-side="{{side}}" data-trade-offer-key="{{offerKey}}" data-trade-offer-actor-uuid="{{../uuid}}" data-search-actor-uuid="{{../uuid}}" data-item-id="{{offerKey}}" data-inventory-grid-item data-x="{{placement.x}}" data-y="{{placement.y}}">
                <span class="fallout-maw-currency-icon">
                  {{#if hasImage}}
                  <img src="{{img}}" alt="{{label}}">
                  {{else}}
                  <span class="fallout-maw-currency-icon-placeholder"></span>
                  {{/if}}
                </span>
                <strong>{{amount}}</strong>
                {{#unless completed}}
                <button type="button" class="fallout-maw-trade-offer-remove" data-trade-offer-remove="currency" data-trade-side="{{side}}" data-trade-offer-key="{{offerKey}}" title="Убрать" {{#unless ../tradeOffer.canControl}}disabled{{/unless}}>
                  <i class="fa-solid fa-xmark"></i>
                </button>
                {{/unless}}
              </article>
              {{/each}}
            </div>
          </section>
          {{/if}}

            <section class="fallout-maw-panel fallout-maw-equipment-pane fallout-maw-search-equipment-pane {{#if equipmentCollapsed}}collapsed{{/if}}">
              <h2 {{#if ../isTrade}}class="fallout-maw-trade-equipment-toggle" data-trade-equipment-toggle{{/if}}>
                {{#if ../isTrade}}
                <i class="fa-solid {{#if equipmentCollapsed}}fa-chevron-right{{else}}fa-chevron-down{{/if}}"></i>
                <span>{{inventory.equipmentHeading}}</span>
                {{else}}{{inventory.equipmentHeading}}{{/if}}
              </h2>
              <div class="fallout-maw-pane-scroll fallout-maw-equipment-scroll" data-trade-equipment-body>
                <div class="fallout-maw-equipment-slot-list">
                  {{#each inventory.equipmentSlots}}
                  <div class="fallout-maw-slot-card">
                    <div class="fallout-maw-slot-card-label" {{#if fullLabel}}title="{{fullLabel}}"{{/if}}>{{label}}</div>
                    <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large {{#if locked}}locked{{/if}} {{#if (eq item.occupiedSlotMode "oneOf")}}one-of{{/if}}" {{#unless locked}}data-search-drop-zone{{/unless}} data-search-actor-uuid="{{../uuid}}" data-equipment-slot="{{key}}">
                      {{#if item}}
                      <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}" {{#if item.tradePrice}}data-trade-price="{{item.tradePrice}}"{{/if}}>
                        <img src="{{item.img}}" alt="{{item.name}}">
                        {{#if item.tradePrice}}<span class="fallout-maw-trade-price">{{item.tradePrice}}</span>{{/if}}
                        {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                      </article>
                      {{/if}}
                    </div>
                  </div>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
                  {{/each}}
                </div>

                {{#if inventory.prosthesisSlots.length}}
                <h2>Протезы</h2>
                <div class="fallout-maw-equipment-slot-list fallout-maw-prosthesis-slot-list">
                  {{#each inventory.prosthesisSlots}}
                  <div class="fallout-maw-slot-card">
                    <div class="fallout-maw-slot-card-label">{{label}}</div>
                    <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-prosthesis-slot" data-prosthesis-limb="{{key}}">
                      {{#if item}}
                      <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item equipped {{#if item.brokenCondition}}broken-condition{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}" {{#if item.tradePrice}}data-trade-price="{{item.tradePrice}}"{{/if}}>
                        <img src="{{item.img}}" alt="{{item.name}}">
                        {{#if item.tradePrice}}<span class="fallout-maw-trade-price">{{item.tradePrice}}</span>{{/if}}
                        {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                      </article>
                      {{/if}}
                    </div>
                  </div>
                  {{/each}}
                </div>
                {{/if}}

                <h2>{{localize "FALLOUTMAW.Common.Weapon"}}</h2>
                <div class="fallout-maw-weapon-set-list">
                  {{#each inventory.weaponSets}}
                  <section class="fallout-maw-weapon-set">
                    <h3>{{label}}</h3>
                    <div class="fallout-maw-weapon-slot-list">
                      {{#each slots}}
                      <div class="fallout-maw-slot-card">
                        <div class="fallout-maw-slot-card-label">{{label}}</div>
                        <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-weapon-set="{{weaponSetKey}}" data-weapon-slot="{{key}}">
                          {{#if item}}
                          <article class="{{#unless phantom}}{{item.draggableClass}}{{/unless}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}" {{#if item.tradePrice}}data-trade-price="{{item.tradePrice}}"{{/if}}>
                            <img src="{{item.img}}" alt="{{item.name}}">
                            {{#if item.tradePrice}}<span class="fallout-maw-trade-price">{{item.tradePrice}}</span>{{/if}}
                            {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                          </article>
                          {{/if}}
                        </div>
                      </div>
                      {{/each}}
                    </div>
                  </section>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
                  {{/each}}
                </div>
              </div>
            </section>

            <section class="fallout-maw-panel fallout-maw-inventory-pane">
              <h2>{{localize "FALLOUTMAW.Common.Inventory"}}</h2>
              <div class="fallout-maw-pane-scroll fallout-maw-inventory-scroll">
                <div class="fallout-maw-inventory-grid {{#if inventory.grid.hasPhantomItems}}has-phantom-items{{/if}}" data-search-drop-zone data-search-actor-uuid="{{uuid}}" data-inventory-grid data-inventory-parent-id="" style="--fallout-maw-inventory-columns: {{inventory.grid.columns}};">
                  {{#each inventory.grid.cells}}
                  <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}} {{#if phantom}}phantom{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../uuid}}" data-inventory-cell data-inventory-parent-id="" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
                  {{/each}}
                  {{#each inventory.grid.items}}
                  <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="" data-x="{{placement.x}}" data-y="{{placement.y}}" {{#if tradePrice}}data-trade-price="{{tradePrice}}"{{/if}} style="{{gridStyle}}">
                    <img src="{{img}}" alt="{{name}}">
                    {{#if tradePrice}}<span class="fallout-maw-trade-price">{{tradePrice}}</span>{{/if}}
                    {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                  </article>
                  {{/each}}
                </div>

                {{#each inventory.containers}}
                <section class="fallout-maw-container-section" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-container-id="{{id}}" data-inventory-parent-id="{{id}}">
                  <div class="fallout-maw-panel-header fallout-maw-container-header">
                    <div class="fallout-maw-container-overview {{draggableClass}} fallout-maw-draggable-item" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}">
                      <strong class="fallout-maw-container-overview-name">{{name}}</strong>
                      <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Item.ContainerCurrentLoad'}}">
                        <div class="fallout-maw-load-meter-track">
                          <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
                        </div>
                        <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
                      </div>
                    </div>
                  </div>
                  <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}}" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="--fallout-maw-inventory-columns: {{grid.columns}};">
                    {{#each grid.cells}}
                    <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}} {{#if phantom}}phantom{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actorUuid}}" data-inventory-cell data-inventory-parent-id="{{../id}}" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
                    {{/each}}
                    {{#each grid.items}}
                    <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" {{#if tradePrice}}data-trade-price="{{tradePrice}}"{{/if}} style="{{gridStyle}}">
                      <img src="{{img}}" alt="{{name}}">
                      {{#if tradePrice}}<span class="fallout-maw-trade-price">{{tradePrice}}</span>{{/if}}
                      {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                    </article>
                    {{/each}}
                  </div>
                </section>
                {{/each}}
              </div>
            </section>
          </div>
        </section>
        {{/each}}
      </div>
    </section>
  </div>
</div>
