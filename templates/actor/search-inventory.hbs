<div class="fallout-maw-sheet fallout-maw-search-sheet" data-search-root>
  <header class="fallout-maw-sheet-header fallout-maw-search-header">
    {{#each actors}}
    <section class="fallout-maw-search-actor-title fallout-maw-search-actor-title--{{side}}">
      <div class="fallout-maw-title-display">{{name}}</div>
    </section>
    {{/each}}
    <div class="fallout-maw-search-bulk-controls">
      <button type="button" data-search-bulk-transfer="put" title="Положить все" {{#unless canInteract}}disabled{{/unless}}>
        <img src="icons/svg/chest.svg" alt="Положить все">
      </button>
      <button type="button" data-search-bulk-transfer="take" title="Забрать все" {{#unless canInteract}}disabled{{/unless}}>
        <img src="icons/svg/item-bag.svg" alt="Забрать все">
      </button>
    </div>
  </header>

  <div class="fallout-maw-sheet-body fallout-maw-search-sheet-body">
    {{#unless canInteract}}
    <p class="fallout-maw-empty-list fallout-maw-search-notice">Нет прав на обыскивающего актера.</p>
    {{/unless}}

    <section class="tab active fallout-maw-search-tab" data-tab="inventory">
      <div class="fallout-maw-search-columns">
        {{#each actors}}
        <section class="fallout-maw-search-side fallout-maw-search-side--{{side}}" data-search-actor-uuid="{{uuid}}" data-search-side="{{side}}">
          <section class="fallout-maw-panel fallout-maw-load-panel">
            <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Common.Load'}}">
              <div class="fallout-maw-load-meter-track">
                <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
              </div>
              <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
            </div>
          </section>

          <section class="fallout-maw-inventory-summary">
            <section class="fallout-maw-panel">
              <div class="fallout-maw-currency-list">
                {{#each currencies}}
                <div class="fallout-maw-currency-chip" data-search-currency="{{key}}" data-search-actor-uuid="{{../uuid}}" title="{{label}} | {{localize 'FALLOUTMAW.Common.Value'}}: {{value}}">
                  <span class="fallout-maw-currency-icon">
                    {{#if hasImage}}
                    <img src="{{img}}" alt="{{label}}">
                    {{else}}
                    <span class="fallout-maw-currency-icon-placeholder"></span>
                    {{/if}}
                  </span>
                  <strong class="fallout-maw-currency-amount">{{amount}}</strong>
                </div>
                {{else}}
                <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.Currencies.Empty"}}</p>
                {{/each}}
              </div>
            </section>
          </section>

          <div class="fallout-maw-search-inventory-stack fallout-maw-pane-scroll" data-search-scroll-key="{{side}}:inventory-stack" data-search-drop-zone data-search-actor-uuid="{{uuid}}" data-inventory-parent-id="">
            <section class="fallout-maw-panel fallout-maw-equipment-pane fallout-maw-search-equipment-pane">
              <h2>{{localize "FALLOUTMAW.Common.Equipment"}}</h2>
              <div class="fallout-maw-pane-scroll fallout-maw-equipment-scroll">
                <div class="fallout-maw-equipment-slot-list">
                  {{#each inventory.equipmentSlots}}
                  <div class="fallout-maw-slot-card">
                    <div class="fallout-maw-slot-card-label">{{label}}</div>
                    <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large" data-search-drop-zone data-search-actor-uuid="{{../uuid}}" data-equipment-slot="{{key}}">
                      {{#if item}}
                      <article class="{{item.draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                        <img src="{{item.img}}" alt="{{item.name}}">
                        {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                      </article>
                      {{/if}}
                    </div>
                  </div>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
                  {{/each}}
                </div>

                <h2>{{localize "FALLOUTMAW.Common.Weapon"}}</h2>
                <div class="fallout-maw-weapon-set-list">
                  {{#each inventory.weaponSets}}
                  <section class="fallout-maw-weapon-set">
                    <h3>{{label}}</h3>
                    <div class="fallout-maw-weapon-slot-list">
                      {{#each slots}}
                      <div class="fallout-maw-slot-card">
                        <div class="fallout-maw-slot-card-label">{{label}}</div>
                        <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-weapon-set="{{weaponSetKey}}" data-weapon-slot="{{key}}">
                          {{#if item}}
                          <article class="{{#unless phantom}}{{item.draggableClass}}{{/unless}} fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}}" data-search-actor-uuid="{{item.actorUuid}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                            <img src="{{item.img}}" alt="{{item.name}}">
                            {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                          </article>
                          {{/if}}
                        </div>
                      </div>
                      {{/each}}
                    </div>
                  </section>
                  {{else}}
                  <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
                  {{/each}}
                </div>
              </div>
            </section>

            <section class="fallout-maw-panel fallout-maw-inventory-pane">
              <h2>{{localize "FALLOUTMAW.Common.Inventory"}}</h2>
              <div class="fallout-maw-pane-scroll fallout-maw-inventory-scroll">
                <div class="fallout-maw-inventory-grid" data-search-drop-zone data-search-actor-uuid="{{uuid}}" data-inventory-grid data-inventory-parent-id="" style="--fallout-maw-inventory-columns: {{inventory.grid.columns}};">
                  {{#each inventory.grid.cells}}
                  <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../uuid}}" data-inventory-cell data-inventory-parent-id="" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
                  {{/each}}
                  {{#each inventory.grid.items}}
                  <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                    <img src="{{img}}" alt="{{name}}">
                    {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                  </article>
                  {{/each}}
                </div>

                {{#each inventory.containers}}
                <section class="fallout-maw-container-section" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-container-id="{{id}}" data-inventory-parent-id="{{id}}">
                  <div class="fallout-maw-panel-header fallout-maw-container-header">
                    <div class="fallout-maw-container-overview {{draggableClass}} fallout-maw-draggable-item" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}">
                      <strong class="fallout-maw-container-overview-name">{{name}}</strong>
                      <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Item.ContainerCurrentLoad'}}">
                        <div class="fallout-maw-load-meter-track">
                          <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
                        </div>
                        <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
                      </div>
                    </div>
                  </div>
                  <div class="fallout-maw-inventory-grid" data-search-drop-zone data-search-actor-uuid="{{actorUuid}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="--fallout-maw-inventory-columns: {{grid.columns}};">
                    {{#each grid.cells}}
                    <div class="fallout-maw-inventory-cell {{#if occupied}}occupied{{/if}}" data-search-drop-zone data-search-actor-uuid="{{../actorUuid}}" data-inventory-cell data-inventory-parent-id="{{../id}}" data-x="{{x}}" data-y="{{y}}" style="{{style}}"></div>
                    {{/each}}
                    {{#each grid.items}}
                    <article class="{{draggableClass}} fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if equipped}}equipped{{/if}}" data-search-actor-uuid="{{actorUuid}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                      <img src="{{img}}" alt="{{name}}">
                      {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
                    </article>
                    {{/each}}
                  </div>
                </section>
                {{/each}}
              </div>
            </section>
          </div>
        </section>
        {{/each}}
      </div>
    </section>
  </div>
</div>
