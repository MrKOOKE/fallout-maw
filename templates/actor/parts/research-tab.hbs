<section class="tab {{tabs.research.cssClass}} fallout-maw-research-tab" data-group="{{tabs.research.group}}" data-tab="{{tabs.research.id}}">
  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.OrganismDevelopment.Title"}}</h2>
      <span class="fallout-maw-organism-development-threshold">
        {{localize "FALLOUTMAW.OrganismDevelopment.Threshold"}}: {{organismDevelopment.thresholdLabel}}
      </span>
    </div>

    <div class="fallout-maw-organism-development-list">
      {{#each organismDevelopment.entries}}
      <article class="fallout-maw-organism-development-row">
        <div class="fallout-maw-organism-development-main-header">
          <strong>{{label}}</strong>
        </div>

        <div
          class="fallout-maw-resource-meter fallout-maw-organism-development-progress-bar"
          style="{{meterStyle}}"
          role="meter"
          aria-valuemin="0"
          aria-valuenow="{{progress}}"
          aria-valuemax="{{target}}"
        >
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>

        <div class="fallout-maw-organism-development-meta">
          <span>{{localize "FALLOUTMAW.OrganismDevelopment.Progress"}}: {{progressLabel}} / {{targetLabel}}</span>
        </div>
      </article>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <div class="fallout-maw-panel-header">
      <h2>{{localize "FALLOUTMAW.Research.Title"}}</h2>
      {{#if canManageResearchControls}}
      <button type="button" data-action="createResearch">
        <i class="fa-solid fa-flask"></i>
        {{localize "FALLOUTMAW.Research.Start"}}
      </button>
      {{/if}}
    </div>

    <div class="fallout-maw-research-list">
      {{#each researches}}
      <article class="fallout-maw-research-row{{#if completed}} completed{{/if}}" data-research-id="{{id}}">
        <button type="button" class="fallout-maw-research-main" data-action="openResearchTime">
          {{#if completed}}
          <span class="fallout-maw-research-complete-banner">{{localize "FALLOUTMAW.Research.Completed"}}</span>
          {{/if}}

          <div class="fallout-maw-research-main-header">
            <strong>{{name}}</strong>
            <span>{{skillLabel}}</span>
          </div>

          <div
            class="fallout-maw-resource-meter fallout-maw-research-progress-bar"
            style="{{meterStyle}}"
            role="meter"
            aria-valuemin="0"
            aria-valuenow="{{progress}}"
            aria-valuemax="{{target}}"
          >
            <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
          </div>

          <div class="fallout-maw-research-meta">
            <span>{{localize "FALLOUTMAW.Research.Progress"}}: {{progressLabel}} / {{targetLabel}}</span>
            <span>{{localize "FALLOUTMAW.SkillCheck.Difficulty"}}: {{difficulty}}</span>
            <span>{{localize "FALLOUTMAW.SkillCheck.SkillValue"}}: {{skillValue}}</span>
          </div>
        </button>

        {{#if ../canManageResearchControls}}
        <div class="fallout-maw-research-actions">
          <button
            type="button"
            class="fallout-maw-research-manage"
            data-action="manageResearch"
            title="{{localize 'FALLOUTMAW.Research.Manage'}}"
          >
            <i class="fa-solid fa-gear"></i>
          </button>

          <button
            type="button"
            class="fallout-maw-research-delete"
            data-action="deleteResearch"
            title="{{localize 'Delete'}}"
          >
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
        {{/if}}
      </article>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Research.Empty"}}</p>
      {{/each}}
    </div>
  </section>
</section>
