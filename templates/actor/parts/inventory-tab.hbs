<section class="tab {{tabs.inventory.cssClass}}" data-group="{{tabs.inventory.group}}" data-tab="{{tabs.inventory.id}}">
  {{#if travelGroup.visible}}
  <section class="fallout-maw-panel fallout-maw-travel-group-sheet">
    <h2>Состав путешествия</h2>
    {{#if travelGroup.empty}}
    <p class="fallout-maw-empty-list">В группе нет участников.</p>
    {{else}}
    <div class="fallout-maw-travel-group-sheet-layout">
      {{#if travelGroup.hasWalkers}}
      <section class="fallout-maw-travel-group-walkers">
        <h3>Пешие участники</h3>
        <div class="fallout-maw-travel-group-walker-list">
          {{#each travelGroup.walkers}}
          <article class="fallout-maw-travel-group-walker {{#if missing}}missing{{/if}}" title="{{name}}">
            <img src="{{img}}" alt="{{name}}">
            <strong>{{name}}</strong>
          </article>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if travelGroup.hasVehicles}}
      <section class="fallout-maw-travel-group-vehicles">
        {{#each travelGroup.vehicles}}
        <article class="fallout-maw-travel-group-vehicle {{#if missing}}missing{{/if}}">
          <header class="fallout-maw-travel-group-vehicle-header">
            <img src="{{img}}" alt="{{name}}">
            <strong>{{name}}</strong>
          </header>
          <div class="fallout-maw-travel-group-vehicle-body">
            {{#if hasSeats}}
            {{#each seatGroups}}
            <div class="fallout-maw-actor-container-group fallout-maw-travel-group-seat-group">
              <h3>{{name}}</h3>
              {{#each rows}}
              <div class="fallout-maw-actor-container-row fallout-maw-travel-group-seat-row">
                {{#each instances}}
                <div class="fallout-maw-inventory-grid fallout-maw-actor-container-grid fallout-maw-travel-group-grid" data-actor-container-grid data-travel-unit-id="{{../../../../id}}" data-vehicle-actor-uuid="{{../../../../actorUuid}}" data-slot-id="{{slotId}}" data-slot-index="{{slotIndex}}" style="{{style}}">
                  {{#each passengers}}
                  <article class="draggable fallout-maw-inventory-item fallout-maw-inventory-grid-item fallout-maw-actor-container-passenger fallout-maw-travel-group-passenger equipped" data-actor-container-passenger data-travel-unit-id="{{../../../../id}}" data-vehicle-actor-uuid="{{../../../../actorUuid}}" data-passenger-id="{{id}}" title="{{actorName}}" style="{{gridStyle}}">
                    <img src="{{actorImg}}" alt="{{actorName}}">
                  </article>
                  {{/each}}
                </div>
                {{/each}}
              </div>
              {{/each}}
            </div>
            {{/each}}
            {{else}}
            <p class="fallout-maw-empty-list">У транспорта нет настроенных мест.</p>
            {{/if}}
          </div>
        </article>
        {{/each}}
      </section>
      {{/if}}
    </div>
    {{/if}}
  </section>
  {{else}}
  <section class="fallout-maw-inventory-summary">
    <section class="fallout-maw-panel">
      <h2>{{localize "FALLOUTMAW.Common.Currencies"}}</h2>
      <div class="fallout-maw-currency-list">
        {{#each currencies}}
        <div class="fallout-maw-currency-chip" title="{{label}} | {{localize 'FALLOUTMAW.Common.Value'}}: {{value}}">
          <span class="fallout-maw-currency-icon">
            {{#if hasImage}}
            <img src="{{img}}" alt="{{label}}">
            {{else}}
            <span class="fallout-maw-currency-icon-placeholder"></span>
            {{/if}}
          </span>
          {{#if ../freeEdit}}<input class="fallout-maw-currency-amount-input" type="number" name="system.currencies.{{key}}" value="{{amount}}" min="0" step="1">{{else}}<strong class="fallout-maw-currency-amount">{{amount}}</strong>{{/if}}
        </div>
        {{else}}
        <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.Currencies.Empty"}}</p>
        {{/each}}
      </div>
    </section>
  </section>
  <div class="fallout-maw-inventory-layout" data-inventory-drop-surface data-inventory-parent-id="">
    <section class="fallout-maw-panel fallout-maw-equipment-pane" data-equipment-drop-surface>
      <h2>{{inventory.equipmentHeading}}</h2>
      <div class="fallout-maw-pane-scroll fallout-maw-equipment-scroll" data-scroll-key="equipment">
        <div class="fallout-maw-equipment-slot-list">
          {{#each inventory.equipmentSlots}}
          <div class="fallout-maw-slot-card">
            <div class="fallout-maw-slot-card-label" {{#if fullLabel}}title="{{fullLabel}}"{{/if}}>{{label}}</div>
            <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large {{#if locked}}locked{{/if}} {{#if (eq item.occupiedSlotMode "oneOf")}}one-of{{/if}}" data-equipment-slot="{{key}}" {{#unless locked}}data-drop-zone{{/unless}}>
              {{#if item}}
              <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                {{#if item.showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{item.firstAidCharges.value}}/{{item.firstAidCharges.max}}</span>{{/if}}
                {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
              </article>
              {{/if}}
            </div>
          </div>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoEquipmentSlots"}}</p>
          {{/each}}
        </div>

        {{#if inventory.prosthesisSlots.length}}
        <h2>Протезы</h2>
        <div class="fallout-maw-equipment-slot-list fallout-maw-prosthesis-slot-list">
          {{#each inventory.prosthesisSlots}}
          <div class="fallout-maw-slot-card">
            <div class="fallout-maw-slot-card-label">{{label}}</div>
            <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-prosthesis-slot" data-prosthesis-limb="{{key}}">
              <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item equipped {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                {{#if item.showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{item.firstAidCharges.value}}/{{item.firstAidCharges.max}}</span>{{/if}}
                {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
              </article>
            </div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if inventory.implantSlots.length}}
        <h2>Импланты</h2>
        <div class="fallout-maw-equipment-slot-list fallout-maw-implant-slot-list">
          {{#each inventory.implantSlots}}
          <div class="fallout-maw-slot-card">
            <div class="fallout-maw-slot-card-label">{{label}}</div>
            <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-implant-slot" data-implant-limb="{{limbKey}}">
              <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item equipped {{#if item.locked}}locked{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                {{#if item.showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{item.firstAidCharges.value}}/{{item.firstAidCharges.max}}</span>{{/if}}
                {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
              </article>
            </div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        <h2>{{localize "FALLOUTMAW.Common.Weapon"}}</h2>
        <div class="fallout-maw-weapon-set-list">
          {{#if inventory.naturalWeaponSet}}
          <section class="fallout-maw-weapon-set fallout-maw-natural-weapon-set {{#if inventory.naturalWeaponSet.active}}active{{/if}}" data-action="selectHudWeaponSet" data-weapon-set="{{inventory.naturalWeaponSet.key}}" role="button" tabindex="0" aria-pressed="{{inventory.naturalWeaponSet.active}}" title="{{inventory.naturalWeaponSet.label}}">
            <h3>{{inventory.naturalWeaponSet.label}}</h3>
            <div class="fallout-maw-weapon-slot-list">
              {{#each inventory.naturalWeaponSet.slots}}
              <div class="fallout-maw-slot-card">
                <div class="fallout-maw-slot-card-label">{{label}}</div>
                <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot fallout-maw-natural-weapon-slot" data-natural-weapon-slot="{{key}}">
                  {{#if item}}
                  <article class="fallout-maw-inventory-item fallout-maw-draggable-item equipped {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                  </article>
                  {{/if}}
                </div>
              </div>
              {{/each}}
            </div>
          </section>
          {{/if}}
          {{#each inventory.weaponSets}}
          <section class="fallout-maw-weapon-set {{#if active}}active{{/if}}" data-action="selectHudWeaponSet" data-weapon-set="{{key}}" role="button" tabindex="0" aria-pressed="{{active}}" title="{{label}}">
            <h3>{{label}}</h3>
            <div class="fallout-maw-weapon-slot-list">
              {{#each slots}}
              <div class="fallout-maw-slot-card">
                <div class="fallout-maw-slot-card-label">{{label}}</div>
                <div class="fallout-maw-equipment-slot fallout-maw-equipment-slot--large fallout-maw-weapon-slot" data-weapon-set="{{../key}}" data-weapon-slot="{{key}}" data-drop-zone>
                  {{#if item}}
                  {{#if phantom}}
                  <article class="fallout-maw-inventory-item fallout-maw-draggable-item phantom {{#if useDisabled}}unusable{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                    {{#if item.showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{item.firstAidCharges.value}}/{{item.firstAidCharges.max}}</span>{{/if}}
                    {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                  </article>
                  {{else}}
                  <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item {{#if item.equipped}}equipped{{/if}} {{#if item.locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if useDisabled}}unusable{{/if}} {{#if item.brokenCondition}}broken-condition{{/if}}{{#if item.interactionToggleable}} toggleable{{/if}}{{#if item.interactionToggled}} toggled{{/if}}" data-item-id="{{item.id}}" data-tooltip-item="{{item.id}}">
                    <img src="{{item.img}}" alt="{{item.name}}">
                    {{#if item.showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{item.firstAidCharges.value}}/{{item.firstAidCharges.max}}</span>{{/if}}
                    {{#if item.showQuantity}}<strong>{{item.quantity}}</strong>{{/if}}
                  </article>
                  {{/if}}
                  {{/if}}
                </div>
              </div>
              {{/each}}
            </div>
          </section>
          {{else}}
          <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Settings.CreatureOptions.NoWeaponSets"}}</p>
          {{/each}}
        </div>
      </div>
    </section>

    <div class="fallout-maw-inventory-main-column">
      <section class="fallout-maw-panel fallout-maw-load-panel">
        <h2>{{localize "FALLOUTMAW.Common.Load"}}</h2>
        <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Common.Load'}}">
          <div class="fallout-maw-load-meter-track">
            <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
          </div>
          <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
        </div>
      </section>

      {{#if inventory.actorContainers.visible}}
      <section class="fallout-maw-panel fallout-maw-actor-container-section">
        <h2>Пассажирские места</h2>
        {{#each inventory.actorContainers.groups}}
        <div class="fallout-maw-actor-container-group">
          <h3>{{name}}</h3>
          {{#each rows}}
          <div class="fallout-maw-actor-container-row">
            {{#each instances}}
            <div class="fallout-maw-inventory-grid fallout-maw-actor-container-grid" data-actor-container-grid data-slot-id="{{slotId}}" data-slot-index="{{slotIndex}}" style="{{style}}">
              {{#each passengers}}
              <article class="draggable fallout-maw-inventory-item fallout-maw-inventory-grid-item fallout-maw-actor-container-passenger equipped" data-actor-container-passenger data-passenger-id="{{id}}" title="{{actorName}}" style="{{gridStyle}}">
                <img src="{{actorImg}}" alt="{{actorName}}">
              </article>
              {{/each}}
            </div>
            {{/each}}
          </div>
          {{/each}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      {{#with inventory.butcheringStorage}}
      {{#if grid.items.length}}
      <section class="fallout-maw-panel fallout-maw-butchering-storage-section">
        <h2>Разделка</h2>
        <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="{{grid.style}}">
          {{#each grid.items}}
          <article class="fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if placement.rotated}}rotated{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
            <img src="{{img}}" alt="{{name}}">
            {{#if showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</span>{{/if}}
            {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
          </article>
          {{/each}}
        </div>
      </section>
      {{/if}}
      {{/with}}

      <section class="fallout-maw-panel fallout-maw-inventory-pane">
        <div class="fallout-maw-panel-header fallout-maw-inventory-pane-header">
          <h2>{{localize "FALLOUTMAW.Common.Inventory"}}</h2>
          {{#if freeEdit}}
          <button type="button" class="fallout-maw-inventory-clear-button" data-action="clearInventory" title="{{localize 'FALLOUTMAW.Actor.ClearInventoryTitle'}}" aria-label="{{localize 'FALLOUTMAW.Actor.ClearInventoryTitle'}}">
            <i class="fa-solid fa-trash"></i>
          </button>
          {{/if}}
        </div>
        <div class="fallout-maw-pane-scroll fallout-maw-inventory-scroll" data-scroll-key="inventory">
          <div class="fallout-maw-inventory-grid {{#if inventory.grid.hasPhantomItems}}has-phantom-items{{/if}}" data-inventory-grid data-inventory-parent-id="" style="{{inventory.grid.style}}">
            {{#each inventory.grid.items}}
            <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if placement.rotated}}rotated{{/if}} {{#if equipped}}equipped{{/if}} {{#if locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
              <img src="{{img}}" alt="{{name}}">
              {{#if showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</span>{{/if}}
              {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
            </article>
            {{/each}}
          </div>

          {{#each inventory.containers}}
          <section class="fallout-maw-container-section" data-container-drop-surface data-container-id="{{id}}" data-inventory-parent-id="{{id}}">
            <div class="fallout-maw-panel-header fallout-maw-container-header">
              <div class="fallout-maw-container-overview draggable fallout-maw-draggable-item{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-item-id="{{id}}" data-tooltip-item="{{id}}">
                <strong class="fallout-maw-container-overview-name">{{name}}</strong>
                <div class="fallout-maw-load-meter fallout-maw-load-meter--{{load.trend}} fallout-maw-load-meter--{{load.state}}" aria-label="{{localize 'FALLOUTMAW.Item.ContainerCurrentLoad'}}">
                  <div class="fallout-maw-load-meter-track">
                    <div class="fallout-maw-load-meter-fill" style="width: {{load.percent}}%;"></div>
                  </div>
                  <strong class="fallout-maw-load-meter-value">{{load.value}} / {{load.max}} {{localize "FALLOUTMAW.Common.Kg"}}</strong>
                </div>
              </div>
            </div>
            <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="{{grid.style}}">
              {{#each grid.items}}
              <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item {{#if placement.rotated}}rotated{{/if}} {{#if equipped}}equipped{{/if}} {{#if locked}}locked{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                <img src="{{img}}" alt="{{name}}">
                {{#if showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</span>{{/if}}
                {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
              </article>
              {{/each}}
            </div>
          </section>
          {{/each}}

          {{#with inventory.lockedStorage}}
          {{#if grid.items.length}}
          <section class="fallout-maw-container-section fallout-maw-locked-storage-section">
            <div class="fallout-maw-panel-header fallout-maw-container-header">
              <div class="fallout-maw-container-overview">
                <strong class="fallout-maw-container-overview-name">{{localize "FALLOUTMAW.Common.Locked"}}</strong>
              </div>
            </div>
            <div class="fallout-maw-inventory-grid {{#if grid.hasPhantomItems}}has-phantom-items{{/if}}" data-inventory-grid data-inventory-parent-id="{{id}}" style="{{grid.style}}">
              {{#each grid.items}}
              <article class="draggable fallout-maw-inventory-item fallout-maw-draggable-item fallout-maw-inventory-grid-item locked {{#if placement.rotated}}rotated{{/if}} {{#if phantom}}phantom{{/if}} {{#if brokenCondition}}broken-condition{{/if}}{{#if interactionToggleable}} toggleable{{/if}}{{#if interactionToggled}} toggled{{/if}}" data-item-id="{{id}}" data-tooltip-item="{{id}}" data-inventory-grid-item data-inventory-parent-id="{{../id}}" data-x="{{placement.x}}" data-y="{{placement.y}}" style="{{gridStyle}}">
                <img src="{{img}}" alt="{{name}}">
                {{#if showFirstAidCharges}}<span class="fallout-maw-inventory-item-charges">{{firstAidCharges.value}}/{{firstAidCharges.max}}</span>{{/if}}
                {{#if showQuantity}}<strong>{{quantity}}</strong>{{/if}}
              </article>
              {{/each}}
            </div>
          </section>
          {{/if}}
          {{/with}}
        </div>
      </section>
    </div>
  </div>
  {{/if}}
</section>
