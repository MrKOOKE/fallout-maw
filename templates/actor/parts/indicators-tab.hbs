<section class="tab {{tabs.indicators.cssClass}}" data-group="{{tabs.indicators.group}}" data-tab="{{tabs.indicators.id}}">
  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Resources"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each resources}}
      <label class="fallout-maw-resource-card">
        <span class="fallout-maw-resource-name">{{label}}:</span>
        <span class="fallout-maw-resource-value">
          {{#if ../freeEdit}}<input type="number" name="system.resources.{{key}}.value" value="{{value}}">{{else}}<strong>{{value}}</strong>{{/if}}
          <span class="fallout-maw-resource-max">/ {{max}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Needs"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each needs}}
      <label class="fallout-maw-resource-card">
        <span class="fallout-maw-resource-name">{{label}}:</span>
        <span class="fallout-maw-resource-value">
          {{#if ../freeEdit}}<input type="number" name="system.needs.{{key}}.value" value="{{value}}">{{else}}<strong>{{value}}</strong>{{/if}}
          <span class="fallout-maw-resource-max">/ {{max}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Limbs"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each limbs}}
      <label class="fallout-maw-resource-card">
        <span class="fallout-maw-resource-name">{{label}}:</span>
        <span class="fallout-maw-resource-value">
          {{#if ../freeEdit}}<input type="number" name="system.limbs.{{key}}.value" value="{{value}}" min="0" max="{{max}}">{{else}}<strong>{{value}}</strong>{{/if}}
          <span class="fallout-maw-resource-max">/ {{max}}</span>
        </span>
      </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.DamageResistances"}}</h2>
    <div class="fallout-maw-summary-grid three-columns">
      {{#each damageResistances}}
      <div class="fallout-maw-inline-stat">
        <span>{{label}}:</span>
        <strong>{{value}}</strong>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Actor.Progression"}}</h2>
    <div class="fallout-maw-summary-grid two-columns">
      <label class="fallout-maw-inline-stat">
        <span>{{localize "FALLOUTMAW.Actor.SkillPointsPerLevel"}}:</span>
        {{#if freeEdit}}
        <input type="number" name="system.progression.skillPointsPerLevel" value="{{system.progression.skillPointsPerLevel}}" {{editLockAttribute}}>
        {{else}}
        <strong>{{system.progression.skillPointsPerLevel}}</strong>
        {{/if}}
      </label>
      <label class="fallout-maw-inline-stat">
        <span>{{localize "FALLOUTMAW.Actor.ResearchPointsPerLevel"}}:</span>
        {{#if freeEdit}}
        <input type="number" name="system.progression.researchPointsPerLevel" value="{{system.progression.researchPointsPerLevel}}" {{editLockAttribute}}>
        {{else}}
        <strong>{{system.progression.researchPointsPerLevel}}</strong>
        {{/if}}
      </label>
    </div>
  </section>
</section>
