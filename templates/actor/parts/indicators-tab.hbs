<section class="tab {{tabs.indicators.cssClass}}" data-group="{{tabs.indicators.group}}" data-tab="{{tabs.indicators.id}}">
  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Resources"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each resources}}
      <div class="fallout-maw-resource-card fallout-maw-resource-meter-card">
        <div class="fallout-maw-resource-card-header">
          <span class="fallout-maw-resource-name">{{label}}</span>
          <span class="fallout-maw-resource-value">
            {{#if ../freeEdit}}<input type="number" name="{{inputName}}" value="{{value}}" min="{{min}}" max="{{max}}">{{else}}<strong>{{value}}</strong>{{/if}}
            <span class="fallout-maw-resource-max">/ {{max}}</span>
          </span>
        </div>
        <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Needs"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each needs}}
      <div class="fallout-maw-resource-card fallout-maw-resource-meter-card">
        <div class="fallout-maw-resource-card-header">
          <span class="fallout-maw-resource-name">{{label}}</span>
          <span class="fallout-maw-resource-value">
            {{#if ../freeEdit}}<input type="number" name="{{inputName}}" value="{{value}}" min="{{min}}" max="{{max}}">{{else}}<strong>{{value}}</strong>{{/if}}
            <span class="fallout-maw-resource-max">/ {{max}}</span>
          </span>
        </div>
        <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{#if limbSilhouette.visible}}
  <div class="fallout-maw-limb-trauma-layout">
    <section class="fallout-maw-panel fallout-maw-limb-silhouette-section">
      <h2>{{localize "FALLOUTMAW.Common.Limbs"}}</h2>
      <svg class="fallout-maw-actor-limb-silhouette" viewBox="{{limbSilhouette.viewBox}}" role="img" aria-label="{{localize 'FALLOUTMAW.Common.Limbs'}}">
        {{#each limbSilhouette.parts}}
        <path class="fallout-maw-actor-limb-silhouette-part{{#if active}} active{{/if}}" d="{{d}}" fill="{{fill}}" data-limb-control-card data-limb-key="{{limbKey}}" role="button" tabindex="0"></path>
        {{/each}}
        {{#each limbSilhouette.outline}}
        <path class="fallout-maw-actor-limb-silhouette-outline" d="{{d}}"></path>
        {{/each}}
      </svg>
    </section>

    <section class="fallout-maw-panel fallout-maw-trauma-inline-section">
      <h2>{{localize "FALLOUTMAW.Common.Traumas"}}</h2>
      <div class="fallout-maw-trauma-list">
        {{#each traumas}}
        <article class="fallout-maw-trauma-row" data-trauma-id="{{id}}">
          <div class="fallout-maw-trauma-title">
            <img src="{{img}}" alt="{{name}}">
            <div class="fallout-maw-trauma-summary">
              <strong>{{name}}</strong>
              {{#each sources}}
              <span>{{summary}}</span>
              {{/each}}
            </div>
          </div>
          <div class="fallout-maw-trauma-treatment">
            <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}: <strong>{{healingDifficulty}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}: <strong>{{healingToolClass}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}: <strong>{{healingProgress}} / {{healingProgressMax}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}: <strong>{{healingSkillLabel}}</strong></span>
          </div>
          <div class="fallout-maw-trauma-effects">
            {{#each effects}}
            <span title="{{title}}">{{summary}}</span>
            {{else}}
            <span>{{localize "FALLOUTMAW.Effects.NoChanges"}}</span>
            {{/each}}
          </div>
          {{#if ../freeEdit}}
          <button type="button" data-action="deleteTrauma" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          {{/if}}
        </article>
        {{else}}
        <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Actor.NoTraumas"}}</p>
        {{/each}}
      </div>
    </section>

    <section class="fallout-maw-panel fallout-maw-disease-inline-section">
      <h2>{{localize "FALLOUTMAW.Common.Diseases"}}</h2>
      <div class="fallout-maw-trauma-list fallout-maw-disease-list">
        {{#each diseases}}
        <article class="fallout-maw-trauma-row fallout-maw-disease-row" data-disease-id="{{id}}">
          <div class="fallout-maw-trauma-title">
            <img src="{{img}}" alt="{{name}}">
            <div class="fallout-maw-trauma-summary">
              <strong>{{name}}</strong>
              <span>{{stageLabel}}</span>
              <span>Прогресс усугубления: {{worseningProgressLabel}} / {{worseningProgressMax}}</span>
              <span>Множитель: {{worseningMultiplierLabel}}x</span>
              <span>Расчетное до: {{worseningHoursLeftLabel}} ч</span>
            </div>
          </div>
          <div class="fallout-maw-trauma-treatment">
            <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}: <strong>{{healingDifficulty}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}: <strong>{{healingToolClass}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}: <strong>{{healingProgress}} / {{healingProgressMax}}</strong></span>
            <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}: <strong>{{healingSkillLabel}}</strong></span>
          </div>
          <div class="fallout-maw-trauma-effects">
            {{#each effects}}
            <span title="{{title}}">{{summary}}</span>
            {{else}}
            <span>{{localize "FALLOUTMAW.Effects.NoChanges"}}</span>
            {{/each}}
          </div>
          {{#if ../freeEdit}}
          <button type="button" data-action="deleteDisease" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
          {{/if}}
        </article>
        {{else}}
        <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Actor.NoDiseases"}}</p>
        {{/each}}
      </div>
    </section>
  </div>
  {{else}}
  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Limbs"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each limbs}}
      <div class="fallout-maw-resource-card fallout-maw-resource-meter-card{{#if active}} active{{/if}}" data-limb-control-card data-limb-key="{{key}}" role="button" tabindex="0">
        <div class="fallout-maw-resource-card-header">
          <button
            type="button"
            class="fallout-maw-resource-name fallout-maw-limb-select"
            data-action="selectLimb"
            data-limb-key="{{key}}"
          >{{label}}</button>
          <span class="fallout-maw-resource-value">
            {{#if ../freeEdit}}<input type="number" name="{{inputName}}" value="{{value}}" min="{{min}}" max="{{max}}">{{else}}<strong>{{value}}</strong>{{/if}}
            <span class="fallout-maw-resource-max">/ {{max}}</span>
          </span>
        </div>
        <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Traumas"}}</h2>
    <div class="fallout-maw-trauma-list">
      {{#each traumas}}
      <article class="fallout-maw-trauma-row" data-trauma-id="{{id}}">
        <div class="fallout-maw-trauma-title">
          <img src="{{img}}" alt="{{name}}">
          <div class="fallout-maw-trauma-summary">
            <strong>{{name}}</strong>
            {{#each sources}}
            <span>{{summary}}</span>
            {{/each}}
          </div>
        </div>
        <div class="fallout-maw-trauma-treatment">
          <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}: <strong>{{healingDifficulty}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}: <strong>{{healingToolClass}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}: <strong>{{healingProgress}} / {{healingProgressMax}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}: <strong>{{healingSkillLabel}}</strong></span>
        </div>
        <div class="fallout-maw-trauma-effects">
          {{#each effects}}
          <span title="{{title}}">{{summary}}</span>
          {{else}}
          <span>{{localize "FALLOUTMAW.Effects.NoChanges"}}</span>
          {{/each}}
        </div>
        {{#if ../freeEdit}}
        <button type="button" data-action="deleteTrauma" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
        {{/if}}
      </article>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Actor.NoTraumas"}}</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Diseases"}}</h2>
    <div class="fallout-maw-trauma-list fallout-maw-disease-list">
      {{#each diseases}}
      <article class="fallout-maw-trauma-row fallout-maw-disease-row" data-disease-id="{{id}}">
        <div class="fallout-maw-trauma-title">
          <img src="{{img}}" alt="{{name}}">
          <div class="fallout-maw-trauma-summary">
            <strong>{{name}}</strong>
            <span>{{stageLabel}}</span>
            <span>Прогресс усугубления: {{worseningProgressLabel}} / {{worseningProgressMax}}</span>
            <span>Множитель: {{worseningMultiplierLabel}}x</span>
            <span>Расчетное до: {{worseningHoursLeftLabel}} ч</span>
          </div>
        </div>
        <div class="fallout-maw-trauma-treatment">
          <span>{{localize "FALLOUTMAW.Trauma.HealingDifficulty"}}: <strong>{{healingDifficulty}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingToolClass"}}: <strong>{{healingToolClass}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingProgress"}}: <strong>{{healingProgress}} / {{healingProgressMax}}</strong></span>
          <span>{{localize "FALLOUTMAW.Trauma.HealingSkill"}}: <strong>{{healingSkillLabel}}</strong></span>
        </div>
        <div class="fallout-maw-trauma-effects">
          {{#each effects}}
          <span title="{{title}}">{{summary}}</span>
          {{else}}
          <span>{{localize "FALLOUTMAW.Effects.NoChanges"}}</span>
          {{/each}}
        </div>
        {{#if ../freeEdit}}
        <button type="button" data-action="deleteDisease" title="{{localize 'FALLOUTMAW.Common.Delete'}}"><i class="fa-solid fa-trash"></i></button>
        {{/if}}
      </article>
      {{else}}
      <p class="fallout-maw-empty-list">{{localize "FALLOUTMAW.Actor.NoDiseases"}}</p>
      {{/each}}
    </div>
  </section>
  {{/if}}

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.DamageResistances"}}{{#if activeLimb}} - {{activeLimb.label}}{{/if}}</h2>
    <div class="fallout-maw-summary-grid six-columns">
      {{#each damageResistances}}
      <div class="fallout-maw-inline-stat">
        <span>{{label}}:</span>
        <strong>{{value}}</strong>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.DamageDefenses"}}{{#if activeLimb}} - {{activeLimb.label}}{{/if}}</h2>
    <div class="fallout-maw-summary-grid six-columns">
      {{#each damageDefenses}}
      <div class="fallout-maw-inline-stat">
        <span>{{label}}:</span>
        <strong>{{value}}</strong>
      </div>
      {{/each}}
    </div>
  </section>
</section>
