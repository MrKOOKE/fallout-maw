<section class="tab {{tabs.identity.cssClass}}" data-group="{{tabs.identity.group}}" data-tab="{{tabs.identity.id}}">
  <header class="sheet-header fallout-maw-sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-field="img" title="{{actor.name}}" height="96" width="96">
    <div class="fallout-maw-header-fields">
      {{#if freeEdit}}
      <input class="fallout-maw-title-input" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
      {{else}}
      <div class="fallout-maw-title-display">{{actor.name}}</div>
      {{/if}}
      <div class="fallout-maw-header-grid">
        <div class="fallout-maw-header-meta">
          <div class="fallout-maw-header-meta-row">
            <label class="fallout-maw-header-stat">
              <span>{{localize "FALLOUTMAW.Actor.CreatureType"}}:</span>
              {{#if freeEdit}}
              <select name="system.creature.typeId" data-creature-type-select>
                <option value="">{{localize "FALLOUTMAW.Actor.NoCreatureType"}}</option>
                {{#each creatureTypes}}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
              {{else}}
              <strong>{{creatureTypeName}}</strong>
              {{/if}}
            </label>
            <label class="fallout-maw-header-stat fallout-maw-level-field">
              <span>{{localize "FALLOUTMAW.Actor.Level"}}:</span>
              {{#if freeEdit}}
              <input type="number" name="system.attributes.level" value="{{system.attributes.level}}" min="1">
              {{else}}
              <strong>{{system.attributes.level}}</strong>
              {{/if}}
            </label>
          </div>
          <div class="fallout-maw-header-meta-row">
            <label class="fallout-maw-header-stat">
              <span>{{localize "FALLOUTMAW.Actor.Race"}}:</span>
              {{#if freeEdit}}
              <select name="system.creature.raceId" data-creature-race-select>
                <option value="">{{localize "FALLOUTMAW.Actor.NoRace"}}</option>
                {{#each creatureRaces}}
                <option value="{{id}}" data-type-id="{{typeId}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
              {{else}}
              <strong>{{creatureRaceName}}</strong>
              {{/if}}
            </label>
            <div class="fallout-maw-header-stat fallout-maw-header-experience-field">
              <span>{{localize "FALLOUTMAW.Advancement.Experience"}}:</span>
              <div class="fallout-maw-header-experience-stack">
                {{#if freeEdit}}
                <span class="fallout-maw-header-experience-edit">
                  <input type="number" name="system.development.experience" value="{{system.development.experience}}" min="0">
                  <strong>/ {{progressionExperienceNext}}</strong>
                </span>
                {{else}}
                <strong>{{progressionExperienceDisplay}}</strong>
                {{/if}}
                <div class="fallout-maw-load-meter fallout-maw-load-meter--positive fallout-maw-load-meter--normal" aria-label="{{localize 'FALLOUTMAW.Advancement.Experience'}}">
                  <div class="fallout-maw-load-meter-track">
                    <div class="fallout-maw-load-meter-fill" style="width: {{progressionExperiencePercent}}%;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="fallout-maw-header-actions">
          <button
            type="button"
            class="fallout-maw-development-button"
            data-action="openDevelopment"
            title="{{localize 'FALLOUTMAW.Advancement.Title'}}"
            aria-label="{{localize 'FALLOUTMAW.Advancement.Title'}}"
          >
            <i class="fa-solid fa-star"></i>
          </button>
          <button
            type="button"
            class="fallout-maw-toggle-edit"
            data-action="toggleFreeEdit"
            title="{{#if freeEdit}}{{localize 'FALLOUTMAW.Actor.LockCoreFields'}}{{else}}{{localize 'FALLOUTMAW.Actor.UnlockCoreFields'}}{{/if}}"
            aria-label="{{#if freeEdit}}{{localize 'FALLOUTMAW.Actor.LockCoreFields'}}{{else}}{{localize 'FALLOUTMAW.Actor.UnlockCoreFields'}}{{/if}}"
          >
            {{#if freeEdit}}
            <i class="fa-solid fa-lock-open"></i>
            {{else}}
            <i class="fa-solid fa-lock"></i>
            {{/if}}
          </button>
        </div>
      </div>
    </div>
  </header>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Characteristics"}}</h2>
    <div class="fallout-maw-characteristic-grid">
      {{#each characteristics}}
      <label>
        <span title="{{abbr}} / {{key}}">{{label}}</span>
        {{#if ../freeEdit}}
        <input type="number" name="system.characteristics.{{key}}" value="{{sourceValue}}">
        {{else}}
        <strong>{{value}}</strong>
        {{/if}}
      </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Skills"}}</h2>
    <div class="fallout-maw-identity-skill-grid">
      {{#each skills}}
      <button type="button" class="fallout-maw-identity-skill fallout-maw-identity-skill-button" data-action="rollSkill" data-skill-key="{{key}}">
        <span>{{label}}</span>
        <strong>{{value}}</strong>
      </button>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Proficiencies"}}</h2>
    <div class="fallout-maw-identity-skill-grid">
      {{#each proficiencies}}
      <div class="fallout-maw-identity-skill">
        <span>{{label}}</span>
        <strong>{{value}} / {{max}}</strong>
      </div>
      {{/each}}
    </div>
  </section>
</section>
