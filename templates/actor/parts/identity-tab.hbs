<section class="tab {{tabs.identity.cssClass}}" data-group="{{tabs.identity.group}}" data-tab="{{tabs.identity.id}}">
  <header class="sheet-header fallout-maw-sheet-header">
    <img class="profile-img{{#if freeEdit}} fallout-maw-profile-img-editable{{/if}}" src="{{actor.img}}" {{#if freeEdit}}data-action="editActorImage" data-edit="img"{{/if}} title="{{actor.name}}" height="96" width="96">
    <div class="fallout-maw-header-fields">
      {{#if freeEdit}}
      <input class="fallout-maw-title-input" data-actor-name-input type="text" value="{{actorName}}" placeholder="{{localize 'DOCUMENT.FIELDS.name.label'}}">
      {{else}}
      <div class="fallout-maw-title-display">{{actor.name}}</div>
      {{/if}}
      <div class="fallout-maw-header-grid">
        <div class="fallout-maw-header-meta">
          <div class="fallout-maw-header-meta-row">
            {{#unless isConstruct}}
            <label class="fallout-maw-header-stat fallout-maw-header-creature-field">
              <span>{{localize "FALLOUTMAW.Actor.CreatureType"}} / {{localize "FALLOUTMAW.Actor.Race"}} / {{localize "FALLOUTMAW.Actor.Subtype"}}:</span>
              {{#if freeEdit}}
              <span class="fallout-maw-header-creature-selects">
              <select name="system.creature.typeId" data-creature-type-select>
                <option value="">{{localize "FALLOUTMAW.Actor.NoCreatureType"}}</option>
                {{#each creatureTypes}}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
              <select name="system.creature.raceId" data-creature-race-select>
                <option value="">{{localize "FALLOUTMAW.Actor.NoRace"}}</option>
                {{#each creatureRaces}}
                <option value="{{id}}" data-type-id="{{typeId}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
              <select name="system.creature.subtypeId" data-creature-subtype-select>
                <option value="">{{localize "FALLOUTMAW.Actor.NoSubtype"}}</option>
                {{#each creatureSubtypes}}
                <option value="{{id}}" data-race-id="{{raceId}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              </span>
              {{else}}
              <strong>{{creatureTypeName}} / {{creatureRaceName}} / {{creatureSubtypeName}}</strong>
              {{/if}}
            </label>
            {{/unless}}
            <label class="fallout-maw-header-stat fallout-maw-level-field">
              <span>{{localize "FALLOUTMAW.Actor.Level"}}:</span>
              {{#if freeEdit}}
              <input type="number" name="system.attributes.level" value="{{system.attributes.level}}" min="1">
              {{else}}
              <strong>{{system.attributes.level}}</strong>
              {{/if}}
            </label>
          </div>
          <div class="fallout-maw-header-meta-row">
            <label class="fallout-maw-header-stat">
              <span>{{localize "FALLOUTMAW.Actor.Initiative"}}:</span>
              <strong>{{system.attributes.initiative}}</strong>
            </label>
            <div class="fallout-maw-header-stat fallout-maw-header-experience-field">
              <span>{{localize "FALLOUTMAW.Advancement.Experience"}}:</span>
              <div class="fallout-maw-header-experience-stack">
                {{#if freeEdit}}
                <span class="fallout-maw-header-experience-edit">
                  <input type="number" name="system.development.experience" value="{{system.development.experience}}" min="0">
                  <strong>/ {{progressionExperienceNext}}</strong>
                </span>
                {{else}}
                <strong>{{progressionExperienceDisplay}}</strong>
                {{/if}}
                <div class="fallout-maw-load-meter fallout-maw-load-meter--positive fallout-maw-load-meter--normal" aria-label="{{localize 'FALLOUTMAW.Advancement.Experience'}}">
                  <div class="fallout-maw-load-meter-track">
                    <div class="fallout-maw-load-meter-fill" style="width: {{progressionExperiencePercent}}%;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="fallout-maw-header-actions">
          <button
            type="button"
            class="fallout-maw-development-button"
            data-action="openDevelopment"
            title="{{localize 'FALLOUTMAW.Advancement.Title'}}"
            aria-label="{{localize 'FALLOUTMAW.Advancement.Title'}}"
          >
            <i class="fa-solid fa-star"></i>
          </button>
        </div>
      </div>
    </div>
  </header>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Characteristics"}}</h2>
    <div class="fallout-maw-characteristic-grid">
      {{#each characteristics}}
      <label>
        <span title="{{abbr}} / {{key}}">{{label}}</span>
        {{#if ../freeEdit}}
        <input type="number" name="system.characteristics.{{key}}" value="{{sourceValue}}">
        {{else}}
        <strong>{{value}}</strong>
        {{/if}}
      </label>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Skills"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each skills}}
      <div class="fallout-maw-resource-card fallout-maw-resource-meter-card fallout-maw-skill-roll-card" data-action="rollSkill" data-skill-key="{{key}}" role="button" tabindex="0">
        <div class="fallout-maw-resource-card-header">
          <span class="fallout-maw-resource-name" title="{{abbr}} / {{key}}">{{label}}</span>
          <span class="fallout-maw-resource-value">
            <strong>{{value}}</strong>
            <span class="fallout-maw-resource-max">/ {{max}}</span>
          </span>
        </div>
        <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>Способности</h2>
    <div class="fallout-maw-ability-card-grid">
      {{#each abilities}}
      <article class="fallout-maw-ability-card" data-ability-id="{{id}}" data-tooltip-item="{{id}}">
        <img src="{{img}}" alt="" width="42" height="42">
        <strong>{{name}}</strong>
        {{#if ../freeEdit}}
        <button type="button" class="fallout-maw-ability-delete" data-action="deleteAbility" data-tooltip-ignore title="{{localize 'FALLOUTMAW.Common.Delete'}}">
          <i class="fa-solid fa-trash"></i>
        </button>
        {{/if}}
      </article>
      {{else}}
      <p class="fallout-maw-empty-list">Способности не изучены.</p>
      {{/each}}
    </div>
  </section>

  <section class="fallout-maw-panel">
    <h2>{{localize "FALLOUTMAW.Common.Proficiencies"}}</h2>
    <div class="fallout-maw-resource-grid">
      {{#each proficiencies}}
      <div class="fallout-maw-resource-card fallout-maw-resource-meter-card">
        <div class="fallout-maw-resource-card-header">
          <span class="fallout-maw-resource-name" title="{{abbr}} / {{key}}">{{label}}</span>
          <span class="fallout-maw-resource-value">
            {{#if ../freeEdit}}<input type="number" name="{{inputName}}" value="{{value}}" min="{{min}}" max="{{max}}">{{else}}<strong>{{value}}</strong>{{/if}}
            <span class="fallout-maw-resource-max">/ {{max}}</span>
          </span>
        </div>
        <div class="fallout-maw-resource-meter" style="{{meterStyle}}" role="meter" aria-valuemin="{{min}}" aria-valuenow="{{value}}" aria-valuemax="{{max}}">
          <span class="fallout-maw-resource-meter-fill" style="{{fillStyle}}"></span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{#if freeEdit}}
  <section class="fallout-maw-panel">
    <h2>Показатели</h2>
    <div class="fallout-maw-development-points-grid">
      {{#each developmentPointEntries}}
      <label>
        <span>{{label}}</span>
        <input type="number" data-development-point-input="{{key}}" value="{{value}}" min="0" step="1">
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}
</section>
