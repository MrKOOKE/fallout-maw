<section class="fallout-maw-craft-window-craft">
  {{#if recipe}}
  <header class="fallout-maw-craft-window-toolbar">
    <div class="fallout-maw-craft-window-title">
      <img src="{{recipe.img}}" alt="{{recipe.name}}" data-tooltip-uuid="{{recipe.uuid}}">
      <div class="fallout-maw-craft-window-title-body">
        <div class="fallout-maw-craft-window-title-main">
          <strong data-tooltip-uuid="{{recipe.uuid}}">{{recipe.name}}</strong>
          <span>{{craft.summary}}</span>
        </div>
      </div>
    </div>
    <div class="fallout-maw-craft-window-actions">
      {{#if craft.acquisition}}
      <button type="button" class="fallout-maw-craft-window-secondary-action" data-action="hideAcquisitionWays" title="Вернуться к схеме">
        <i class="fa-solid fa-arrow-left"></i>
        <span>Вернуться</span>
      </button>
      {{else if craft.usage}}
      <button type="button" class="fallout-maw-craft-window-secondary-action" data-action="hideAcquisitionWays" title="Вернуться к схеме">
        <i class="fa-solid fa-arrow-left"></i>
        <span>Вернуться</span>
      </button>
      {{else}}
      <button type="button" class="fallout-maw-craft-window-secondary-action" data-action="showAcquisitionWays" title="Показать способы получения" {{#unless craft.canShowAcquisitionWays}}disabled{{/unless}}>
        <i class="fa-solid fa-route"></i>
        <span>Показать способы получения</span>
      </button>
      <button type="button" class="fallout-maw-craft-window-hammer" data-action="craft" title="{{craft.actionTitle}}" {{#unless craft.canCraft}}disabled{{/unless}}>
        <i class="fa-solid {{craft.actionIcon}}"></i>
      </button>
      {{/if}}
    </div>
  </header>

  {{#if craft.acquisition}}
  <div class="fallout-maw-craft-acquisition">
    <header class="fallout-maw-craft-acquisition-header">
      <div>
        <h2>Показать способы получения</h2>
        <span>{{craft.acquisition.targetName}}</span>
      </div>
      <strong>{{craft.acquisition.entries.length}}</strong>
    </header>
    {{#if craft.acquisition.entries.length}}
    <div class="fallout-maw-craft-acquisition-list">
      {{#each craft.acquisition.entries}}
      <article class="fallout-maw-craft-acquisition-entry {{statusClass}}" data-acquisition-recipe-uuid="{{recipeSelectionUuid}}" data-acquisition-recipe-mode="{{mode}}" role="button" tabindex="0">
        <img src="{{img}}" alt="{{name}}">
        <div class="fallout-maw-craft-acquisition-entry-body">
          <div class="fallout-maw-craft-acquisition-entry-title">
            <strong>{{name}}</strong>
            <span class="{{statusClass}}">{{statusLabel}}</span>
          </div>
          <div class="fallout-maw-craft-acquisition-entry-meta">
            <span>{{category}}</span>
            <span>{{targetQuantityLabel}}</span>
          </div>
          <div class="fallout-maw-craft-acquisition-outputs">
            {{#each outputs}}
            <span class="fallout-maw-craft-acquisition-chip {{#if target}}target{{/if}}" data-tooltip-uuid="{{uuid}}">
              <img src="{{img}}" alt="{{name}}">
              <span>{{name}}</span>
              <strong>{{quantityLabel}}</strong>
            </span>
            {{/each}}
          </div>
        </div>
      </article>
      {{/each}}
    </div>
    {{else}}
    <div class="fallout-maw-craft-acquisition-empty">Нет разборов, которые дают этот предмет.</div>
    {{/if}}
  </div>
  {{else if craft.usage}}
  <div class="fallout-maw-craft-acquisition">
    <header class="fallout-maw-craft-acquisition-header">
      <div>
        <h2>Показать в каких крафтах участвует</h2>
        <span>{{craft.usage.targetName}}</span>
      </div>
      <strong>{{craft.usage.entries.length}}</strong>
    </header>
    {{#if craft.usage.entries.length}}
    <div class="fallout-maw-craft-acquisition-list">
      {{#each craft.usage.entries}}
      <article class="fallout-maw-craft-acquisition-entry {{statusClass}}" data-acquisition-recipe-uuid="{{recipeSelectionUuid}}" data-acquisition-recipe-mode="{{mode}}" role="button" tabindex="0">
        <img src="{{img}}" alt="{{name}}">
        <div class="fallout-maw-craft-acquisition-entry-body">
          <div class="fallout-maw-craft-acquisition-entry-title">
            <strong>{{name}}</strong>
            <span class="{{statusClass}}">{{statusLabel}}</span>
          </div>
          <div class="fallout-maw-craft-acquisition-entry-meta">
            <span>{{category}}</span>
            <span>{{targetQuantityLabel}}</span>
          </div>
        </div>
      </article>
      {{/each}}
    </div>
    {{else}}
    <div class="fallout-maw-craft-acquisition-empty">Нет известных крафтов, где используется этот предмет.</div>
    {{/if}}
  </div>
  {{else}}
  <div class="fallout-maw-craft-editor fallout-maw-craft-viewer fallout-maw-craft-mode-{{craft.mode}}" data-craft-workspace style="{{craft.viewportStyle}}">
    <div class="fallout-maw-craft-world" data-craft-world style="{{craft.viewportStyle}}">
      <svg class="fallout-maw-craft-links" data-craft-links aria-hidden="true"></svg>
      {{#each craft.blocks}}
      <div class="fallout-maw-craft-block readonly" data-craft-block-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-label="{{label}}"></div>
      {{/each}}
      {{#each craft.nodes}}
      <div class="fallout-maw-craft-node readonly {{#if root}}root{{/if}} {{#if isToolRequirement}}tool-requirement{{/if}} {{#if toolPickerOpen}}selected{{/if}} {{#if missing}}missing{{/if}}" data-craft-node-id="{{id}}" data-craft-block-id="{{blockId}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" {{#if isToolRequirement}}data-craft-tool-node="true" data-search-actor-uuid="{{tooltipActorUuid}}" data-tooltip-item="{{tooltipItemId}}"{{else}}data-tooltip-uuid="{{tooltipUuid}}"{{/if}} style="{{style}}">
        <span class="fallout-maw-craft-node-image">
          <img src="{{img}}" alt="{{name}}">
          <span class="fallout-maw-craft-node-quantity">{{quantityLabel}}</span>
        </span>
        {{#if toolPickerOpen}}
        <div class="fallout-maw-craft-tool-picker" data-craft-tool-picker>
          <h3>{{name}}</h3>
          {{#each toolRequirements}}
          <section class="fallout-maw-craft-tool-picker-group">
            <p>{{toolLabel}} {{toolClass}}: {{owned}}/{{quantity}}</p>
            <div class="fallout-maw-craft-tool-picker-list">
              {{#each candidates}}
              <label class="{{#if selected}}selected{{/if}} {{#unless usable}}missing{{/unless}}">
                <input type="radio" name="craft-tool-{{../key}}" data-craft-tool-select="{{../key}}" data-instrument-id="{{id}}" {{#if selected}}checked{{/if}} aria-label="{{name}}">
                <img src="{{img}}" alt="{{name}}">
                <span>{{name}}</span>
                <strong>{{toolClass}} {{supplyValue}}</strong>
              </label>
              {{/each}}
            </div>
            {{#unless candidates.length}}
            <p>Подходящих инструментов нет.</p>
            {{/unless}}
          </section>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/each}}
      {{#each craft.blocks}}
      <div class="fallout-maw-craft-block-frame readonly" data-craft-block-frame-id="{{id}}" data-craft-x="{{x}}" data-craft-y="{{y}}" data-craft-width="{{width}}" data-craft-height="{{height}}" style="{{style}}" aria-hidden="true"></div>
      {{/each}}
    </div>
  </div>
  {{/if}}
  {{else}}
  <div class="fallout-maw-craft-window-empty">Выберите рецепт</div>
  {{/if}}
</section>
