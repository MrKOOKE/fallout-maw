<article class="fallout-maw-chat-card fallout-maw-finishing-blow-card">
  <header class="fallout-maw-damage-summary-header">
    <div>
      <h2>{{labels.title}}</h2>
    </div>
  </header>

  <section class="fallout-maw-finishing-blow-body">
    <div class="fallout-maw-damage-summary-victim-body">
      <strong class="fallout-maw-damage-summary-victim-name">{{target.name}}</strong>
      <div class="fallout-maw-damage-summary-damage-row">
        <span>{{labels.attacker}}</span>
        <b>{{attacker.name}}</b>
      </div>
      <div class="fallout-maw-damage-summary-damage-row">
        <span>{{labels.limb}}</span>
        <b>{{limb.label}}</b>
      </div>
    </div>
    <p>{{labels.description}}</p>
  </section>
</article>
