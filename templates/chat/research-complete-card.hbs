<article class="fallout-maw-chat-card fallout-maw-research-complete-card">
  <header>
    <h2>{{localize "FALLOUTMAW.Research.Completed"}}</h2>
    <span>{{actor.name}}</span>
  </header>

  <div class="fallout-maw-research-complete-result">
    <strong>{{research.name}}</strong>
    <span>{{research.progressLabel}} / {{research.targetLabel}}</span>
  </div>

  <p>{{completionMessage}}</p>
</article>
