<div class="fallout-maw-global-map-form">
  <div class="form-group"><label>Название</label><div class="form-fields"><input type="text" name="terrain.name" value="{{terrain.name}}" required></div></div>
  <div class="form-group"><label>Цвет</label><div class="form-fields"><input type="color" name="terrain.color" value="{{terrain.color}}"></div></div>
  <div class="form-group"><label>Сложность</label><div class="form-fields"><input type="number" name="terrain.difficulty" value="{{terrain.difficulty}}" step="1"></div></div>
  <div class="form-group"><label>Стоимость выхода из клетки, км</label><div class="form-fields"><input type="number" name="terrain.cellAreaKm" value="{{terrain.cellAreaKm}}" min="0.01" step="0.01"></div></div>
  <div class="form-group"><label>Радиус кисти</label><div class="form-fields"><input type="number" name="terrain.brushRadius" value="{{terrain.brushRadius}}" min="1" max="12"></div></div>
  <div class="hint">
    <div>ЛКМ добавляет клетки.</div>
    <div>Shift+ЛКМ удаляет клетки.</div>
    <div>Ctrl+ЛКМ перезаписывает клетки других местностей.</div>
  </div>
  <footer class="form-footer">
    <button type="submit"><i class="fa-solid fa-floppy-disk"></i> Сохранить</button>
    {{#if canDelete}}<button type="button" data-action="delete" class="danger"><i class="fa-solid fa-trash"></i> Удалить</button>{{/if}}
  </footer>
</div>
