<div class="fallout-maw-global-map-form">
  <div class="form-group">
    <label>Цвет связанной зоны</label>
    <div class="form-fields"><input type="color" name="entry.color" value="{{entry.entryColor}}"></div>
  </div>
  <div class="form-group">
    <label>Радиус кисти</label>
    <div class="form-fields"><input type="number" name="entry.brushRadius" value="{{entry.brushRadius}}" min="1" max="12"></div>
  </div>
  <div class="hint">
    <div>ЛКМ добавляет клетки.</div>
    <div>Shift+ЛКМ удаляет клетки.</div>
  </div>
  <footer class="form-footer">
    <button type="submit"><i class="fa-solid fa-floppy-disk"></i> Сохранить</button>
    {{#if hasCells}}<button type="button" data-action="clear" class="danger"><i class="fa-solid fa-trash"></i> Удалить зону</button>{{/if}}
  </footer>
</div>
