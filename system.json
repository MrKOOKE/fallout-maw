{
  "id": "fallout-maw",
  "type": "system",
  "title": "Fallout-MaW",
  "description": "A universal automation-focused tabletop system for Foundry Virtual Tabletop.",
  "version": "0.2.1",
  "compatibility": {
    "minimum": "14",
    "verified": "14.361"
  },
  "authors": [
    {
      "name": "Fallout-MaW Developers"
    }
  ],
  "esmodules": [
    "src/main.mjs"
  ],
  "styles": [
    "styles/fallout-maw.css",
    "styles/combat-carousel.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "ru",
      "name": "Русский",
      "path": "lang/ru.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "description"
        ]
      },
      "construct": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "Item": {
      "gear": {
        "htmlFields": [
          "description"
        ]
      },
      "ability": {
        "htmlFields": [
          "description"
        ]
      },
      "trauma": {
        "htmlFields": [
          "description"
        ]
      },
      "disease": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "RegionBehavior": {
      "fallout-maw.periodicDamage": {}
    }
  },
  "packs": [
    {
      "name": "fallout-mav-items",
      "label": "\u041f\u0440\u0435\u0434\u043c\u0435\u0442\u044b",
      "system": "fallout-maw",
      "path": "packs/fallout-mav-items",
      "type": "Item"
    },
    {
      "name": "fallout-mav-actors",
      "label": "\u041f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0438",
      "system": "fallout-maw",
      "path": "packs/fallout-mav-actors",
      "type": "Actor"
    },
    {
      "name": "fallout-mav-scenes",
      "label": "\u041a\u0430\u0440\u0442\u044b",
      "path": "packs/fallout-mav-scenes",
      "type": "Scene"
    }
  ],
  "packFolders": [
    {
      "name": "Fallout_MaV",
      "sorting": "m",
      "color": "#4f8f5b",
      "packs": [
        "fallout-mav-items",
        "fallout-mav-actors",
        "fallout-mav-scenes"
      ]
    }
  ],
  "socket": true,
  "persistentStorage": true,
  "initiative": "1d20 + @attributes.initiative",
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "resources.health",
  "secondaryTokenAttribute": "resources.dodge",
  "media": [],
  "readme": "README.md"
}
