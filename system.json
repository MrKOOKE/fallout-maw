{
  "id": "fallout-maw",
  "type": "system",
  "title": "Fallout-MaW",
  "description": "A universal automation-focused tabletop system for Foundry Virtual Tabletop.",
  "version": "0.2.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14.361"
  },
  "authors": [
    {
      "name": "Fallout-MaW Developers"
    }
  ],
  "esmodules": [
    "src/main.mjs"
  ],
  "styles": [
    "styles/fallout-maw.css",
    "styles/combat-carousel.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "ru",
      "name": "Русский",
      "path": "lang/ru.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "description"
        ]
      },
      "construct": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "Item": {
      "gear": {
        "htmlFields": [
          "description"
        ]
      },
      "ability": {
        "htmlFields": [
          "description"
        ]
      },
      "trauma": {
        "htmlFields": [
          "description"
        ]
      },
      "disease": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "RegionBehavior": {
      "fallout-maw.periodicDamage": {}
    }
  },
  "socket": true,
  "initiative": "1d20 + @attributes.initiative",
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "resources.health",
  "secondaryTokenAttribute": "resources.dodge",
  "media": [],
  "readme": "README.md"
}
